{"pageNumber":533,"juzNumber":27,"verses":[{"key":"55:41","surahNumber":55,"ayahNumber":41,"juzNumber":27,"pageNumber":533,"arabicText":"يُعْرَفُ ٱلْمُجْرِمُونَ بِسِيمَٰهُمْ فَيُؤْخَذُ بِٱلنَّوَٰصِى وَٱلْأَقْدَامِ","translationText":"Suçlular simalarından tanınırlar da, alın saçlarından ve ayaklarından yakalanırlar."},{"key":"55:42","surahNumber":55,"ayahNumber":42,"juzNumber":27,"pageNumber":533,"arabicText":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","translationText":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"key":"55:43","surahNumber":55,"ayahNumber":43,"juzNumber":27,"pageNumber":533,"arabicText":"هَٰذِهِۦ جَهَنَّمُ ٱلَّتِى يُكَذِّبُ بِهَا ٱلْمُجْرِمُونَ","translationText":"İşte suçluların yalanladıkları cehennem budur."},{"key":"55:44","surahNumber":55,"ayahNumber":44,"juzNumber":27,"pageNumber":533,"arabicText":"يَطُوفُونَ بَيْنَهَا وَبَيْنَ حَمِيمٍ ءَانٍۢ","translationText":"Onlar, cehennem ateşiyle kaynar su arasında dolaşır dururlar."},{"key":"55:45","surahNumber":55,"ayahNumber":45,"juzNumber":27,"pageNumber":533,"arabicText":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","translationText":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"key":"55:46","surahNumber":55,"ayahNumber":46,"juzNumber":27,"pageNumber":533,"arabicText":"وَلِمَنْ خَافَ مَقَامَ رَبِّهِۦ جَنَّتَانِ","translationText":"Rabbine karşı durmaktan korkan kimseye iki cennet vardır."},{"key":"55:47","surahNumber":55,"ayahNumber":47,"juzNumber":27,"pageNumber":533,"arabicText":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","translationText":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"key":"55:48","surahNumber":55,"ayahNumber":48,"juzNumber":27,"pageNumber":533,"arabicText":"ذَوَاتَآ أَفْنَانٍۢ","translationText":"Bu iki cennet türlü ağaçlarla doludur."},{"key":"55:49","surahNumber":55,"ayahNumber":49,"juzNumber":27,"pageNumber":533,"arabicText":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","translationText":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"key":"55:50","surahNumber":55,"ayahNumber":50,"juzNumber":27,"pageNumber":533,"arabicText":"فِيهِمَا عَيْنَانِ تَجْرِيَانِ","translationText":"Bu cennetlerden akan iki kaynak vardır."},{"key":"55:51","surahNumber":55,"ayahNumber":51,"juzNumber":27,"pageNumber":533,"arabicText":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","translationText":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"key":"55:52","surahNumber":55,"ayahNumber":52,"juzNumber":27,"pageNumber":533,"arabicText":"فِيهِمَا مِن كُلِّ فَٰكِهَةٍۢ زَوْجَانِ","translationText":"Bu cennetlerde türlü meyveden çift çift vardır."},{"key":"55:53","surahNumber":55,"ayahNumber":53,"juzNumber":27,"pageNumber":533,"arabicText":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","translationText":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"key":"55:54","surahNumber":55,"ayahNumber":54,"juzNumber":27,"pageNumber":533,"arabicText":"مُتَّكِـِٔينَ عَلَىٰ فُرُشٍۭ بَطَآئِنُهَا مِنْ إِسْتَبْرَقٍۢ ۚ وَجَنَى ٱلْجَنَّتَيْنِ دَانٍۢ","translationText":"Orada, örtüleri parlak atlastan yataklara yaslanırlar; iki cennetin meyvelerini de kolayca toplarlar."},{"key":"55:55","surahNumber":55,"ayahNumber":55,"juzNumber":27,"pageNumber":533,"arabicText":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","translationText":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"key":"55:56","surahNumber":55,"ayahNumber":56,"juzNumber":27,"pageNumber":533,"arabicText":"فِيهِنَّ قَٰصِرَٰتُ ٱلطَّرْفِ لَمْ يَطْمِثْهُنَّ إِنسٌۭ قَبْلَهُمْ وَلَا جَآنٌّۭ","translationText":"Orada, bakışlarını yalnız eşlerine çevirmiş, daha önce ne insan ve ne de cinlerin dokunmuş olduğu eşler vardır."},{"key":"55:57","surahNumber":55,"ayahNumber":57,"juzNumber":27,"pageNumber":533,"arabicText":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","translationText":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"key":"55:58","surahNumber":55,"ayahNumber":58,"juzNumber":27,"pageNumber":533,"arabicText":"كَأَنَّهُنَّ ٱلْيَاقُوتُ وَٱلْمَرْجَانُ","translationText":"Onlar yakut ve mercan gibidirler."},{"key":"55:59","surahNumber":55,"ayahNumber":59,"juzNumber":27,"pageNumber":533,"arabicText":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","translationText":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"key":"55:60","surahNumber":55,"ayahNumber":60,"juzNumber":27,"pageNumber":533,"arabicText":"هَلْ جَزَآءُ ٱلْإِحْسَٰنِ إِلَّا ٱلْإِحْسَٰنُ","translationText":"İyiliğin karşılığı ancak iyilik değil midir?"},{"key":"55:61","surahNumber":55,"ayahNumber":61,"juzNumber":27,"pageNumber":533,"arabicText":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","translationText":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"key":"55:62","surahNumber":55,"ayahNumber":62,"juzNumber":27,"pageNumber":533,"arabicText":"وَمِن دُونِهِمَا جَنَّتَانِ","translationText":"Bu iki cennetten başka iki cennet daha vardır."},{"key":"55:63","surahNumber":55,"ayahNumber":63,"juzNumber":27,"pageNumber":533,"arabicText":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","translationText":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"key":"55:64","surahNumber":55,"ayahNumber":64,"juzNumber":27,"pageNumber":533,"arabicText":"مُدْهَآمَّتَانِ","translationText":"Renkleri koyu yeşildir."},{"key":"55:65","surahNumber":55,"ayahNumber":65,"juzNumber":27,"pageNumber":533,"arabicText":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","translationText":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?"},{"key":"55:66","surahNumber":55,"ayahNumber":66,"juzNumber":27,"pageNumber":533,"arabicText":"فِيهِمَا عَيْنَانِ نَضَّاخَتَانِ","translationText":"İkisinde de durmadan fışkıran iki kaynak vardır."},{"key":"55:67","surahNumber":55,"ayahNumber":67,"juzNumber":27,"pageNumber":533,"arabicText":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","translationText":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız?"}],"translationEditionUsed":"tr.diyanet"}