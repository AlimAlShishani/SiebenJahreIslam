{"pageNumber":600,"juzNumber":30,"verses":[{"key":"100:10","surahNumber":100,"ayahNumber":10,"juzNumber":30,"pageNumber":600,"arabicText":"وَحُصِّلَ مَا فِى ٱلصُّدُورِ","translationText":"İnsan, kabirlerde bulunanların çıkarılacağı ve kalblerde olanların ortaya konulacağı bir zamanın geleceğini bilmez mi?"},{"key":"100:11","surahNumber":100,"ayahNumber":11,"juzNumber":30,"pageNumber":600,"arabicText":"إِنَّ رَبَّهُم بِهِمْ يَوْمَئِذٍۢ لَّخَبِيرٌۢ","translationText":"Doğrusu Rableri o gün onların her şeyinden haberdardır."},{"key":"101:1","surahNumber":101,"ayahNumber":1,"juzNumber":30,"pageNumber":600,"arabicText":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ ٱلْقَارِعَةُ","translationText":"Gürültü koparacak olan"},{"key":"101:2","surahNumber":101,"ayahNumber":2,"juzNumber":30,"pageNumber":600,"arabicText":"مَا ٱلْقَارِعَةُ","translationText":"Nedir o gürültü koparacak olan?"},{"key":"101:3","surahNumber":101,"ayahNumber":3,"juzNumber":30,"pageNumber":600,"arabicText":"وَمَآ أَدْرَىٰكَ مَا ٱلْقَارِعَةُ","translationText":"O gürültü koparacak olanın ne olduğunu sen bilir misin?"},{"key":"101:4","surahNumber":101,"ayahNumber":4,"juzNumber":30,"pageNumber":600,"arabicText":"يَوْمَ يَكُونُ ٱلنَّاسُ كَٱلْفَرَاشِ ٱلْمَبْثُوثِ","translationText":"O gün insanlar, ateş etrafında çırpınıp dökülen pervaneye dönecekler."},{"key":"101:5","surahNumber":101,"ayahNumber":5,"juzNumber":30,"pageNumber":600,"arabicText":"وَتَكُونُ ٱلْجِبَالُ كَٱلْعِهْنِ ٱلْمَنفُوشِ","translationText":"Dağlar, atılmış renkli yüne benzeyecekler."},{"key":"101:6","surahNumber":101,"ayahNumber":6,"juzNumber":30,"pageNumber":600,"arabicText":"فَأَمَّا مَن ثَقُلَتْ مَوَٰزِينُهُۥ","translationText":"Ama tartıları ağır gelen kimse hoş bir hayat içinde olacaktır."},{"key":"101:7","surahNumber":101,"ayahNumber":7,"juzNumber":30,"pageNumber":600,"arabicText":"فَهُوَ فِى عِيشَةٍۢ رَّاضِيَةٍۢ","translationText":"Ama tartıları ağır gelen kimse hoş bir hayat içinde olacaktır."},{"key":"101:8","surahNumber":101,"ayahNumber":8,"juzNumber":30,"pageNumber":600,"arabicText":"وَأَمَّا مَنْ خَفَّتْ مَوَٰزِينُهُۥ","translationText":"Tartıları hafif gelenler ise,"},{"key":"101:9","surahNumber":101,"ayahNumber":9,"juzNumber":30,"pageNumber":600,"arabicText":"فَأُمُّهُۥ هَاوِيَةٌۭ","translationText":"Onların yeri bir çukurdur."},{"key":"101:10","surahNumber":101,"ayahNumber":10,"juzNumber":30,"pageNumber":600,"arabicText":"وَمَآ أَدْرَىٰكَ مَا هِيَهْ","translationText":"O çukurun ne olduğunu sen bilir misin?"},{"key":"101:11","surahNumber":101,"ayahNumber":11,"juzNumber":30,"pageNumber":600,"arabicText":"نَارٌ حَامِيَةٌۢ","translationText":"O, kızgın bir ateştir."},{"key":"102:1","surahNumber":102,"ayahNumber":1,"juzNumber":30,"pageNumber":600,"arabicText":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ أَلْهَىٰكُمُ ٱلتَّكَاثُرُ","translationText":"Çoğunluk olmak iddianız sizi o kadar meşgul etti ki, mezarları ziyaretle oradakileri de sayacak kadar oldunuz."},{"key":"102:2","surahNumber":102,"ayahNumber":2,"juzNumber":30,"pageNumber":600,"arabicText":"حَتَّىٰ زُرْتُمُ ٱلْمَقَابِرَ","translationText":"Çoğunluk olmak iddianız sizi o kadar meşgul etti ki, mezarları ziyaretle oradakileri de sayacak kadar oldunuz."},{"key":"102:3","surahNumber":102,"ayahNumber":3,"juzNumber":30,"pageNumber":600,"arabicText":"كَلَّا سَوْفَ تَعْلَمُونَ","translationText":"Hayır; öyle olmayın; yakında bileceksiniz."},{"key":"102:4","surahNumber":102,"ayahNumber":4,"juzNumber":30,"pageNumber":600,"arabicText":"ثُمَّ كَلَّا سَوْفَ تَعْلَمُونَ","translationText":"Hayır; gözünüzü açın; yakında bileceksiniz."},{"key":"102:5","surahNumber":102,"ayahNumber":5,"juzNumber":30,"pageNumber":600,"arabicText":"كَلَّا لَوْ تَعْلَمُونَ عِلْمَ ٱلْيَقِينِ","translationText":"Dikkat edin, şayet yaptığınızın sonucunu kesin olarak bir bilseniz!"},{"key":"102:6","surahNumber":102,"ayahNumber":6,"juzNumber":30,"pageNumber":600,"arabicText":"لَتَرَوُنَّ ٱلْجَحِيمَ","translationText":"And olsun ki, cehennemi göreceksiniz."},{"key":"102:7","surahNumber":102,"ayahNumber":7,"juzNumber":30,"pageNumber":600,"arabicText":"ثُمَّ لَتَرَوُنَّهَا عَيْنَ ٱلْيَقِينِ","translationText":"And olsun ki, onu gözünüzle kesin olarak göreceksiniz."},{"key":"102:8","surahNumber":102,"ayahNumber":8,"juzNumber":30,"pageNumber":600,"arabicText":"ثُمَّ لَتُسْـَٔلُنَّ يَوْمَئِذٍ عَنِ ٱلنَّعِيمِ","translationText":"Sonra o gün, size verilmiş olan her nimetten sorguya çekileceksiniz."}],"translationEditionUsed":"tr.diyanet"}