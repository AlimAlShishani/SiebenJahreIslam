{"pageNumber":1,"juzNumber":1,"verses":[{"key":"1:1","surahNumber":1,"ayahNumber":1,"juzNumber":1,"pageNumber":1,"arabicText":"﻿بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ","translationText":"Rahman ve Rahim olan Allah'ın adıyla:"},{"key":"1:2","surahNumber":1,"ayahNumber":2,"juzNumber":1,"pageNumber":1,"arabicText":"ٱلْحَمْدُ لِلَّهِ رَبِّ ٱلْعَٰلَمِينَ","translationText":"Hamd, Alemlerin Rabbi Allah'a mahsustur."},{"key":"1:3","surahNumber":1,"ayahNumber":3,"juzNumber":1,"pageNumber":1,"arabicText":"ٱلرَّحْمَٰنِ ٱلرَّحِيمِ","translationText":"O Rahman ve Rahim'dir,"},{"key":"1:4","surahNumber":1,"ayahNumber":4,"juzNumber":1,"pageNumber":1,"arabicText":"مَٰلِكِ يَوْمِ ٱلدِّينِ","translationText":"Din Gününün sahibidir."},{"key":"1:5","surahNumber":1,"ayahNumber":5,"juzNumber":1,"pageNumber":1,"arabicText":"إِيَّاكَ نَعْبُدُ وَإِيَّاكَ نَسْتَعِينُ","translationText":"Ancak Sana kulluk eder ve yalnız Senden yardım dileriz."},{"key":"1:6","surahNumber":1,"ayahNumber":6,"juzNumber":1,"pageNumber":1,"arabicText":"ٱهْدِنَا ٱلصِّرَٰطَ ٱلْمُسْتَقِيمَ","translationText":"Bizi doğru yola eriştir."},{"key":"1:7","surahNumber":1,"ayahNumber":7,"juzNumber":1,"pageNumber":1,"arabicText":"صِرَٰطَ ٱلَّذِينَ أَنْعَمْتَ عَلَيْهِمْ غَيْرِ ٱلْمَغْضُوبِ عَلَيْهِمْ وَلَا ٱلضَّآلِّينَ","translationText":"Nimete erdirdiğin kimselerin yoluna; gazaba uğrayanların, ya da sapıtanların yoluna değil."}],"translationEditionUsed":"tr.diyanet"}