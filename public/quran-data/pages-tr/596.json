{"pageNumber":596,"juzNumber":30,"verses":[{"key":"92:15","surahNumber":92,"ayahNumber":15,"juzNumber":30,"pageNumber":596,"arabicText":"لَا يَصْلَىٰهَآ إِلَّا ٱلْأَشْقَى","translationText":"Oraya, yalanlayıp yüz çevirmiş olan o en azgından başkası yaslanmaz."},{"key":"92:16","surahNumber":92,"ayahNumber":16,"juzNumber":30,"pageNumber":596,"arabicText":"ٱلَّذِى كَذَّبَ وَتَوَلَّىٰ","translationText":"Oraya, yalanlayıp yüz çevirmiş olan o en azgından başkası yaslanmaz."},{"key":"92:17","surahNumber":92,"ayahNumber":17,"juzNumber":30,"pageNumber":596,"arabicText":"وَسَيُجَنَّبُهَا ٱلْأَتْقَى","translationText":"Arınmak için malını veren, en çok sakınan kimse ise ondan uzak tutulur."},{"key":"92:18","surahNumber":92,"ayahNumber":18,"juzNumber":30,"pageNumber":596,"arabicText":"ٱلَّذِى يُؤْتِى مَالَهُۥ يَتَزَكَّىٰ","translationText":"Arınmak için malını veren, en çok sakınan kimse ise ondan uzak tutulur."},{"key":"92:19","surahNumber":92,"ayahNumber":19,"juzNumber":30,"pageNumber":596,"arabicText":"وَمَا لِأَحَدٍ عِندَهُۥ مِن نِّعْمَةٍۢ تُجْزَىٰٓ","translationText":"O yaptığı iyiliği birinden karşılık görmek için değil, ancak yüce Rabbinin hoşnudluğunu (rızasını) gözeterek yapmıştır."},{"key":"92:20","surahNumber":92,"ayahNumber":20,"juzNumber":30,"pageNumber":596,"arabicText":"إِلَّا ٱبْتِغَآءَ وَجْهِ رَبِّهِ ٱلْأَعْلَىٰ","translationText":"O yaptığı iyiliği birinden karşılık görmek için değil, ancak yüce Rabbinin hoşnudluğunu (rızasını) gözeterek yapmıştır."},{"key":"92:21","surahNumber":92,"ayahNumber":21,"juzNumber":30,"pageNumber":596,"arabicText":"وَلَسَوْفَ يَرْضَىٰ","translationText":"Elbette kendisi de hoşnut (razı) olacaktır."},{"key":"93:1","surahNumber":93,"ayahNumber":1,"juzNumber":30,"pageNumber":596,"arabicText":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلضُّحَىٰ","translationText":"Kuşluk vaktine and olsun;"},{"key":"93:2","surahNumber":93,"ayahNumber":2,"juzNumber":30,"pageNumber":596,"arabicText":"وَٱلَّيْلِ إِذَا سَجَىٰ","translationText":"Sükun erdiği zaman geceye and olsun ki,"},{"key":"93:3","surahNumber":93,"ayahNumber":3,"juzNumber":30,"pageNumber":596,"arabicText":"مَا وَدَّعَكَ رَبُّكَ وَمَا قَلَىٰ","translationText":"Rabbin seni ne bıraktı ve ne de sana darıldı."},{"key":"93:4","surahNumber":93,"ayahNumber":4,"juzNumber":30,"pageNumber":596,"arabicText":"وَلَلْءَاخِرَةُ خَيْرٌۭ لَّكَ مِنَ ٱلْأُولَىٰ","translationText":"Doğrusu ahiret senin için dünyadan daha hayırlıdır."},{"key":"93:5","surahNumber":93,"ayahNumber":5,"juzNumber":30,"pageNumber":596,"arabicText":"وَلَسَوْفَ يُعْطِيكَ رَبُّكَ فَتَرْضَىٰٓ","translationText":"Rabbin şüphesiz sana verecek ve sen de hoşnut olacaksın."},{"key":"93:6","surahNumber":93,"ayahNumber":6,"juzNumber":30,"pageNumber":596,"arabicText":"أَلَمْ يَجِدْكَ يَتِيمًۭا فَـَٔاوَىٰ","translationText":"Seni öksüz bulup da barındırmadı mı?"},{"key":"93:7","surahNumber":93,"ayahNumber":7,"juzNumber":30,"pageNumber":596,"arabicText":"وَوَجَدَكَ ضَآلًّۭا فَهَدَىٰ","translationText":"Seni şaşırmış bulup, doğru yola eriştirmedi mi?"},{"key":"93:8","surahNumber":93,"ayahNumber":8,"juzNumber":30,"pageNumber":596,"arabicText":"وَوَجَدَكَ عَآئِلًۭا فَأَغْنَىٰ","translationText":"Seni fakir bulup zenginleştirmedi mi?"},{"key":"93:9","surahNumber":93,"ayahNumber":9,"juzNumber":30,"pageNumber":596,"arabicText":"فَأَمَّا ٱلْيَتِيمَ فَلَا تَقْهَرْ","translationText":"Öyleyse sakın öksüze kötü muamele etme;"},{"key":"93:10","surahNumber":93,"ayahNumber":10,"juzNumber":30,"pageNumber":596,"arabicText":"وَأَمَّا ٱلسَّآئِلَ فَلَا تَنْهَرْ","translationText":"Ve sakın bir şey isteyeni azarlama;"},{"key":"93:11","surahNumber":93,"ayahNumber":11,"juzNumber":30,"pageNumber":596,"arabicText":"وَأَمَّا بِنِعْمَةِ رَبِّكَ فَحَدِّثْ","translationText":"Yalnızca Rabbinin nimetini anlat."},{"key":"94:1","surahNumber":94,"ayahNumber":1,"juzNumber":30,"pageNumber":596,"arabicText":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ أَلَمْ نَشْرَحْ لَكَ صَدْرَكَ","translationText":"Senin gönlünü açmadık mı?"},{"key":"94:2","surahNumber":94,"ayahNumber":2,"juzNumber":30,"pageNumber":596,"arabicText":"وَوَضَعْنَا عَنكَ وِزْرَكَ","translationText":"Belini büken yükünü üzerinden almadık mı?"},{"key":"94:3","surahNumber":94,"ayahNumber":3,"juzNumber":30,"pageNumber":596,"arabicText":"ٱلَّذِىٓ أَنقَضَ ظَهْرَكَ","translationText":"Belini büken yükünü üzerinden almadık mı?"},{"key":"94:4","surahNumber":94,"ayahNumber":4,"juzNumber":30,"pageNumber":596,"arabicText":"وَرَفَعْنَا لَكَ ذِكْرَكَ","translationText":"Senin şanını yükseltmedik mi?"},{"key":"94:5","surahNumber":94,"ayahNumber":5,"juzNumber":30,"pageNumber":596,"arabicText":"فَإِنَّ مَعَ ٱلْعُسْرِ يُسْرًا","translationText":"Elbette güçlükle beraber şüphesiz bir kolaylık vardır."},{"key":"94:6","surahNumber":94,"ayahNumber":6,"juzNumber":30,"pageNumber":596,"arabicText":"إِنَّ مَعَ ٱلْعُسْرِ يُسْرًۭا","translationText":"Gerçekten, güçlükle beraber bir kolaylık vardır."},{"key":"94:7","surahNumber":94,"ayahNumber":7,"juzNumber":30,"pageNumber":596,"arabicText":"فَإِذَا فَرَغْتَ فَٱنصَبْ","translationText":"Öyleyse, bir işi bitirince diğerine giriş;"},{"key":"94:8","surahNumber":94,"ayahNumber":8,"juzNumber":30,"pageNumber":596,"arabicText":"وَإِلَىٰ رَبِّكَ فَٱرْغَب","translationText":"Ve ümit edeceğini yalnız Rabbinden iste."}],"translationEditionUsed":"tr.diyanet"}