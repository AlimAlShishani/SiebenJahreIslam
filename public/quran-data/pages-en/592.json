{"pageNumber":592,"juzNumber":30,"verses":[{"key":"87:16","surahNumber":87,"ayahNumber":16,"juzNumber":30,"pageNumber":592,"arabicText":"بَلْ تُؤْثِرُونَ ٱلْحَيَوٰةَ ٱلدُّنْيَا","translationText":"But you prefer the worldly life,"},{"key":"87:17","surahNumber":87,"ayahNumber":17,"juzNumber":30,"pageNumber":592,"arabicText":"وَٱلْءَاخِرَةُ خَيْرٌۭ وَأَبْقَىٰٓ","translationText":"While the Hereafter is better and more enduring."},{"key":"87:18","surahNumber":87,"ayahNumber":18,"juzNumber":30,"pageNumber":592,"arabicText":"إِنَّ هَٰذَا لَفِى ٱلصُّحُفِ ٱلْأُولَىٰ","translationText":"Indeed, this is in the former scriptures,"},{"key":"87:19","surahNumber":87,"ayahNumber":19,"juzNumber":30,"pageNumber":592,"arabicText":"صُحُفِ إِبْرَٰهِيمَ وَمُوسَىٰ","translationText":"The scriptures of Abraham and Moses."},{"key":"88:1","surahNumber":88,"ayahNumber":1,"juzNumber":30,"pageNumber":592,"arabicText":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ هَلْ أَتَىٰكَ حَدِيثُ ٱلْغَٰشِيَةِ","translationText":"Has there reached you the report of the Overwhelming [event]?"},{"key":"88:2","surahNumber":88,"ayahNumber":2,"juzNumber":30,"pageNumber":592,"arabicText":"وُجُوهٌۭ يَوْمَئِذٍ خَٰشِعَةٌ","translationText":"[Some] faces, that Day, will be humbled,"},{"key":"88:3","surahNumber":88,"ayahNumber":3,"juzNumber":30,"pageNumber":592,"arabicText":"عَامِلَةٌۭ نَّاصِبَةٌۭ","translationText":"Working [hard] and exhausted."},{"key":"88:4","surahNumber":88,"ayahNumber":4,"juzNumber":30,"pageNumber":592,"arabicText":"تَصْلَىٰ نَارًا حَامِيَةًۭ","translationText":"They will [enter to] burn in an intensely hot Fire."},{"key":"88:5","surahNumber":88,"ayahNumber":5,"juzNumber":30,"pageNumber":592,"arabicText":"تُسْقَىٰ مِنْ عَيْنٍ ءَانِيَةٍۢ","translationText":"They will be given drink from a boiling spring."},{"key":"88:6","surahNumber":88,"ayahNumber":6,"juzNumber":30,"pageNumber":592,"arabicText":"لَّيْسَ لَهُمْ طَعَامٌ إِلَّا مِن ضَرِيعٍۢ","translationText":"For them there will be no food except from a poisonous, thorny plant"},{"key":"88:7","surahNumber":88,"ayahNumber":7,"juzNumber":30,"pageNumber":592,"arabicText":"لَّا يُسْمِنُ وَلَا يُغْنِى مِن جُوعٍۢ","translationText":"Which neither nourishes nor avails against hunger."},{"key":"88:8","surahNumber":88,"ayahNumber":8,"juzNumber":30,"pageNumber":592,"arabicText":"وُجُوهٌۭ يَوْمَئِذٍۢ نَّاعِمَةٌۭ","translationText":"[Other] faces, that Day, will show pleasure."},{"key":"88:9","surahNumber":88,"ayahNumber":9,"juzNumber":30,"pageNumber":592,"arabicText":"لِّسَعْيِهَا رَاضِيَةٌۭ","translationText":"With their effort [they are] satisfied"},{"key":"88:10","surahNumber":88,"ayahNumber":10,"juzNumber":30,"pageNumber":592,"arabicText":"فِى جَنَّةٍ عَالِيَةٍۢ","translationText":"In an elevated garden,"},{"key":"88:11","surahNumber":88,"ayahNumber":11,"juzNumber":30,"pageNumber":592,"arabicText":"لَّا تَسْمَعُ فِيهَا لَٰغِيَةًۭ","translationText":"Wherein they will hear no unsuitable speech."},{"key":"88:12","surahNumber":88,"ayahNumber":12,"juzNumber":30,"pageNumber":592,"arabicText":"فِيهَا عَيْنٌۭ جَارِيَةٌۭ","translationText":"Within it is a flowing spring."},{"key":"88:13","surahNumber":88,"ayahNumber":13,"juzNumber":30,"pageNumber":592,"arabicText":"فِيهَا سُرُرٌۭ مَّرْفُوعَةٌۭ","translationText":"Within it are couches raised high"},{"key":"88:14","surahNumber":88,"ayahNumber":14,"juzNumber":30,"pageNumber":592,"arabicText":"وَأَكْوَابٌۭ مَّوْضُوعَةٌۭ","translationText":"And cups put in place"},{"key":"88:15","surahNumber":88,"ayahNumber":15,"juzNumber":30,"pageNumber":592,"arabicText":"وَنَمَارِقُ مَصْفُوفَةٌۭ","translationText":"And cushions lined up"},{"key":"88:16","surahNumber":88,"ayahNumber":16,"juzNumber":30,"pageNumber":592,"arabicText":"وَزَرَابِىُّ مَبْثُوثَةٌ","translationText":"And carpets spread around."},{"key":"88:17","surahNumber":88,"ayahNumber":17,"juzNumber":30,"pageNumber":592,"arabicText":"أَفَلَا يَنظُرُونَ إِلَى ٱلْإِبِلِ كَيْفَ خُلِقَتْ","translationText":"Then do they not look at the camels - how they are created?"},{"key":"88:18","surahNumber":88,"ayahNumber":18,"juzNumber":30,"pageNumber":592,"arabicText":"وَإِلَى ٱلسَّمَآءِ كَيْفَ رُفِعَتْ","translationText":"And at the sky - how it is raised?"},{"key":"88:19","surahNumber":88,"ayahNumber":19,"juzNumber":30,"pageNumber":592,"arabicText":"وَإِلَى ٱلْجِبَالِ كَيْفَ نُصِبَتْ","translationText":"And at the mountains - how they are erected?"},{"key":"88:20","surahNumber":88,"ayahNumber":20,"juzNumber":30,"pageNumber":592,"arabicText":"وَإِلَى ٱلْأَرْضِ كَيْفَ سُطِحَتْ","translationText":"And at the earth - how it is spread out?"},{"key":"88:21","surahNumber":88,"ayahNumber":21,"juzNumber":30,"pageNumber":592,"arabicText":"فَذَكِّرْ إِنَّمَآ أَنتَ مُذَكِّرٌۭ","translationText":"So remind, [O Muhammad]; you are only a reminder."},{"key":"88:22","surahNumber":88,"ayahNumber":22,"juzNumber":30,"pageNumber":592,"arabicText":"لَّسْتَ عَلَيْهِم بِمُصَيْطِرٍ","translationText":"You are not over them a controller."},{"key":"88:23","surahNumber":88,"ayahNumber":23,"juzNumber":30,"pageNumber":592,"arabicText":"إِلَّا مَن تَوَلَّىٰ وَكَفَرَ","translationText":"However, he who turns away and disbelieves -"},{"key":"88:24","surahNumber":88,"ayahNumber":24,"juzNumber":30,"pageNumber":592,"arabicText":"فَيُعَذِّبُهُ ٱللَّهُ ٱلْعَذَابَ ٱلْأَكْبَرَ","translationText":"Then Allah will punish him with the greatest punishment."},{"key":"88:25","surahNumber":88,"ayahNumber":25,"juzNumber":30,"pageNumber":592,"arabicText":"إِنَّ إِلَيْنَآ إِيَابَهُمْ","translationText":"Indeed, to Us is their return."},{"key":"88:26","surahNumber":88,"ayahNumber":26,"juzNumber":30,"pageNumber":592,"arabicText":"ثُمَّ إِنَّ عَلَيْنَا حِسَابَهُم","translationText":"Then indeed, upon Us is their account."}],"translationEditionUsed":"en.sahih"}