{"pageNumber":600,"juzNumber":30,"verses":[{"key":"100:10","surahNumber":100,"ayahNumber":10,"juzNumber":30,"pageNumber":600,"arabicText":"وَحُصِّلَ مَا فِى ٱلصُّدُورِ","translationText":"And that within the breasts is obtained,"},{"key":"100:11","surahNumber":100,"ayahNumber":11,"juzNumber":30,"pageNumber":600,"arabicText":"إِنَّ رَبَّهُم بِهِمْ يَوْمَئِذٍۢ لَّخَبِيرٌۢ","translationText":"Indeed, their Lord with them, that Day, is [fully] Acquainted."},{"key":"101:1","surahNumber":101,"ayahNumber":1,"juzNumber":30,"pageNumber":600,"arabicText":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ ٱلْقَارِعَةُ","translationText":"The Striking Calamity -"},{"key":"101:2","surahNumber":101,"ayahNumber":2,"juzNumber":30,"pageNumber":600,"arabicText":"مَا ٱلْقَارِعَةُ","translationText":"What is the Striking Calamity?"},{"key":"101:3","surahNumber":101,"ayahNumber":3,"juzNumber":30,"pageNumber":600,"arabicText":"وَمَآ أَدْرَىٰكَ مَا ٱلْقَارِعَةُ","translationText":"And what can make you know what is the Striking Calamity?"},{"key":"101:4","surahNumber":101,"ayahNumber":4,"juzNumber":30,"pageNumber":600,"arabicText":"يَوْمَ يَكُونُ ٱلنَّاسُ كَٱلْفَرَاشِ ٱلْمَبْثُوثِ","translationText":"It is the Day when people will be like moths, dispersed,"},{"key":"101:5","surahNumber":101,"ayahNumber":5,"juzNumber":30,"pageNumber":600,"arabicText":"وَتَكُونُ ٱلْجِبَالُ كَٱلْعِهْنِ ٱلْمَنفُوشِ","translationText":"And the mountains will be like wool, fluffed up."},{"key":"101:6","surahNumber":101,"ayahNumber":6,"juzNumber":30,"pageNumber":600,"arabicText":"فَأَمَّا مَن ثَقُلَتْ مَوَٰزِينُهُۥ","translationText":"Then as for one whose scales are heavy [with good deeds],"},{"key":"101:7","surahNumber":101,"ayahNumber":7,"juzNumber":30,"pageNumber":600,"arabicText":"فَهُوَ فِى عِيشَةٍۢ رَّاضِيَةٍۢ","translationText":"He will be in a pleasant life."},{"key":"101:8","surahNumber":101,"ayahNumber":8,"juzNumber":30,"pageNumber":600,"arabicText":"وَأَمَّا مَنْ خَفَّتْ مَوَٰزِينُهُۥ","translationText":"But as for one whose scales are light,"},{"key":"101:9","surahNumber":101,"ayahNumber":9,"juzNumber":30,"pageNumber":600,"arabicText":"فَأُمُّهُۥ هَاوِيَةٌۭ","translationText":"His refuge will be an abyss."},{"key":"101:10","surahNumber":101,"ayahNumber":10,"juzNumber":30,"pageNumber":600,"arabicText":"وَمَآ أَدْرَىٰكَ مَا هِيَهْ","translationText":"And what can make you know what that is?"},{"key":"101:11","surahNumber":101,"ayahNumber":11,"juzNumber":30,"pageNumber":600,"arabicText":"نَارٌ حَامِيَةٌۢ","translationText":"It is a Fire, intensely hot."},{"key":"102:1","surahNumber":102,"ayahNumber":1,"juzNumber":30,"pageNumber":600,"arabicText":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ أَلْهَىٰكُمُ ٱلتَّكَاثُرُ","translationText":"Competition in [worldly] increase diverts you"},{"key":"102:2","surahNumber":102,"ayahNumber":2,"juzNumber":30,"pageNumber":600,"arabicText":"حَتَّىٰ زُرْتُمُ ٱلْمَقَابِرَ","translationText":"Until you visit the graveyards."},{"key":"102:3","surahNumber":102,"ayahNumber":3,"juzNumber":30,"pageNumber":600,"arabicText":"كَلَّا سَوْفَ تَعْلَمُونَ","translationText":"No! You are going to know."},{"key":"102:4","surahNumber":102,"ayahNumber":4,"juzNumber":30,"pageNumber":600,"arabicText":"ثُمَّ كَلَّا سَوْفَ تَعْلَمُونَ","translationText":"Then no! You are going to know."},{"key":"102:5","surahNumber":102,"ayahNumber":5,"juzNumber":30,"pageNumber":600,"arabicText":"كَلَّا لَوْ تَعْلَمُونَ عِلْمَ ٱلْيَقِينِ","translationText":"No! If you only knew with knowledge of certainty..."},{"key":"102:6","surahNumber":102,"ayahNumber":6,"juzNumber":30,"pageNumber":600,"arabicText":"لَتَرَوُنَّ ٱلْجَحِيمَ","translationText":"You will surely see the Hellfire."},{"key":"102:7","surahNumber":102,"ayahNumber":7,"juzNumber":30,"pageNumber":600,"arabicText":"ثُمَّ لَتَرَوُنَّهَا عَيْنَ ٱلْيَقِينِ","translationText":"Then you will surely see it with the eye of certainty."},{"key":"102:8","surahNumber":102,"ayahNumber":8,"juzNumber":30,"pageNumber":600,"arabicText":"ثُمَّ لَتُسْـَٔلُنَّ يَوْمَئِذٍ عَنِ ٱلنَّعِيمِ","translationText":"Then you will surely be asked that Day about pleasure."}],"translationEditionUsed":"en.sahih"}