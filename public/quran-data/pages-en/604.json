{"pageNumber":604,"juzNumber":30,"verses":[{"key":"112:1","surahNumber":112,"ayahNumber":1,"juzNumber":30,"pageNumber":604,"arabicText":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ قُلْ هُوَ ٱللَّهُ أَحَدٌ","translationText":"Say, \"He is Allah, [who is] One,"},{"key":"112:2","surahNumber":112,"ayahNumber":2,"juzNumber":30,"pageNumber":604,"arabicText":"ٱللَّهُ ٱلصَّمَدُ","translationText":"Allah, the Eternal Refuge."},{"key":"112:3","surahNumber":112,"ayahNumber":3,"juzNumber":30,"pageNumber":604,"arabicText":"لَمْ يَلِدْ وَلَمْ يُولَدْ","translationText":"He neither begets nor is born,"},{"key":"112:4","surahNumber":112,"ayahNumber":4,"juzNumber":30,"pageNumber":604,"arabicText":"وَلَمْ يَكُن لَّهُۥ كُفُوًا أَحَدٌۢ","translationText":"Nor is there to Him any equivalent.\""},{"key":"113:1","surahNumber":113,"ayahNumber":1,"juzNumber":30,"pageNumber":604,"arabicText":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ قُلْ أَعُوذُ بِرَبِّ ٱلْفَلَقِ","translationText":"Say, \"I seek refuge in the Lord of daybreak"},{"key":"113:2","surahNumber":113,"ayahNumber":2,"juzNumber":30,"pageNumber":604,"arabicText":"مِن شَرِّ مَا خَلَقَ","translationText":"From the evil of that which He created"},{"key":"113:3","surahNumber":113,"ayahNumber":3,"juzNumber":30,"pageNumber":604,"arabicText":"وَمِن شَرِّ غَاسِقٍ إِذَا وَقَبَ","translationText":"And from the evil of darkness when it settles"},{"key":"113:4","surahNumber":113,"ayahNumber":4,"juzNumber":30,"pageNumber":604,"arabicText":"وَمِن شَرِّ ٱلنَّفَّٰثَٰتِ فِى ٱلْعُقَدِ","translationText":"And from the evil of the blowers in knots"},{"key":"113:5","surahNumber":113,"ayahNumber":5,"juzNumber":30,"pageNumber":604,"arabicText":"وَمِن شَرِّ حَاسِدٍ إِذَا حَسَدَ","translationText":"And from the evil of an envier when he envies.\""},{"key":"114:1","surahNumber":114,"ayahNumber":1,"juzNumber":30,"pageNumber":604,"arabicText":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ قُلْ أَعُوذُ بِرَبِّ ٱلنَّاسِ","translationText":"Say, \"I seek refuge in the Lord of mankind,"},{"key":"114:2","surahNumber":114,"ayahNumber":2,"juzNumber":30,"pageNumber":604,"arabicText":"مَلِكِ ٱلنَّاسِ","translationText":"The Sovereign of mankind."},{"key":"114:3","surahNumber":114,"ayahNumber":3,"juzNumber":30,"pageNumber":604,"arabicText":"إِلَٰهِ ٱلنَّاسِ","translationText":"The God of mankind,"},{"key":"114:4","surahNumber":114,"ayahNumber":4,"juzNumber":30,"pageNumber":604,"arabicText":"مِن شَرِّ ٱلْوَسْوَاسِ ٱلْخَنَّاسِ","translationText":"From the evil of the retreating whisperer -"},{"key":"114:5","surahNumber":114,"ayahNumber":5,"juzNumber":30,"pageNumber":604,"arabicText":"ٱلَّذِى يُوَسْوِسُ فِى صُدُورِ ٱلنَّاسِ","translationText":"Who whispers [evil] into the breasts of mankind -"},{"key":"114:6","surahNumber":114,"ayahNumber":6,"juzNumber":30,"pageNumber":604,"arabicText":"مِنَ ٱلْجِنَّةِ وَٱلنَّاسِ","translationText":"From among the jinn and mankind.\""}],"translationEditionUsed":"en.sahih"}