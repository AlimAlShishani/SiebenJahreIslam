{"pageNumber":596,"juzNumber":30,"verses":[{"key":"92:15","surahNumber":92,"ayahNumber":15,"juzNumber":30,"pageNumber":596,"arabicText":"لَا يَصْلَىٰهَآ إِلَّا ٱلْأَشْقَى","translationText":"None will [enter to] burn therein except the most wretched one."},{"key":"92:16","surahNumber":92,"ayahNumber":16,"juzNumber":30,"pageNumber":596,"arabicText":"ٱلَّذِى كَذَّبَ وَتَوَلَّىٰ","translationText":"Who had denied and turned away."},{"key":"92:17","surahNumber":92,"ayahNumber":17,"juzNumber":30,"pageNumber":596,"arabicText":"وَسَيُجَنَّبُهَا ٱلْأَتْقَى","translationText":"But the righteous one will avoid it -"},{"key":"92:18","surahNumber":92,"ayahNumber":18,"juzNumber":30,"pageNumber":596,"arabicText":"ٱلَّذِى يُؤْتِى مَالَهُۥ يَتَزَكَّىٰ","translationText":"[He] who gives [from] his wealth to purify himself"},{"key":"92:19","surahNumber":92,"ayahNumber":19,"juzNumber":30,"pageNumber":596,"arabicText":"وَمَا لِأَحَدٍ عِندَهُۥ مِن نِّعْمَةٍۢ تُجْزَىٰٓ","translationText":"And not [giving] for anyone who has [done him] a favor to be rewarded"},{"key":"92:20","surahNumber":92,"ayahNumber":20,"juzNumber":30,"pageNumber":596,"arabicText":"إِلَّا ٱبْتِغَآءَ وَجْهِ رَبِّهِ ٱلْأَعْلَىٰ","translationText":"But only seeking the countenance of his Lord, Most High."},{"key":"92:21","surahNumber":92,"ayahNumber":21,"juzNumber":30,"pageNumber":596,"arabicText":"وَلَسَوْفَ يَرْضَىٰ","translationText":"And he is going to be satisfied."},{"key":"93:1","surahNumber":93,"ayahNumber":1,"juzNumber":30,"pageNumber":596,"arabicText":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلضُّحَىٰ","translationText":"By the morning brightness"},{"key":"93:2","surahNumber":93,"ayahNumber":2,"juzNumber":30,"pageNumber":596,"arabicText":"وَٱلَّيْلِ إِذَا سَجَىٰ","translationText":"And [by] the night when it covers with darkness,"},{"key":"93:3","surahNumber":93,"ayahNumber":3,"juzNumber":30,"pageNumber":596,"arabicText":"مَا وَدَّعَكَ رَبُّكَ وَمَا قَلَىٰ","translationText":"Your Lord has not taken leave of you, [O Muhammad], nor has He detested [you]."},{"key":"93:4","surahNumber":93,"ayahNumber":4,"juzNumber":30,"pageNumber":596,"arabicText":"وَلَلْءَاخِرَةُ خَيْرٌۭ لَّكَ مِنَ ٱلْأُولَىٰ","translationText":"And the Hereafter is better for you than the first [life]."},{"key":"93:5","surahNumber":93,"ayahNumber":5,"juzNumber":30,"pageNumber":596,"arabicText":"وَلَسَوْفَ يُعْطِيكَ رَبُّكَ فَتَرْضَىٰٓ","translationText":"And your Lord is going to give you, and you will be satisfied."},{"key":"93:6","surahNumber":93,"ayahNumber":6,"juzNumber":30,"pageNumber":596,"arabicText":"أَلَمْ يَجِدْكَ يَتِيمًۭا فَـَٔاوَىٰ","translationText":"Did He not find you an orphan and give [you] refuge?"},{"key":"93:7","surahNumber":93,"ayahNumber":7,"juzNumber":30,"pageNumber":596,"arabicText":"وَوَجَدَكَ ضَآلًّۭا فَهَدَىٰ","translationText":"And He found you lost and guided [you],"},{"key":"93:8","surahNumber":93,"ayahNumber":8,"juzNumber":30,"pageNumber":596,"arabicText":"وَوَجَدَكَ عَآئِلًۭا فَأَغْنَىٰ","translationText":"And He found you poor and made [you] self-sufficient."},{"key":"93:9","surahNumber":93,"ayahNumber":9,"juzNumber":30,"pageNumber":596,"arabicText":"فَأَمَّا ٱلْيَتِيمَ فَلَا تَقْهَرْ","translationText":"So as for the orphan, do not oppress [him]."},{"key":"93:10","surahNumber":93,"ayahNumber":10,"juzNumber":30,"pageNumber":596,"arabicText":"وَأَمَّا ٱلسَّآئِلَ فَلَا تَنْهَرْ","translationText":"And as for the petitioner, do not repel [him]."},{"key":"93:11","surahNumber":93,"ayahNumber":11,"juzNumber":30,"pageNumber":596,"arabicText":"وَأَمَّا بِنِعْمَةِ رَبِّكَ فَحَدِّثْ","translationText":"But as for the favor of your Lord, report [it]."},{"key":"94:1","surahNumber":94,"ayahNumber":1,"juzNumber":30,"pageNumber":596,"arabicText":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ أَلَمْ نَشْرَحْ لَكَ صَدْرَكَ","translationText":"Did We not expand for you, [O Muhammad], your breast?"},{"key":"94:2","surahNumber":94,"ayahNumber":2,"juzNumber":30,"pageNumber":596,"arabicText":"وَوَضَعْنَا عَنكَ وِزْرَكَ","translationText":"And We removed from you your burden"},{"key":"94:3","surahNumber":94,"ayahNumber":3,"juzNumber":30,"pageNumber":596,"arabicText":"ٱلَّذِىٓ أَنقَضَ ظَهْرَكَ","translationText":"Which had weighed upon your back"},{"key":"94:4","surahNumber":94,"ayahNumber":4,"juzNumber":30,"pageNumber":596,"arabicText":"وَرَفَعْنَا لَكَ ذِكْرَكَ","translationText":"And raised high for you your repute."},{"key":"94:5","surahNumber":94,"ayahNumber":5,"juzNumber":30,"pageNumber":596,"arabicText":"فَإِنَّ مَعَ ٱلْعُسْرِ يُسْرًا","translationText":"For indeed, with hardship [will be] ease."},{"key":"94:6","surahNumber":94,"ayahNumber":6,"juzNumber":30,"pageNumber":596,"arabicText":"إِنَّ مَعَ ٱلْعُسْرِ يُسْرًۭا","translationText":"Indeed, with hardship [will be] ease."},{"key":"94:7","surahNumber":94,"ayahNumber":7,"juzNumber":30,"pageNumber":596,"arabicText":"فَإِذَا فَرَغْتَ فَٱنصَبْ","translationText":"So when you have finished [your duties], then stand up [for worship]."},{"key":"94:8","surahNumber":94,"ayahNumber":8,"juzNumber":30,"pageNumber":596,"arabicText":"وَإِلَىٰ رَبِّكَ فَٱرْغَب","translationText":"And to your Lord direct [your] longing."}],"translationEditionUsed":"en.sahih"}