{"pageNumber":585,"juzNumber":30,"verses":[{"key":"80:1","surahNumber":80,"ayahNumber":1,"juzNumber":30,"pageNumber":585,"arabicText":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ عَبَسَ وَتَوَلَّىٰٓ","translationText":"The Prophet frowned and turned away"},{"key":"80:2","surahNumber":80,"ayahNumber":2,"juzNumber":30,"pageNumber":585,"arabicText":"أَن جَآءَهُ ٱلْأَعْمَىٰ","translationText":"Because there came to him the blind man, [interrupting]."},{"key":"80:3","surahNumber":80,"ayahNumber":3,"juzNumber":30,"pageNumber":585,"arabicText":"وَمَا يُدْرِيكَ لَعَلَّهُۥ يَزَّكَّىٰٓ","translationText":"But what would make you perceive, [O Muhammad], that perhaps he might be purified"},{"key":"80:4","surahNumber":80,"ayahNumber":4,"juzNumber":30,"pageNumber":585,"arabicText":"أَوْ يَذَّكَّرُ فَتَنفَعَهُ ٱلذِّكْرَىٰٓ","translationText":"Or be reminded and the remembrance would benefit him?"},{"key":"80:5","surahNumber":80,"ayahNumber":5,"juzNumber":30,"pageNumber":585,"arabicText":"أَمَّا مَنِ ٱسْتَغْنَىٰ","translationText":"As for he who thinks himself without need,"},{"key":"80:6","surahNumber":80,"ayahNumber":6,"juzNumber":30,"pageNumber":585,"arabicText":"فَأَنتَ لَهُۥ تَصَدَّىٰ","translationText":"To him you give attention."},{"key":"80:7","surahNumber":80,"ayahNumber":7,"juzNumber":30,"pageNumber":585,"arabicText":"وَمَا عَلَيْكَ أَلَّا يَزَّكَّىٰ","translationText":"And not upon you [is any blame] if he will not be purified."},{"key":"80:8","surahNumber":80,"ayahNumber":8,"juzNumber":30,"pageNumber":585,"arabicText":"وَأَمَّا مَن جَآءَكَ يَسْعَىٰ","translationText":"But as for he who came to you striving [for knowledge]"},{"key":"80:9","surahNumber":80,"ayahNumber":9,"juzNumber":30,"pageNumber":585,"arabicText":"وَهُوَ يَخْشَىٰ","translationText":"While he fears [Allah],"},{"key":"80:10","surahNumber":80,"ayahNumber":10,"juzNumber":30,"pageNumber":585,"arabicText":"فَأَنتَ عَنْهُ تَلَهَّىٰ","translationText":"From him you are distracted."},{"key":"80:11","surahNumber":80,"ayahNumber":11,"juzNumber":30,"pageNumber":585,"arabicText":"كَلَّآ إِنَّهَا تَذْكِرَةٌۭ","translationText":"No! Indeed, these verses are a reminder;"},{"key":"80:12","surahNumber":80,"ayahNumber":12,"juzNumber":30,"pageNumber":585,"arabicText":"فَمَن شَآءَ ذَكَرَهُۥ","translationText":"So whoever wills may remember it."},{"key":"80:13","surahNumber":80,"ayahNumber":13,"juzNumber":30,"pageNumber":585,"arabicText":"فِى صُحُفٍۢ مُّكَرَّمَةٍۢ","translationText":"[It is recorded] in honored sheets,"},{"key":"80:14","surahNumber":80,"ayahNumber":14,"juzNumber":30,"pageNumber":585,"arabicText":"مَّرْفُوعَةٍۢ مُّطَهَّرَةٍۭ","translationText":"Exalted and purified,"},{"key":"80:15","surahNumber":80,"ayahNumber":15,"juzNumber":30,"pageNumber":585,"arabicText":"بِأَيْدِى سَفَرَةٍۢ","translationText":"[Carried] by the hands of messenger-angels,"},{"key":"80:16","surahNumber":80,"ayahNumber":16,"juzNumber":30,"pageNumber":585,"arabicText":"كِرَامٍۭ بَرَرَةٍۢ","translationText":"Noble and dutiful."},{"key":"80:17","surahNumber":80,"ayahNumber":17,"juzNumber":30,"pageNumber":585,"arabicText":"قُتِلَ ٱلْإِنسَٰنُ مَآ أَكْفَرَهُۥ","translationText":"Cursed is man; how disbelieving is he."},{"key":"80:18","surahNumber":80,"ayahNumber":18,"juzNumber":30,"pageNumber":585,"arabicText":"مِنْ أَىِّ شَىْءٍ خَلَقَهُۥ","translationText":"From what substance did He create him?"},{"key":"80:19","surahNumber":80,"ayahNumber":19,"juzNumber":30,"pageNumber":585,"arabicText":"مِن نُّطْفَةٍ خَلَقَهُۥ فَقَدَّرَهُۥ","translationText":"From a sperm-drop He created him and destined for him;"},{"key":"80:20","surahNumber":80,"ayahNumber":20,"juzNumber":30,"pageNumber":585,"arabicText":"ثُمَّ ٱلسَّبِيلَ يَسَّرَهُۥ","translationText":"Then He eased the way for him;"},{"key":"80:21","surahNumber":80,"ayahNumber":21,"juzNumber":30,"pageNumber":585,"arabicText":"ثُمَّ أَمَاتَهُۥ فَأَقْبَرَهُۥ","translationText":"Then He causes his death and provides a grave for him."},{"key":"80:22","surahNumber":80,"ayahNumber":22,"juzNumber":30,"pageNumber":585,"arabicText":"ثُمَّ إِذَا شَآءَ أَنشَرَهُۥ","translationText":"Then when He wills, He will resurrect him."},{"key":"80:23","surahNumber":80,"ayahNumber":23,"juzNumber":30,"pageNumber":585,"arabicText":"كَلَّا لَمَّا يَقْضِ مَآ أَمَرَهُۥ","translationText":"No! Man has not yet accomplished what He commanded him."},{"key":"80:24","surahNumber":80,"ayahNumber":24,"juzNumber":30,"pageNumber":585,"arabicText":"فَلْيَنظُرِ ٱلْإِنسَٰنُ إِلَىٰ طَعَامِهِۦٓ","translationText":"Then let mankind look at his food -"},{"key":"80:25","surahNumber":80,"ayahNumber":25,"juzNumber":30,"pageNumber":585,"arabicText":"أَنَّا صَبَبْنَا ٱلْمَآءَ صَبًّۭا","translationText":"How We poured down water in torrents,"},{"key":"80:26","surahNumber":80,"ayahNumber":26,"juzNumber":30,"pageNumber":585,"arabicText":"ثُمَّ شَقَقْنَا ٱلْأَرْضَ شَقًّۭا","translationText":"Then We broke open the earth, splitting [it with sprouts],"},{"key":"80:27","surahNumber":80,"ayahNumber":27,"juzNumber":30,"pageNumber":585,"arabicText":"فَأَنۢبَتْنَا فِيهَا حَبًّۭا","translationText":"And caused to grow within it grain"},{"key":"80:28","surahNumber":80,"ayahNumber":28,"juzNumber":30,"pageNumber":585,"arabicText":"وَعِنَبًۭا وَقَضْبًۭا","translationText":"And grapes and herbage"},{"key":"80:29","surahNumber":80,"ayahNumber":29,"juzNumber":30,"pageNumber":585,"arabicText":"وَزَيْتُونًۭا وَنَخْلًۭا","translationText":"And olive and palm trees"},{"key":"80:30","surahNumber":80,"ayahNumber":30,"juzNumber":30,"pageNumber":585,"arabicText":"وَحَدَآئِقَ غُلْبًۭا","translationText":"And gardens of dense shrubbery"},{"key":"80:31","surahNumber":80,"ayahNumber":31,"juzNumber":30,"pageNumber":585,"arabicText":"وَفَٰكِهَةًۭ وَأَبًّۭا","translationText":"And fruit and grass -"},{"key":"80:32","surahNumber":80,"ayahNumber":32,"juzNumber":30,"pageNumber":585,"arabicText":"مَّتَٰعًۭا لَّكُمْ وَلِأَنْعَٰمِكُمْ","translationText":"[As] enjoyment for you and your grazing livestock."},{"key":"80:33","surahNumber":80,"ayahNumber":33,"juzNumber":30,"pageNumber":585,"arabicText":"فَإِذَا جَآءَتِ ٱلصَّآخَّةُ","translationText":"But when there comes the Deafening Blast"},{"key":"80:34","surahNumber":80,"ayahNumber":34,"juzNumber":30,"pageNumber":585,"arabicText":"يَوْمَ يَفِرُّ ٱلْمَرْءُ مِنْ أَخِيهِ","translationText":"On the Day a man will flee from his brother"},{"key":"80:35","surahNumber":80,"ayahNumber":35,"juzNumber":30,"pageNumber":585,"arabicText":"وَأُمِّهِۦ وَأَبِيهِ","translationText":"And his mother and his father"},{"key":"80:36","surahNumber":80,"ayahNumber":36,"juzNumber":30,"pageNumber":585,"arabicText":"وَصَٰحِبَتِهِۦ وَبَنِيهِ","translationText":"And his wife and his children,"},{"key":"80:37","surahNumber":80,"ayahNumber":37,"juzNumber":30,"pageNumber":585,"arabicText":"لِكُلِّ ٱمْرِئٍۢ مِّنْهُمْ يَوْمَئِذٍۢ شَأْنٌۭ يُغْنِيهِ","translationText":"For every man, that Day, will be a matter adequate for him."},{"key":"80:38","surahNumber":80,"ayahNumber":38,"juzNumber":30,"pageNumber":585,"arabicText":"وُجُوهٌۭ يَوْمَئِذٍۢ مُّسْفِرَةٌۭ","translationText":"[Some] faces, that Day, will be bright -"},{"key":"80:39","surahNumber":80,"ayahNumber":39,"juzNumber":30,"pageNumber":585,"arabicText":"ضَاحِكَةٌۭ مُّسْتَبْشِرَةٌۭ","translationText":"Laughing, rejoicing at good news."},{"key":"80:40","surahNumber":80,"ayahNumber":40,"juzNumber":30,"pageNumber":585,"arabicText":"وَوُجُوهٌۭ يَوْمَئِذٍ عَلَيْهَا غَبَرَةٌۭ","translationText":"And [other] faces, that Day, will have upon them dust."},{"key":"80:41","surahNumber":80,"ayahNumber":41,"juzNumber":30,"pageNumber":585,"arabicText":"تَرْهَقُهَا قَتَرَةٌ","translationText":"Blackness will cover them."},{"key":"80:42","surahNumber":80,"ayahNumber":42,"juzNumber":30,"pageNumber":585,"arabicText":"أُو۟لَٰٓئِكَ هُمُ ٱلْكَفَرَةُ ٱلْفَجَرَةُ","translationText":"Those are the disbelievers, the wicked ones."}],"translationEditionUsed":"en.sahih"}