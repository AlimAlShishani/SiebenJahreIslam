{"pageNumber":582,"juzNumber":30,"verses":[{"key":"78:1","surahNumber":78,"ayahNumber":1,"juzNumber":30,"pageNumber":582,"arabicText":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ عَمَّ يَتَسَآءَلُونَ","translationText":"About what are they asking one another?"},{"key":"78:2","surahNumber":78,"ayahNumber":2,"juzNumber":30,"pageNumber":582,"arabicText":"عَنِ ٱلنَّبَإِ ٱلْعَظِيمِ","translationText":"About the great news -"},{"key":"78:3","surahNumber":78,"ayahNumber":3,"juzNumber":30,"pageNumber":582,"arabicText":"ٱلَّذِى هُمْ فِيهِ مُخْتَلِفُونَ","translationText":"That over which they are in disagreement."},{"key":"78:4","surahNumber":78,"ayahNumber":4,"juzNumber":30,"pageNumber":582,"arabicText":"كَلَّا سَيَعْلَمُونَ","translationText":"No! They are going to know."},{"key":"78:5","surahNumber":78,"ayahNumber":5,"juzNumber":30,"pageNumber":582,"arabicText":"ثُمَّ كَلَّا سَيَعْلَمُونَ","translationText":"Then, no! They are going to know."},{"key":"78:6","surahNumber":78,"ayahNumber":6,"juzNumber":30,"pageNumber":582,"arabicText":"أَلَمْ نَجْعَلِ ٱلْأَرْضَ مِهَٰدًۭا","translationText":"Have We not made the earth a resting place?"},{"key":"78:7","surahNumber":78,"ayahNumber":7,"juzNumber":30,"pageNumber":582,"arabicText":"وَٱلْجِبَالَ أَوْتَادًۭا","translationText":"And the mountains as stakes?"},{"key":"78:8","surahNumber":78,"ayahNumber":8,"juzNumber":30,"pageNumber":582,"arabicText":"وَخَلَقْنَٰكُمْ أَزْوَٰجًۭا","translationText":"And We created you in pairs"},{"key":"78:9","surahNumber":78,"ayahNumber":9,"juzNumber":30,"pageNumber":582,"arabicText":"وَجَعَلْنَا نَوْمَكُمْ سُبَاتًۭا","translationText":"And made your sleep [a means for] rest"},{"key":"78:10","surahNumber":78,"ayahNumber":10,"juzNumber":30,"pageNumber":582,"arabicText":"وَجَعَلْنَا ٱلَّيْلَ لِبَاسًۭا","translationText":"And made the night as clothing"},{"key":"78:11","surahNumber":78,"ayahNumber":11,"juzNumber":30,"pageNumber":582,"arabicText":"وَجَعَلْنَا ٱلنَّهَارَ مَعَاشًۭا","translationText":"And made the day for livelihood"},{"key":"78:12","surahNumber":78,"ayahNumber":12,"juzNumber":30,"pageNumber":582,"arabicText":"وَبَنَيْنَا فَوْقَكُمْ سَبْعًۭا شِدَادًۭا","translationText":"And constructed above you seven strong [heavens]"},{"key":"78:13","surahNumber":78,"ayahNumber":13,"juzNumber":30,"pageNumber":582,"arabicText":"وَجَعَلْنَا سِرَاجًۭا وَهَّاجًۭا","translationText":"And made [therein] a burning lamp"},{"key":"78:14","surahNumber":78,"ayahNumber":14,"juzNumber":30,"pageNumber":582,"arabicText":"وَأَنزَلْنَا مِنَ ٱلْمُعْصِرَٰتِ مَآءًۭ ثَجَّاجًۭا","translationText":"And sent down, from the rain clouds, pouring water"},{"key":"78:15","surahNumber":78,"ayahNumber":15,"juzNumber":30,"pageNumber":582,"arabicText":"لِّنُخْرِجَ بِهِۦ حَبًّۭا وَنَبَاتًۭا","translationText":"That We may bring forth thereby grain and vegetation"},{"key":"78:16","surahNumber":78,"ayahNumber":16,"juzNumber":30,"pageNumber":582,"arabicText":"وَجَنَّٰتٍ أَلْفَافًا","translationText":"And gardens of entwined growth."},{"key":"78:17","surahNumber":78,"ayahNumber":17,"juzNumber":30,"pageNumber":582,"arabicText":"إِنَّ يَوْمَ ٱلْفَصْلِ كَانَ مِيقَٰتًۭا","translationText":"Indeed, the Day of Judgement is an appointed time -"},{"key":"78:18","surahNumber":78,"ayahNumber":18,"juzNumber":30,"pageNumber":582,"arabicText":"يَوْمَ يُنفَخُ فِى ٱلصُّورِ فَتَأْتُونَ أَفْوَاجًۭا","translationText":"The Day the Horn is blown and you will come forth in multitudes"},{"key":"78:19","surahNumber":78,"ayahNumber":19,"juzNumber":30,"pageNumber":582,"arabicText":"وَفُتِحَتِ ٱلسَّمَآءُ فَكَانَتْ أَبْوَٰبًۭا","translationText":"And the heaven is opened and will become gateways"},{"key":"78:20","surahNumber":78,"ayahNumber":20,"juzNumber":30,"pageNumber":582,"arabicText":"وَسُيِّرَتِ ٱلْجِبَالُ فَكَانَتْ سَرَابًا","translationText":"And the mountains are removed and will be [but] a mirage."},{"key":"78:21","surahNumber":78,"ayahNumber":21,"juzNumber":30,"pageNumber":582,"arabicText":"إِنَّ جَهَنَّمَ كَانَتْ مِرْصَادًۭا","translationText":"Indeed, Hell has been lying in wait"},{"key":"78:22","surahNumber":78,"ayahNumber":22,"juzNumber":30,"pageNumber":582,"arabicText":"لِّلطَّٰغِينَ مَـَٔابًۭا","translationText":"For the transgressors, a place of return,"},{"key":"78:23","surahNumber":78,"ayahNumber":23,"juzNumber":30,"pageNumber":582,"arabicText":"لَّٰبِثِينَ فِيهَآ أَحْقَابًۭا","translationText":"In which they will remain for ages [unending]."},{"key":"78:24","surahNumber":78,"ayahNumber":24,"juzNumber":30,"pageNumber":582,"arabicText":"لَّا يَذُوقُونَ فِيهَا بَرْدًۭا وَلَا شَرَابًا","translationText":"They will not taste therein [any] coolness or drink"},{"key":"78:25","surahNumber":78,"ayahNumber":25,"juzNumber":30,"pageNumber":582,"arabicText":"إِلَّا حَمِيمًۭا وَغَسَّاقًۭا","translationText":"Except scalding water and [foul] purulence -"},{"key":"78:26","surahNumber":78,"ayahNumber":26,"juzNumber":30,"pageNumber":582,"arabicText":"جَزَآءًۭ وِفَاقًا","translationText":"An appropriate recompense."},{"key":"78:27","surahNumber":78,"ayahNumber":27,"juzNumber":30,"pageNumber":582,"arabicText":"إِنَّهُمْ كَانُوا۟ لَا يَرْجُونَ حِسَابًۭا","translationText":"Indeed, they were not expecting an account"},{"key":"78:28","surahNumber":78,"ayahNumber":28,"juzNumber":30,"pageNumber":582,"arabicText":"وَكَذَّبُوا۟ بِـَٔايَٰتِنَا كِذَّابًۭا","translationText":"And denied Our verses with [emphatic] denial."},{"key":"78:29","surahNumber":78,"ayahNumber":29,"juzNumber":30,"pageNumber":582,"arabicText":"وَكُلَّ شَىْءٍ أَحْصَيْنَٰهُ كِتَٰبًۭا","translationText":"But all things We have enumerated in writing."},{"key":"78:30","surahNumber":78,"ayahNumber":30,"juzNumber":30,"pageNumber":582,"arabicText":"فَذُوقُوا۟ فَلَن نَّزِيدَكُمْ إِلَّا عَذَابًا","translationText":"\"So taste [the penalty], and never will We increase you except in torment.\""}],"translationEditionUsed":"en.sahih"}