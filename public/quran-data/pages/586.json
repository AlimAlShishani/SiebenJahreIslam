{"pageNumber":586,"juzNumber":30,"verses":[{"key":"81:1","surahNumber":81,"ayahNumber":1,"juzNumber":30,"pageNumber":586,"arabicText":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ إِذَا ٱلشَّمْسُ كُوِّرَتْ","translationText":"Wenn die Sonne eingerollt ist"},{"key":"81:2","surahNumber":81,"ayahNumber":2,"juzNumber":30,"pageNumber":586,"arabicText":"وَإِذَا ٱلنُّجُومُ ٱنكَدَرَتْ","translationText":"und wenn die Sterne trübe sind"},{"key":"81:3","surahNumber":81,"ayahNumber":3,"juzNumber":30,"pageNumber":586,"arabicText":"وَإِذَا ٱلْجِبَالُ سُيِّرَتْ","translationText":"und wenn die Berge fortbewegt werden"},{"key":"81:4","surahNumber":81,"ayahNumber":4,"juzNumber":30,"pageNumber":586,"arabicText":"وَإِذَا ٱلْعِشَارُ عُطِّلَتْ","translationText":"und wenn die trächtigen Kamelstuten vernachlässigt werden"},{"key":"81:5","surahNumber":81,"ayahNumber":5,"juzNumber":30,"pageNumber":586,"arabicText":"وَإِذَا ٱلْوُحُوشُ حُشِرَتْ","translationText":"und wenn wildes Getier versammelt wird"},{"key":"81:6","surahNumber":81,"ayahNumber":6,"juzNumber":30,"pageNumber":586,"arabicText":"وَإِذَا ٱلْبِحَارُ سُجِّرَتْ","translationText":"und wenn die Meere zu einem Flammenmeer werden"},{"key":"81:7","surahNumber":81,"ayahNumber":7,"juzNumber":30,"pageNumber":586,"arabicText":"وَإِذَا ٱلنُّفُوسُ زُوِّجَتْ","translationText":"und wenn die Seelen (mit ihren Leibern) gepaart werden"},{"key":"81:8","surahNumber":81,"ayahNumber":8,"juzNumber":30,"pageNumber":586,"arabicText":"وَإِذَا ٱلْمَوْءُۥدَةُ سُئِلَتْ","translationText":"und wenn das lebendig begrabene Mädchen gefragt wird"},{"key":"81:9","surahNumber":81,"ayahNumber":9,"juzNumber":30,"pageNumber":586,"arabicText":"بِأَىِّ ذَنۢبٍۢ قُتِلَتْ","translationText":"\"Für welch ein Verbrechen wurdest du getötet?\""},{"key":"81:10","surahNumber":81,"ayahNumber":10,"juzNumber":30,"pageNumber":586,"arabicText":"وَإِذَا ٱلصُّحُفُ نُشِرَتْ","translationText":"Und wenn Schriften weithin aufgerollt werden"},{"key":"81:11","surahNumber":81,"ayahNumber":11,"juzNumber":30,"pageNumber":586,"arabicText":"وَإِذَا ٱلسَّمَآءُ كُشِطَتْ","translationText":"und wenn der Himmel weggezogen wird"},{"key":"81:12","surahNumber":81,"ayahNumber":12,"juzNumber":30,"pageNumber":586,"arabicText":"وَإِذَا ٱلْجَحِيمُ سُعِّرَتْ","translationText":"und wenn die Gahim angefacht wird"},{"key":"81:13","surahNumber":81,"ayahNumber":13,"juzNumber":30,"pageNumber":586,"arabicText":"وَإِذَا ٱلْجَنَّةُ أُزْلِفَتْ","translationText":"und wenn das Paradies nahegerückt wird"},{"key":"81:14","surahNumber":81,"ayahNumber":14,"juzNumber":30,"pageNumber":586,"arabicText":"عَلِمَتْ نَفْسٌۭ مَّآ أَحْضَرَتْ","translationText":"dann wird jede Seele wissen, was sie mitgebracht hat."},{"key":"81:15","surahNumber":81,"ayahNumber":15,"juzNumber":30,"pageNumber":586,"arabicText":"فَلَآ أُقْسِمُ بِٱلْخُنَّسِ","translationText":"Wahrlich, Ich schwöre bei den rückläufigen Sternen"},{"key":"81:16","surahNumber":81,"ayahNumber":16,"juzNumber":30,"pageNumber":586,"arabicText":"ٱلْجَوَارِ ٱلْكُنَّسِ","translationText":"den voraneilenden und den sich verbergenden"},{"key":"81:17","surahNumber":81,"ayahNumber":17,"juzNumber":30,"pageNumber":586,"arabicText":"وَٱلَّيْلِ إِذَا عَسْعَسَ","translationText":"und bei der Nacht, wenn sie vergeht"},{"key":"81:18","surahNumber":81,"ayahNumber":18,"juzNumber":30,"pageNumber":586,"arabicText":"وَٱلصُّبْحِ إِذَا تَنَفَّسَ","translationText":"und Ich schwöre beim Morgen, wenn er zu aufatmen beginnt"},{"key":"81:19","surahNumber":81,"ayahNumber":19,"juzNumber":30,"pageNumber":586,"arabicText":"إِنَّهُۥ لَقَوْلُ رَسُولٍۢ كَرِيمٍۢ","translationText":"daß dies in Wahrheit ein Wort eines edlen Boten ist"},{"key":"81:20","surahNumber":81,"ayahNumber":20,"juzNumber":30,"pageNumber":586,"arabicText":"ذِى قُوَّةٍ عِندَ ذِى ٱلْعَرْشِ مَكِينٍۢ","translationText":"der mit Macht begabt ist bei dem Herrn des Throns und in Ansehen steht"},{"key":"81:21","surahNumber":81,"ayahNumber":21,"juzNumber":30,"pageNumber":586,"arabicText":"مُّطَاعٍۢ ثَمَّ أَمِينٍۢ","translationText":"dem gehorcht wird und der getreu ist"},{"key":"81:22","surahNumber":81,"ayahNumber":22,"juzNumber":30,"pageNumber":586,"arabicText":"وَمَا صَاحِبُكُم بِمَجْنُونٍۢ","translationText":"und euer Gefährte ist nicht ein Besessener."},{"key":"81:23","surahNumber":81,"ayahNumber":23,"juzNumber":30,"pageNumber":586,"arabicText":"وَلَقَدْ رَءَاهُ بِٱلْأُفُقِ ٱلْمُبِينِ","translationText":"Wahrlich, er sah ihn am klaren Horizont."},{"key":"81:24","surahNumber":81,"ayahNumber":24,"juzNumber":30,"pageNumber":586,"arabicText":"وَمَا هُوَ عَلَى ٱلْغَيْبِ بِضَنِينٍۢ","translationText":"Und er ist weder geizig hinsichtlich des Verborgenen"},{"key":"81:25","surahNumber":81,"ayahNumber":25,"juzNumber":30,"pageNumber":586,"arabicText":"وَمَا هُوَ بِقَوْلِ شَيْطَٰنٍۢ رَّجِيمٍۢ","translationText":"noch ist dies das Wort Satans, des Verfluchten."},{"key":"81:26","surahNumber":81,"ayahNumber":26,"juzNumber":30,"pageNumber":586,"arabicText":"فَأَيْنَ تَذْهَبُونَ","translationText":"Wohin also wollt ihr gehen?"},{"key":"81:27","surahNumber":81,"ayahNumber":27,"juzNumber":30,"pageNumber":586,"arabicText":"إِنْ هُوَ إِلَّا ذِكْرٌۭ لِّلْعَٰلَمِينَ","translationText":"Dies ist ja nur eine Ermahnung für alle Welten."},{"key":"81:28","surahNumber":81,"ayahNumber":28,"juzNumber":30,"pageNumber":586,"arabicText":"لِمَن شَآءَ مِنكُمْ أَن يَسْتَقِيمَ","translationText":"Für denjenigen unter euch, der aufrichtig sein will."},{"key":"81:29","surahNumber":81,"ayahNumber":29,"juzNumber":30,"pageNumber":586,"arabicText":"وَمَا تَشَآءُونَ إِلَّآ أَن يَشَآءَ ٱللَّهُ رَبُّ ٱلْعَٰلَمِينَ","translationText":"Und ihr werdet nicht wollen, es sei denn, daß Allah will, der Herr der Welten."}],"translationEditionUsed":"de.aburida"}