{"pageNumber":582,"juzNumber":30,"verses":[{"key":"78:1","surahNumber":78,"ayahNumber":1,"juzNumber":30,"pageNumber":582,"arabicText":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ عَمَّ يَتَسَآءَلُونَ","translationText":"Wonach befragen sie einander?"},{"key":"78:2","surahNumber":78,"ayahNumber":2,"juzNumber":30,"pageNumber":582,"arabicText":"عَنِ ٱلنَّبَإِ ٱلْعَظِيمِ","translationText":"Nach einer gewaltigen Ankündigung"},{"key":"78:3","surahNumber":78,"ayahNumber":3,"juzNumber":30,"pageNumber":582,"arabicText":"ٱلَّذِى هُمْ فِيهِ مُخْتَلِفُونَ","translationText":"über die sie uneinig sind."},{"key":"78:4","surahNumber":78,"ayahNumber":4,"juzNumber":30,"pageNumber":582,"arabicText":"كَلَّا سَيَعْلَمُونَ","translationText":"Nein! Sie werden es bald erfahren."},{"key":"78:5","surahNumber":78,"ayahNumber":5,"juzNumber":30,"pageNumber":582,"arabicText":"ثُمَّ كَلَّا سَيَعْلَمُونَ","translationText":"Und abermals nein! Sie werden es bald erfahren."},{"key":"78:6","surahNumber":78,"ayahNumber":6,"juzNumber":30,"pageNumber":582,"arabicText":"أَلَمْ نَجْعَلِ ٱلْأَرْضَ مِهَٰدًۭا","translationText":"Haben Wir nicht die Erde zu einem Lager gemacht"},{"key":"78:7","surahNumber":78,"ayahNumber":7,"juzNumber":30,"pageNumber":582,"arabicText":"وَٱلْجِبَالَ أَوْتَادًۭا","translationText":"und die Berge zu Pflöcken?"},{"key":"78:8","surahNumber":78,"ayahNumber":8,"juzNumber":30,"pageNumber":582,"arabicText":"وَخَلَقْنَٰكُمْ أَزْوَٰجًۭا","translationText":"Und Wir haben euch in Paaren erschaffen"},{"key":"78:9","surahNumber":78,"ayahNumber":9,"juzNumber":30,"pageNumber":582,"arabicText":"وَجَعَلْنَا نَوْمَكُمْ سُبَاتًۭا","translationText":"und Wir haben euch den Schlaf zur Ruhe gemacht"},{"key":"78:10","surahNumber":78,"ayahNumber":10,"juzNumber":30,"pageNumber":582,"arabicText":"وَجَعَلْنَا ٱلَّيْلَ لِبَاسًۭا","translationText":"und die Nacht zu einer Hülle"},{"key":"78:11","surahNumber":78,"ayahNumber":11,"juzNumber":30,"pageNumber":582,"arabicText":"وَجَعَلْنَا ٱلنَّهَارَ مَعَاشًۭا","translationText":"und den Tag zum Erwerb des Unterhalts"},{"key":"78:12","surahNumber":78,"ayahNumber":12,"juzNumber":30,"pageNumber":582,"arabicText":"وَبَنَيْنَا فَوْقَكُمْ سَبْعًۭا شِدَادًۭا","translationText":"und Wir haben über euch sieben starke (Himmel) erbaut"},{"key":"78:13","surahNumber":78,"ayahNumber":13,"juzNumber":30,"pageNumber":582,"arabicText":"وَجَعَلْنَا سِرَاجًۭا وَهَّاجًۭا","translationText":"und Wir haben eine hellbrennende Leuchte gemacht"},{"key":"78:14","surahNumber":78,"ayahNumber":14,"juzNumber":30,"pageNumber":582,"arabicText":"وَأَنزَلْنَا مِنَ ٱلْمُعْصِرَٰتِ مَآءًۭ ثَجَّاجًۭا","translationText":"und Wir senden aus den Regenwolken Wasser in Strömen hernieder"},{"key":"78:15","surahNumber":78,"ayahNumber":15,"juzNumber":30,"pageNumber":582,"arabicText":"لِّنُخْرِجَ بِهِۦ حَبًّۭا وَنَبَاتًۭا","translationText":"auf daß Wir damit Korn und Kraut hervorbringen"},{"key":"78:16","surahNumber":78,"ayahNumber":16,"juzNumber":30,"pageNumber":582,"arabicText":"وَجَنَّٰتٍ أَلْفَافًا","translationText":"sowie üppige Gärten."},{"key":"78:17","surahNumber":78,"ayahNumber":17,"juzNumber":30,"pageNumber":582,"arabicText":"إِنَّ يَوْمَ ٱلْفَصْلِ كَانَ مِيقَٰتًۭا","translationText":"Wahrlich, der Tag der Entscheidung ist ein fester Termin"},{"key":"78:18","surahNumber":78,"ayahNumber":18,"juzNumber":30,"pageNumber":582,"arabicText":"يَوْمَ يُنفَخُ فِى ٱلصُّورِ فَتَأْتُونَ أَفْوَاجًۭا","translationText":"an jenem Tag, da in den Sur gestoßen wird und ihr in Scharen kommt"},{"key":"78:19","surahNumber":78,"ayahNumber":19,"juzNumber":30,"pageNumber":582,"arabicText":"وَفُتِحَتِ ٱلسَّمَآءُ فَكَانَتْ أَبْوَٰبًۭا","translationText":"und der Himmel sich öffnet und zu Toren wird"},{"key":"78:20","surahNumber":78,"ayahNumber":20,"juzNumber":30,"pageNumber":582,"arabicText":"وَسُيِّرَتِ ٱلْجِبَالُ فَكَانَتْ سَرَابًا","translationText":"und die Berge sich bewegen und zur Luftspiegelung werden."},{"key":"78:21","surahNumber":78,"ayahNumber":21,"juzNumber":30,"pageNumber":582,"arabicText":"إِنَّ جَهَنَّمَ كَانَتْ مِرْصَادًۭا","translationText":"Wahrlich, Gahannam ist ein Hinterhalt"},{"key":"78:22","surahNumber":78,"ayahNumber":22,"juzNumber":30,"pageNumber":582,"arabicText":"لِّلطَّٰغِينَ مَـَٔابًۭا","translationText":"- eine Heimstätte für die Widerspenstigen"},{"key":"78:23","surahNumber":78,"ayahNumber":23,"juzNumber":30,"pageNumber":582,"arabicText":"لَّٰبِثِينَ فِيهَآ أَحْقَابًۭا","translationText":"die dort Epoche für Epoche bleiben"},{"key":"78:24","surahNumber":78,"ayahNumber":24,"juzNumber":30,"pageNumber":582,"arabicText":"لَّا يَذُوقُونَ فِيهَا بَرْدًۭا وَلَا شَرَابًا","translationText":"sie werden dort weder Kühle noch Trank kosten"},{"key":"78:25","surahNumber":78,"ayahNumber":25,"juzNumber":30,"pageNumber":582,"arabicText":"إِلَّا حَمِيمًۭا وَغَسَّاقًۭا","translationText":"außer siedendem Wasser und Eiter."},{"key":"78:26","surahNumber":78,"ayahNumber":26,"juzNumber":30,"pageNumber":582,"arabicText":"جَزَآءًۭ وِفَاقًا","translationText":"(Dies ist) ein Lohn in angemessener Weise"},{"key":"78:27","surahNumber":78,"ayahNumber":27,"juzNumber":30,"pageNumber":582,"arabicText":"إِنَّهُمْ كَانُوا۟ لَا يَرْجُونَ حِسَابًۭا","translationText":"(weil) sie mit keiner Rechenschaft gerechnet haben"},{"key":"78:28","surahNumber":78,"ayahNumber":28,"juzNumber":30,"pageNumber":582,"arabicText":"وَكَذَّبُوا۟ بِـَٔايَٰتِنَا كِذَّابًۭا","translationText":"und gänzlich Unsere Zeichen verleugneten."},{"key":"78:29","surahNumber":78,"ayahNumber":29,"juzNumber":30,"pageNumber":582,"arabicText":"وَكُلَّ شَىْءٍ أَحْصَيْنَٰهُ كِتَٰبًۭا","translationText":"Und alle Dinge haben Wir restlos niedergeschrieben."},{"key":"78:30","surahNumber":78,"ayahNumber":30,"juzNumber":30,"pageNumber":582,"arabicText":"فَذُوقُوا۟ فَلَن نَّزِيدَكُمْ إِلَّا عَذَابًا","translationText":"\"Kostet! Wir werden es euch nicht anders mehren als in der Pein.\""}],"translationEditionUsed":"de.aburida"}