{"pageNumber":604,"juzNumber":30,"verses":[{"key":"112:1","surahNumber":112,"ayahNumber":1,"juzNumber":30,"pageNumber":604,"arabicText":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ قُلْ هُوَ ٱللَّهُ أَحَدٌ","translationText":"Sprich: \"Er ist Allah, ein Einziger"},{"key":"112:2","surahNumber":112,"ayahNumber":2,"juzNumber":30,"pageNumber":604,"arabicText":"ٱللَّهُ ٱلصَّمَدُ","translationText":"Allah, der Absolute (ewig Unabhängige, von Dem alles abhängt)."},{"key":"112:3","surahNumber":112,"ayahNumber":3,"juzNumber":30,"pageNumber":604,"arabicText":"لَمْ يَلِدْ وَلَمْ يُولَدْ","translationText":"Er zeugt nicht und ist nicht gezeugt worden"},{"key":"112:4","surahNumber":112,"ayahNumber":4,"juzNumber":30,"pageNumber":604,"arabicText":"وَلَمْ يَكُن لَّهُۥ كُفُوًا أَحَدٌۢ","translationText":"und Ihm ebenbürtig ist keiner.\""},{"key":"113:1","surahNumber":113,"ayahNumber":1,"juzNumber":30,"pageNumber":604,"arabicText":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ قُلْ أَعُوذُ بِرَبِّ ٱلْفَلَقِ","translationText":"Sprich: \"ich nehme meine Zuflucht beim Herrn des Frühlichts"},{"key":"113:2","surahNumber":113,"ayahNumber":2,"juzNumber":30,"pageNumber":604,"arabicText":"مِن شَرِّ مَا خَلَقَ","translationText":"vor dem Übel dessen, was Er erschaffen hat"},{"key":"113:3","surahNumber":113,"ayahNumber":3,"juzNumber":30,"pageNumber":604,"arabicText":"وَمِن شَرِّ غَاسِقٍ إِذَا وَقَبَ","translationText":"und vor dem Übel der Dunkelheit, wenn sie hereinbricht"},{"key":"113:4","surahNumber":113,"ayahNumber":4,"juzNumber":30,"pageNumber":604,"arabicText":"وَمِن شَرِّ ٱلنَّفَّٰثَٰتِ فِى ٱلْعُقَدِ","translationText":"und vor dem Übel der Knotenanbläserinnen"},{"key":"113:5","surahNumber":113,"ayahNumber":5,"juzNumber":30,"pageNumber":604,"arabicText":"وَمِن شَرِّ حَاسِدٍ إِذَا حَسَدَ","translationText":"und vor dem Übel eines (jeden) Neiders, wenn er neidet.\""},{"key":"114:1","surahNumber":114,"ayahNumber":1,"juzNumber":30,"pageNumber":604,"arabicText":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ قُلْ أَعُوذُ بِرَبِّ ٱلنَّاسِ","translationText":"Sprich: \"lch nehme meine Zuflucht beim Herrn der Menschen"},{"key":"114:2","surahNumber":114,"ayahNumber":2,"juzNumber":30,"pageNumber":604,"arabicText":"مَلِكِ ٱلنَّاسِ","translationText":"dem König der Menschen"},{"key":"114:3","surahNumber":114,"ayahNumber":3,"juzNumber":30,"pageNumber":604,"arabicText":"إِلَٰهِ ٱلنَّاسِ","translationText":"dem Gott der Menschen"},{"key":"114:4","surahNumber":114,"ayahNumber":4,"juzNumber":30,"pageNumber":604,"arabicText":"مِن شَرِّ ٱلْوَسْوَاسِ ٱلْخَنَّاسِ","translationText":"vor dem Übel des Einflüsterers, der entweicht und wiederkehrt"},{"key":"114:5","surahNumber":114,"ayahNumber":5,"juzNumber":30,"pageNumber":604,"arabicText":"ٱلَّذِى يُوَسْوِسُ فِى صُدُورِ ٱلنَّاسِ","translationText":"der in die Herzen der Menschen einflüstert"},{"key":"114:6","surahNumber":114,"ayahNumber":6,"juzNumber":30,"pageNumber":604,"arabicText":"مِنَ ٱلْجِنَّةِ وَٱلنَّاسِ","translationText":"sei dieser aus den Ginn oder den Menschen\""}],"translationEditionUsed":"de.aburida"}