{"pageNumber":596,"juzNumber":30,"verses":[{"key":"92:15","surahNumber":92,"ayahNumber":15,"juzNumber":30,"pageNumber":596,"arabicText":"لَا يَصْلَىٰهَآ إِلَّا ٱلْأَشْقَى","translationText":"in dem nur derjenige brennen wird, der unselig ist"},{"key":"92:16","surahNumber":92,"ayahNumber":16,"juzNumber":30,"pageNumber":596,"arabicText":"ٱلَّذِى كَذَّبَ وَتَوَلَّىٰ","translationText":"der da leugnet und den Rücken kehrt."},{"key":"92:17","surahNumber":92,"ayahNumber":17,"juzNumber":30,"pageNumber":596,"arabicText":"وَسَيُجَنَّبُهَا ٱلْأَتْقَى","translationText":"Geschont von ihm wird derjenige sein, der gottesfürchtig ist"},{"key":"92:18","surahNumber":92,"ayahNumber":18,"juzNumber":30,"pageNumber":596,"arabicText":"ٱلَّذِى يُؤْتِى مَالَهُۥ يَتَزَكَّىٰ","translationText":"der sein Vermögen hergibt, um sich zu reinigen"},{"key":"92:19","surahNumber":92,"ayahNumber":19,"juzNumber":30,"pageNumber":596,"arabicText":"وَمَا لِأَحَدٍ عِندَهُۥ مِن نِّعْمَةٍۢ تُجْزَىٰٓ","translationText":"und der keinem eine Gunst schuldet, die zurückgezahlt werden müßte"},{"key":"92:20","surahNumber":92,"ayahNumber":20,"juzNumber":30,"pageNumber":596,"arabicText":"إِلَّا ٱبْتِغَآءَ وَجْهِ رَبِّهِ ٱلْأَعْلَىٰ","translationText":"außer im Trachten nach dem Wohlgefallen seines Herrn, des Allerhöchsten."},{"key":"92:21","surahNumber":92,"ayahNumber":21,"juzNumber":30,"pageNumber":596,"arabicText":"وَلَسَوْفَ يَرْضَىٰ","translationText":"Und er wird wohlzufrieden sein."},{"key":"93:1","surahNumber":93,"ayahNumber":1,"juzNumber":30,"pageNumber":596,"arabicText":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلضُّحَىٰ","translationText":"Beim Vormittag"},{"key":"93:2","surahNumber":93,"ayahNumber":2,"juzNumber":30,"pageNumber":596,"arabicText":"وَٱلَّيْلِ إِذَا سَجَىٰ","translationText":"und bei der Nacht, wenn alles still ist!"},{"key":"93:3","surahNumber":93,"ayahNumber":3,"juzNumber":30,"pageNumber":596,"arabicText":"مَا وَدَّعَكَ رَبُّكَ وَمَا قَلَىٰ","translationText":"Dein Herr hat dich weder verlassen, noch verabscheut."},{"key":"93:4","surahNumber":93,"ayahNumber":4,"juzNumber":30,"pageNumber":596,"arabicText":"وَلَلْءَاخِرَةُ خَيْرٌۭ لَّكَ مِنَ ٱلْأُولَىٰ","translationText":"Wahrlich, das Jenseits ist besser für dich als das Diesseits."},{"key":"93:5","surahNumber":93,"ayahNumber":5,"juzNumber":30,"pageNumber":596,"arabicText":"وَلَسَوْفَ يُعْطِيكَ رَبُّكَ فَتَرْضَىٰٓ","translationText":"Und wahrlich, dein Herr wird dir geben und du wirst wohlzufrieden sein."},{"key":"93:6","surahNumber":93,"ayahNumber":6,"juzNumber":30,"pageNumber":596,"arabicText":"أَلَمْ يَجِدْكَ يَتِيمًۭا فَـَٔاوَىٰ","translationText":"Hat Er dich nicht als Waise gefunden und aufgenommen"},{"key":"93:7","surahNumber":93,"ayahNumber":7,"juzNumber":30,"pageNumber":596,"arabicText":"وَوَجَدَكَ ضَآلًّۭا فَهَدَىٰ","translationText":"und dich auf dem Irrweg gefunden und richtig geführt"},{"key":"93:8","surahNumber":93,"ayahNumber":8,"juzNumber":30,"pageNumber":596,"arabicText":"وَوَجَدَكَ عَآئِلًۭا فَأَغْنَىٰ","translationText":"und dich dürftig gefunden und reich gemacht?"},{"key":"93:9","surahNumber":93,"ayahNumber":9,"juzNumber":30,"pageNumber":596,"arabicText":"فَأَمَّا ٱلْيَتِيمَ فَلَا تَقْهَرْ","translationText":"Darum unterdrücke nicht die Waise"},{"key":"93:10","surahNumber":93,"ayahNumber":10,"juzNumber":30,"pageNumber":596,"arabicText":"وَأَمَّا ٱلسَّآئِلَ فَلَا تَنْهَرْ","translationText":"und fahre nicht den Bettler an"},{"key":"93:11","surahNumber":93,"ayahNumber":11,"juzNumber":30,"pageNumber":596,"arabicText":"وَأَمَّا بِنِعْمَةِ رَبِّكَ فَحَدِّثْ","translationText":"und sprich überall von der Gnade deines Herrn."},{"key":"94:1","surahNumber":94,"ayahNumber":1,"juzNumber":30,"pageNumber":596,"arabicText":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ أَلَمْ نَشْرَحْ لَكَ صَدْرَكَ","translationText":"Haben Wir dir nicht deine Brust geweitet"},{"key":"94:2","surahNumber":94,"ayahNumber":2,"juzNumber":30,"pageNumber":596,"arabicText":"وَوَضَعْنَا عَنكَ وِزْرَكَ","translationText":"und dir deine Last abgenommen"},{"key":"94:3","surahNumber":94,"ayahNumber":3,"juzNumber":30,"pageNumber":596,"arabicText":"ٱلَّذِىٓ أَنقَضَ ظَهْرَكَ","translationText":"die schwer auf deinem Rücken lastete"},{"key":"94:4","surahNumber":94,"ayahNumber":4,"juzNumber":30,"pageNumber":596,"arabicText":"وَرَفَعْنَا لَكَ ذِكْرَكَ","translationText":"und deinen Namen erhöht?"},{"key":"94:5","surahNumber":94,"ayahNumber":5,"juzNumber":30,"pageNumber":596,"arabicText":"فَإِنَّ مَعَ ٱلْعُسْرِ يُسْرًا","translationText":"Also, wahrlich, mit der Drangsal geht Erleichterung einher"},{"key":"94:6","surahNumber":94,"ayahNumber":6,"juzNumber":30,"pageNumber":596,"arabicText":"إِنَّ مَعَ ٱلْعُسْرِ يُسْرًۭا","translationText":"wahrlich, mit der Drangsal geht Erleichterung (einher)."},{"key":"94:7","surahNumber":94,"ayahNumber":7,"juzNumber":30,"pageNumber":596,"arabicText":"فَإِذَا فَرَغْتَ فَٱنصَبْ","translationText":"Also, wenn du (mit allem) fertig bist, dann mühe dich ab"},{"key":"94:8","surahNumber":94,"ayahNumber":8,"juzNumber":30,"pageNumber":596,"arabicText":"وَإِلَىٰ رَبِّكَ فَٱرْغَب","translationText":"und begehre die Nähe deines Herrn."}],"translationEditionUsed":"de.aburida"}