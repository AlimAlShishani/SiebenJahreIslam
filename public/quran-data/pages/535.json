{"pageNumber":535,"juzNumber":27,"verses":[{"key":"56:17","surahNumber":56,"ayahNumber":17,"juzNumber":27,"pageNumber":535,"arabicText":"يَطُوفُ عَلَيْهِمْ وِلْدَٰنٌۭ مُّخَلَّدُونَ","translationText":"Bedient werden sie von Jünglingen, die nicht altern"},{"key":"56:18","surahNumber":56,"ayahNumber":18,"juzNumber":27,"pageNumber":535,"arabicText":"بِأَكْوَابٍۢ وَأَبَارِيقَ وَكَأْسٍۢ مِّن مَّعِينٍۢ","translationText":"mit Bechern und Krü gen aus einer fließenden Quelle."},{"key":"56:19","surahNumber":56,"ayahNumber":19,"juzNumber":27,"pageNumber":535,"arabicText":"لَّا يُصَدَّعُونَ عَنْهَا وَلَا يُنزِفُونَ","translationText":"Keinen Kopfschmerz werden sie davon bekommen, noch werden sie das Bewußtsein verlieren."},{"key":"56:20","surahNumber":56,"ayahNumber":20,"juzNumber":27,"pageNumber":535,"arabicText":"وَفَٰكِهَةٍۢ مِّمَّا يَتَخَيَّرُونَ","translationText":"Und Früchte, die sie sich wünschen"},{"key":"56:21","surahNumber":56,"ayahNumber":21,"juzNumber":27,"pageNumber":535,"arabicText":"وَلَحْمِ طَيْرٍۢ مِّمَّا يَشْتَهُونَ","translationText":"und Fleisch vom Geflügel, das sie begehren"},{"key":"56:22","surahNumber":56,"ayahNumber":22,"juzNumber":27,"pageNumber":535,"arabicText":"وَحُورٌ عِينٌۭ","translationText":"und Huris"},{"key":"56:23","surahNumber":56,"ayahNumber":23,"juzNumber":27,"pageNumber":535,"arabicText":"كَأَمْثَٰلِ ٱللُّؤْلُؤِ ٱلْمَكْنُونِ","translationText":"wohlbehüteten Perlen gleich"},{"key":"56:24","surahNumber":56,"ayahNumber":24,"juzNumber":27,"pageNumber":535,"arabicText":"جَزَآءًۢ بِمَا كَانُوا۟ يَعْمَلُونَ","translationText":"(werden sie erhalten) als Belohnung für das, was sie zu tun pflegten."},{"key":"56:25","surahNumber":56,"ayahNumber":25,"juzNumber":27,"pageNumber":535,"arabicText":"لَا يَسْمَعُونَ فِيهَا لَغْوًۭا وَلَا تَأْثِيمًا","translationText":"Sie werden dort weder leeres Gerede noch Anschuldigung der Sünde hören"},{"key":"56:26","surahNumber":56,"ayahNumber":26,"juzNumber":27,"pageNumber":535,"arabicText":"إِلَّا قِيلًۭا سَلَٰمًۭا سَلَٰمًۭا","translationText":"nur das Wort: \"Frieden, Frieden!\""},{"key":"56:27","surahNumber":56,"ayahNumber":27,"juzNumber":27,"pageNumber":535,"arabicText":"وَأَصْحَٰبُ ٱلْيَمِينِ مَآ أَصْحَٰبُ ٱلْيَمِينِ","translationText":"Und die zur Rechten - was (wißt ihr) von denen, die zur Rechten sein werden?"},{"key":"56:28","surahNumber":56,"ayahNumber":28,"juzNumber":27,"pageNumber":535,"arabicText":"فِى سِدْرٍۢ مَّخْضُودٍۢ","translationText":"(Sie werden) unter dornlosen Lotusbäumen (sein)"},{"key":"56:29","surahNumber":56,"ayahNumber":29,"juzNumber":27,"pageNumber":535,"arabicText":"وَطَلْحٍۢ مَّنضُودٍۢ","translationText":"und gebüschelten Bananen"},{"key":"56:30","surahNumber":56,"ayahNumber":30,"juzNumber":27,"pageNumber":535,"arabicText":"وَظِلٍّۢ مَّمْدُودٍۢ","translationText":"und endlosem Schatten"},{"key":"56:31","surahNumber":56,"ayahNumber":31,"juzNumber":27,"pageNumber":535,"arabicText":"وَمَآءٍۢ مَّسْكُوبٍۢ","translationText":"bei fließendem Wasser"},{"key":"56:32","surahNumber":56,"ayahNumber":32,"juzNumber":27,"pageNumber":535,"arabicText":"وَفَٰكِهَةٍۢ كَثِيرَةٍۢ","translationText":"und vielen Früchten"},{"key":"56:33","surahNumber":56,"ayahNumber":33,"juzNumber":27,"pageNumber":535,"arabicText":"لَّا مَقْطُوعَةٍۢ وَلَا مَمْنُوعَةٍۢ","translationText":"die weder zu Ende gehen, noch für verboten erklärt werden"},{"key":"56:34","surahNumber":56,"ayahNumber":34,"juzNumber":27,"pageNumber":535,"arabicText":"وَفُرُشٍۢ مَّرْفُوعَةٍ","translationText":"und auf erhöhten Ruhekissen."},{"key":"56:35","surahNumber":56,"ayahNumber":35,"juzNumber":27,"pageNumber":535,"arabicText":"إِنَّآ أَنشَأْنَٰهُنَّ إِنشَآءًۭ","translationText":"Wir haben sie (die Huris) in herrlicher Schöpfung gestaltet"},{"key":"56:36","surahNumber":56,"ayahNumber":36,"juzNumber":27,"pageNumber":535,"arabicText":"فَجَعَلْنَٰهُنَّ أَبْكَارًا","translationText":"und sie zu Jungfrauen gemacht"},{"key":"56:37","surahNumber":56,"ayahNumber":37,"juzNumber":27,"pageNumber":535,"arabicText":"عُرُبًا أَتْرَابًۭا","translationText":"zu liebevollen Altersgenossinnen"},{"key":"56:38","surahNumber":56,"ayahNumber":38,"juzNumber":27,"pageNumber":535,"arabicText":"لِّأَصْحَٰبِ ٱلْيَمِينِ","translationText":"derer zur Rechten."},{"key":"56:39","surahNumber":56,"ayahNumber":39,"juzNumber":27,"pageNumber":535,"arabicText":"ثُلَّةٌۭ مِّنَ ٱلْأَوَّلِينَ","translationText":"(Dies sind) eine große Schar der Früheren"},{"key":"56:40","surahNumber":56,"ayahNumber":40,"juzNumber":27,"pageNumber":535,"arabicText":"وَثُلَّةٌۭ مِّنَ ٱلْءَاخِرِينَ","translationText":"und eine große Schar der Späteren."},{"key":"56:41","surahNumber":56,"ayahNumber":41,"juzNumber":27,"pageNumber":535,"arabicText":"وَأَصْحَٰبُ ٱلشِّمَالِ مَآ أَصْحَٰبُ ٱلشِّمَالِ","translationText":"Und die zur Linken - was (wißt ihr) von denen, die zur Linken sein werden?"},{"key":"56:42","surahNumber":56,"ayahNumber":42,"juzNumber":27,"pageNumber":535,"arabicText":"فِى سَمُومٍۢ وَحَمِيمٍۢ","translationText":"(Sie werden) inmitten von glühenden Winden und siedendem Wasser (sein)"},{"key":"56:43","surahNumber":56,"ayahNumber":43,"juzNumber":27,"pageNumber":535,"arabicText":"وَظِلٍّۢ مِّن يَحْمُومٍۢ","translationText":"und im Schatten schwarzen Rauches"},{"key":"56:44","surahNumber":56,"ayahNumber":44,"juzNumber":27,"pageNumber":535,"arabicText":"لَّا بَارِدٍۢ وَلَا كَرِيمٍ","translationText":"der weder kühl noch erfrischend ist."},{"key":"56:45","surahNumber":56,"ayahNumber":45,"juzNumber":27,"pageNumber":535,"arabicText":"إِنَّهُمْ كَانُوا۟ قَبْلَ ذَٰلِكَ مُتْرَفِينَ","translationText":"Vor diesem (Schicksal) wurden sie in der Tat mit Wohlleben verwöhnt"},{"key":"56:46","surahNumber":56,"ayahNumber":46,"juzNumber":27,"pageNumber":535,"arabicText":"وَكَانُوا۟ يُصِرُّونَ عَلَى ٱلْحِنثِ ٱلْعَظِيمِ","translationText":"und (sie) verharrten in großer Sünde."},{"key":"56:47","surahNumber":56,"ayahNumber":47,"juzNumber":27,"pageNumber":535,"arabicText":"وَكَانُوا۟ يَقُولُونَ أَئِذَا مِتْنَا وَكُنَّا تُرَابًۭا وَعِظَٰمًا أَءِنَّا لَمَبْعُوثُونَ","translationText":"Und sie pflegten zu sagen: \"Wie? Wenn wir tot sind und zu Staub und Gebeinen geworden sind, dann sollen wir wirklich auferweckt werden?"},{"key":"56:48","surahNumber":56,"ayahNumber":48,"juzNumber":27,"pageNumber":535,"arabicText":"أَوَءَابَآؤُنَا ٱلْأَوَّلُونَ","translationText":"Und unsere Vorväter auch?\""},{"key":"56:49","surahNumber":56,"ayahNumber":49,"juzNumber":27,"pageNumber":535,"arabicText":"قُلْ إِنَّ ٱلْأَوَّلِينَ وَٱلْءَاخِرِينَ","translationText":"Sprich: \"Wahrlich, die Früheren und die Späteren"},{"key":"56:50","surahNumber":56,"ayahNumber":50,"juzNumber":27,"pageNumber":535,"arabicText":"لَمَجْمُوعُونَ إِلَىٰ مِيقَٰتِ يَوْمٍۢ مَّعْلُومٍۢ","translationText":"werden alle zur gesetzten Frist eines bestimmten Tages versammelt werden."}],"translationEditionUsed":"de.aburida"}