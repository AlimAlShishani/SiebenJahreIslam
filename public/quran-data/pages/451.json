{"pageNumber":451,"juzNumber":23,"verses":[{"key":"37:127","surahNumber":37,"ayahNumber":127,"juzNumber":23,"pageNumber":451,"arabicText":"فَكَذَّبُوهُ فَإِنَّهُمْ لَمُحْضَرُونَ","translationText":"Jedoch sie erklärten ihn als Lügner, und sie werden bestimmt (zum Gericht) gebracht werden"},{"key":"37:128","surahNumber":37,"ayahNumber":128,"juzNumber":23,"pageNumber":451,"arabicText":"إِلَّا عِبَادَ ٱللَّهِ ٱلْمُخْلَصِينَ","translationText":"ausgenommen die erwählten Diener Allahs."},{"key":"37:129","surahNumber":37,"ayahNumber":129,"juzNumber":23,"pageNumber":451,"arabicText":"وَتَرَكْنَا عَلَيْهِ فِى ٱلْءَاخِرِينَ","translationText":"Und Wir bewahrten seinen Namen unter den künftigen Geschlechtern."},{"key":"37:130","surahNumber":37,"ayahNumber":130,"juzNumber":23,"pageNumber":451,"arabicText":"سَلَٰمٌ عَلَىٰٓ إِلْ يَاسِينَ","translationText":"Friede sei auf Il-Yasin!"},{"key":"37:131","surahNumber":37,"ayahNumber":131,"juzNumber":23,"pageNumber":451,"arabicText":"إِنَّا كَذَٰلِكَ نَجْزِى ٱلْمُحْسِنِينَ","translationText":"So belohnen Wir die, die Gutes tun."},{"key":"37:132","surahNumber":37,"ayahNumber":132,"juzNumber":23,"pageNumber":451,"arabicText":"إِنَّهُۥ مِنْ عِبَادِنَا ٱلْمُؤْمِنِينَ","translationText":"Er gehörte zu Unseren gläubigen Dienern."},{"key":"37:133","surahNumber":37,"ayahNumber":133,"juzNumber":23,"pageNumber":451,"arabicText":"وَإِنَّ لُوطًۭا لَّمِنَ ٱلْمُرْسَلِينَ","translationText":"Und wahrlich, (auch) Lot war einer der Gesandten."},{"key":"37:134","surahNumber":37,"ayahNumber":134,"juzNumber":23,"pageNumber":451,"arabicText":"إِذْ نَجَّيْنَٰهُ وَأَهْلَهُۥٓ أَجْمَعِينَ","translationText":"Da erretteten Wir ihn und alle die Seinen"},{"key":"37:135","surahNumber":37,"ayahNumber":135,"juzNumber":23,"pageNumber":451,"arabicText":"إِلَّا عَجُوزًۭا فِى ٱلْغَٰبِرِينَ","translationText":"ausgenommen eine alte Frau, die mit den (anderen) zurückblieb."},{"key":"37:136","surahNumber":37,"ayahNumber":136,"juzNumber":23,"pageNumber":451,"arabicText":"ثُمَّ دَمَّرْنَا ٱلْءَاخَرِينَ","translationText":"Hierauf zerstörten Wir die anderen."},{"key":"37:137","surahNumber":37,"ayahNumber":137,"juzNumber":23,"pageNumber":451,"arabicText":"وَإِنَّكُمْ لَتَمُرُّونَ عَلَيْهِم مُّصْبِحِينَ","translationText":"Und wahrlich, ihr geht an ihnen am Morgen vorüber"},{"key":"37:138","surahNumber":37,"ayahNumber":138,"juzNumber":23,"pageNumber":451,"arabicText":"وَبِٱلَّيْلِ ۗ أَفَلَا تَعْقِلُونَ","translationText":"und auch am Abend. Wollt ihr es da nicht begreifen?"},{"key":"37:139","surahNumber":37,"ayahNumber":139,"juzNumber":23,"pageNumber":451,"arabicText":"وَإِنَّ يُونُسَ لَمِنَ ٱلْمُرْسَلِينَ","translationText":"Und sicher war Jonas einer der Gesandten."},{"key":"37:140","surahNumber":37,"ayahNumber":140,"juzNumber":23,"pageNumber":451,"arabicText":"إِذْ أَبَقَ إِلَى ٱلْفُلْكِ ٱلْمَشْحُونِ","translationText":"Da floh er zu dem beladenen Schiff"},{"key":"37:141","surahNumber":37,"ayahNumber":141,"juzNumber":23,"pageNumber":451,"arabicText":"فَسَاهَمَ فَكَانَ مِنَ ٱلْمُدْحَضِينَ","translationText":"und loste und verlor dabei."},{"key":"37:142","surahNumber":37,"ayahNumber":142,"juzNumber":23,"pageNumber":451,"arabicText":"فَٱلْتَقَمَهُ ٱلْحُوتُ وَهُوَ مُلِيمٌۭ","translationText":"Und der große Fisch verschlang ihn, während er (Jonas, sich selbst) tadelte."},{"key":"37:143","surahNumber":37,"ayahNumber":143,"juzNumber":23,"pageNumber":451,"arabicText":"فَلَوْلَآ أَنَّهُۥ كَانَ مِنَ ٱلْمُسَبِّحِينَ","translationText":"Wenn er nicht zu jenen gehört hätte, die (Allah) preisen"},{"key":"37:144","surahNumber":37,"ayahNumber":144,"juzNumber":23,"pageNumber":451,"arabicText":"لَلَبِثَ فِى بَطْنِهِۦٓ إِلَىٰ يَوْمِ يُبْعَثُونَ","translationText":"wäre er gewiß in dessen Bauch bis zum Tage der Auferstehung geblieben."},{"key":"37:145","surahNumber":37,"ayahNumber":145,"juzNumber":23,"pageNumber":451,"arabicText":"۞ فَنَبَذْنَٰهُ بِٱلْعَرَآءِ وَهُوَ سَقِيمٌۭ","translationText":"Dann warfen Wir ihn ins Freie, und er war krank."},{"key":"37:146","surahNumber":37,"ayahNumber":146,"juzNumber":23,"pageNumber":451,"arabicText":"وَأَنۢبَتْنَا عَلَيْهِ شَجَرَةًۭ مِّن يَقْطِينٍۢ","translationText":"Und Wir ließen eine Kürbispflanze über ihm wachsen."},{"key":"37:147","surahNumber":37,"ayahNumber":147,"juzNumber":23,"pageNumber":451,"arabicText":"وَأَرْسَلْنَٰهُ إِلَىٰ مِا۟ئَةِ أَلْفٍ أَوْ يَزِيدُونَ","translationText":"Und Wir entsandten ihn zu hunderttausend oder mehr (Menschen)"},{"key":"37:148","surahNumber":37,"ayahNumber":148,"juzNumber":23,"pageNumber":451,"arabicText":"فَـَٔامَنُوا۟ فَمَتَّعْنَٰهُمْ إِلَىٰ حِينٍۢ","translationText":"Und sie wurden gläubig; so gewährten Wir ihnen für eine Zeitlang Versorgung."},{"key":"37:149","surahNumber":37,"ayahNumber":149,"juzNumber":23,"pageNumber":451,"arabicText":"فَٱسْتَفْتِهِمْ أَلِرَبِّكَ ٱلْبَنَاتُ وَلَهُمُ ٱلْبَنُونَ","translationText":"Nun frage sie, ob dein Herr Töchter hat, während sie Söhne haben."},{"key":"37:150","surahNumber":37,"ayahNumber":150,"juzNumber":23,"pageNumber":451,"arabicText":"أَمْ خَلَقْنَا ٱلْمَلَٰٓئِكَةَ إِنَٰثًۭا وَهُمْ شَٰهِدُونَ","translationText":"Oder haben Wir etwa die Engel weiblich erschaffen, während sie zugegen waren?"},{"key":"37:151","surahNumber":37,"ayahNumber":151,"juzNumber":23,"pageNumber":451,"arabicText":"أَلَآ إِنَّهُم مِّنْ إِفْكِهِمْ لَيَقُولُونَ","translationText":"Es ist bloß ihre eigene Lüge, wenn sie sagen"},{"key":"37:152","surahNumber":37,"ayahNumber":152,"juzNumber":23,"pageNumber":451,"arabicText":"وَلَدَ ٱللَّهُ وَإِنَّهُمْ لَكَٰذِبُونَ","translationText":"\"Allah hat gezeugt\"; und sie sind wahrlich Lügner."},{"key":"37:153","surahNumber":37,"ayahNumber":153,"juzNumber":23,"pageNumber":451,"arabicText":"أَصْطَفَى ٱلْبَنَاتِ عَلَى ٱلْبَنِينَ","translationText":"Hat Er Töchter den Söhnen vorgezogen?"}],"translationEditionUsed":"de.aburida"}