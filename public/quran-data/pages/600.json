{"pageNumber":600,"juzNumber":30,"verses":[{"key":"100:10","surahNumber":100,"ayahNumber":10,"juzNumber":30,"pageNumber":600,"arabicText":"وَحُصِّلَ مَا فِى ٱلصُّدُورِ","translationText":"und das herausgeholt wird, was in den Herzen ist"},{"key":"100:11","surahNumber":100,"ayahNumber":11,"juzNumber":30,"pageNumber":600,"arabicText":"إِنَّ رَبَّهُم بِهِمْ يَوْمَئِذٍۢ لَّخَبِيرٌۢ","translationText":"daß ihr Herr sie wahrlich an jenem Tag wohl kennt?"},{"key":"101:1","surahNumber":101,"ayahNumber":1,"juzNumber":30,"pageNumber":600,"arabicText":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ ٱلْقَارِعَةُ","translationText":"Al-Qaria!"},{"key":"101:2","surahNumber":101,"ayahNumber":2,"juzNumber":30,"pageNumber":600,"arabicText":"مَا ٱلْقَارِعَةُ","translationText":"Was ist AI-Qaria?"},{"key":"101:3","surahNumber":101,"ayahNumber":3,"juzNumber":30,"pageNumber":600,"arabicText":"وَمَآ أَدْرَىٰكَ مَا ٱلْقَارِعَةُ","translationText":"Und was läßt dich wissen, was Al-Qaria ist?"},{"key":"101:4","surahNumber":101,"ayahNumber":4,"juzNumber":30,"pageNumber":600,"arabicText":"يَوْمَ يَكُونُ ٱلنَّاسُ كَٱلْفَرَاشِ ٱلْمَبْثُوثِ","translationText":"An einem Tage, da die Menschen gleich verstreuten Motten sein werden"},{"key":"101:5","surahNumber":101,"ayahNumber":5,"juzNumber":30,"pageNumber":600,"arabicText":"وَتَكُونُ ٱلْجِبَالُ كَٱلْعِهْنِ ٱلْمَنفُوشِ","translationText":"und die Berge gleich bunter, zerflockter Wolle"},{"key":"101:6","surahNumber":101,"ayahNumber":6,"juzNumber":30,"pageNumber":600,"arabicText":"فَأَمَّا مَن ثَقُلَتْ مَوَٰزِينُهُۥ","translationText":"dann wird der, dessen Waage schwer ist"},{"key":"101:7","surahNumber":101,"ayahNumber":7,"juzNumber":30,"pageNumber":600,"arabicText":"فَهُوَ فِى عِيشَةٍۢ رَّاضِيَةٍۢ","translationText":"ein Wohlleben genießen"},{"key":"101:8","surahNumber":101,"ayahNumber":8,"juzNumber":30,"pageNumber":600,"arabicText":"وَأَمَّا مَنْ خَفَّتْ مَوَٰزِينُهُۥ","translationText":"dem aber, dessen Waage leicht ist"},{"key":"101:9","surahNumber":101,"ayahNumber":9,"juzNumber":30,"pageNumber":600,"arabicText":"فَأُمُّهُۥ هَاوِيَةٌۭ","translationText":"wird die Hawiya sein Endziel sein."},{"key":"101:10","surahNumber":101,"ayahNumber":10,"juzNumber":30,"pageNumber":600,"arabicText":"وَمَآ أَدْرَىٰكَ مَا هِيَهْ","translationText":"Und was lehrt dich wissen, was die (Hawiya) ist?"},{"key":"101:11","surahNumber":101,"ayahNumber":11,"juzNumber":30,"pageNumber":600,"arabicText":"نَارٌ حَامِيَةٌۢ","translationText":"(Sie ist) ein glühendes Feuer."},{"key":"102:1","surahNumber":102,"ayahNumber":1,"juzNumber":30,"pageNumber":600,"arabicText":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ أَلْهَىٰكُمُ ٱلتَّكَاثُرُ","translationText":"Das Streben nach Mehr lenkt euch solange ab"},{"key":"102:2","surahNumber":102,"ayahNumber":2,"juzNumber":30,"pageNumber":600,"arabicText":"حَتَّىٰ زُرْتُمُ ٱلْمَقَابِرَ","translationText":"bis ihr die Gräber besucht."},{"key":"102:3","surahNumber":102,"ayahNumber":3,"juzNumber":30,"pageNumber":600,"arabicText":"كَلَّا سَوْفَ تَعْلَمُونَ","translationText":"Aber nein! Ihr werdet es bald erfahren."},{"key":"102:4","surahNumber":102,"ayahNumber":4,"juzNumber":30,"pageNumber":600,"arabicText":"ثُمَّ كَلَّا سَوْفَ تَعْلَمُونَ","translationText":"Wiederum: Aber nein! Ihr werdet es bald erfahren."},{"key":"102:5","surahNumber":102,"ayahNumber":5,"juzNumber":30,"pageNumber":600,"arabicText":"كَلَّا لَوْ تَعْلَمُونَ عِلْمَ ٱلْيَقِينِ","translationText":"Aber nein! Wenn ihr es sicher wüßtet!"},{"key":"102:6","surahNumber":102,"ayahNumber":6,"juzNumber":30,"pageNumber":600,"arabicText":"لَتَرَوُنَّ ٱلْجَحِيمَ","translationText":"Ihr werdet die Gahim sehen."},{"key":"102:7","surahNumber":102,"ayahNumber":7,"juzNumber":30,"pageNumber":600,"arabicText":"ثُمَّ لَتَرَوُنَّهَا عَيْنَ ٱلْيَقِينِ","translationText":"Doch, ihr sollt sie noch mit dem Auge der Gewißheit sehen."},{"key":"102:8","surahNumber":102,"ayahNumber":8,"juzNumber":30,"pageNumber":600,"arabicText":"ثُمَّ لَتُسْـَٔلُنَّ يَوْمَئِذٍ عَنِ ٱلنَّعِيمِ","translationText":"Dann werdet ihr, an jenem Tage, nach dem Wohlstand befragt."}],"translationEditionUsed":"de.aburida"}