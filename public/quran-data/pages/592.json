{"pageNumber":592,"juzNumber":30,"verses":[{"key":"87:16","surahNumber":87,"ayahNumber":16,"juzNumber":30,"pageNumber":592,"arabicText":"بَلْ تُؤْثِرُونَ ٱلْحَيَوٰةَ ٱلدُّنْيَا","translationText":"Doch ihr zieht das irdische Leben vor"},{"key":"87:17","surahNumber":87,"ayahNumber":17,"juzNumber":30,"pageNumber":592,"arabicText":"وَٱلْءَاخِرَةُ خَيْرٌۭ وَأَبْقَىٰٓ","translationText":"wo doch das Jenseits besser und dauerhafter ist."},{"key":"87:18","surahNumber":87,"ayahNumber":18,"juzNumber":30,"pageNumber":592,"arabicText":"إِنَّ هَٰذَا لَفِى ٱلصُّحُفِ ٱلْأُولَىٰ","translationText":"Dies stand wahrlich in den ersten Schriften"},{"key":"87:19","surahNumber":87,"ayahNumber":19,"juzNumber":30,"pageNumber":592,"arabicText":"صُحُفِ إِبْرَٰهِيمَ وَمُوسَىٰ","translationText":"den Schriften Abrahams und Moses'."},{"key":"88:1","surahNumber":88,"ayahNumber":1,"juzNumber":30,"pageNumber":592,"arabicText":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ هَلْ أَتَىٰكَ حَدِيثُ ٱلْغَٰشِيَةِ","translationText":"Hat die Geschichte der Al-Gasiya dich erreicht?"},{"key":"88:2","surahNumber":88,"ayahNumber":2,"juzNumber":30,"pageNumber":592,"arabicText":"وُجُوهٌۭ يَوْمَئِذٍ خَٰشِعَةٌ","translationText":"Manche Gesichter werden an jenem Tag niedergeschlagen sein"},{"key":"88:3","surahNumber":88,"ayahNumber":3,"juzNumber":30,"pageNumber":592,"arabicText":"عَامِلَةٌۭ نَّاصِبَةٌۭ","translationText":"sie werden sich plagen und abmühen"},{"key":"88:4","surahNumber":88,"ayahNumber":4,"juzNumber":30,"pageNumber":592,"arabicText":"تَصْلَىٰ نَارًا حَامِيَةًۭ","translationText":"sie werden in einem heißen Feuer brennen"},{"key":"88:5","surahNumber":88,"ayahNumber":5,"juzNumber":30,"pageNumber":592,"arabicText":"تُسْقَىٰ مِنْ عَيْنٍ ءَانِيَةٍۢ","translationText":"sie werden aus einer kochendheißen Quelle trinken"},{"key":"88:6","surahNumber":88,"ayahNumber":6,"juzNumber":30,"pageNumber":592,"arabicText":"لَّيْسَ لَهُمْ طَعَامٌ إِلَّا مِن ضَرِيعٍۢ","translationText":"für sie wird es keine andere Speise geben außer Dornsträuchern"},{"key":"88:7","surahNumber":88,"ayahNumber":7,"juzNumber":30,"pageNumber":592,"arabicText":"لَّا يُسْمِنُ وَلَا يُغْنِى مِن جُوعٍۢ","translationText":"die weder nähren noch Hunger stillen."},{"key":"88:8","surahNumber":88,"ayahNumber":8,"juzNumber":30,"pageNumber":592,"arabicText":"وُجُوهٌۭ يَوْمَئِذٍۢ نَّاعِمَةٌۭ","translationText":"(Und manche) Gesichter werden an jenem Tage fröhlich sein"},{"key":"88:9","surahNumber":88,"ayahNumber":9,"juzNumber":30,"pageNumber":592,"arabicText":"لِّسَعْيِهَا رَاضِيَةٌۭ","translationText":"wohlzufrieden mit ihrer Mühe"},{"key":"88:10","surahNumber":88,"ayahNumber":10,"juzNumber":30,"pageNumber":592,"arabicText":"فِى جَنَّةٍ عَالِيَةٍۢ","translationText":"in einem hohen Garten"},{"key":"88:11","surahNumber":88,"ayahNumber":11,"juzNumber":30,"pageNumber":592,"arabicText":"لَّا تَسْمَعُ فِيهَا لَٰغِيَةًۭ","translationText":"in dem sie kein Geschwätz hören"},{"key":"88:12","surahNumber":88,"ayahNumber":12,"juzNumber":30,"pageNumber":592,"arabicText":"فِيهَا عَيْنٌۭ جَارِيَةٌۭ","translationText":"in dem eine strömende Quelle ist"},{"key":"88:13","surahNumber":88,"ayahNumber":13,"juzNumber":30,"pageNumber":592,"arabicText":"فِيهَا سُرُرٌۭ مَّرْفُوعَةٌۭ","translationText":"in dem es erhöhte Ruhebetten gibt"},{"key":"88:14","surahNumber":88,"ayahNumber":14,"juzNumber":30,"pageNumber":592,"arabicText":"وَأَكْوَابٌۭ مَّوْضُوعَةٌۭ","translationText":"und bereitgestellte Becher"},{"key":"88:15","surahNumber":88,"ayahNumber":15,"juzNumber":30,"pageNumber":592,"arabicText":"وَنَمَارِقُ مَصْفُوفَةٌۭ","translationText":"und aufgereihte Kissen"},{"key":"88:16","surahNumber":88,"ayahNumber":16,"juzNumber":30,"pageNumber":592,"arabicText":"وَزَرَابِىُّ مَبْثُوثَةٌ","translationText":"und ausgebreitete Teppiche."},{"key":"88:17","surahNumber":88,"ayahNumber":17,"juzNumber":30,"pageNumber":592,"arabicText":"أَفَلَا يَنظُرُونَ إِلَى ٱلْإِبِلِ كَيْفَ خُلِقَتْ","translationText":"Schauen sie denn nicht zu den Kamelen, wie sie erschaffen sind"},{"key":"88:18","surahNumber":88,"ayahNumber":18,"juzNumber":30,"pageNumber":592,"arabicText":"وَإِلَى ٱلسَّمَآءِ كَيْفَ رُفِعَتْ","translationText":"und zu dem Himmel, wie er emporgehoben ist"},{"key":"88:19","surahNumber":88,"ayahNumber":19,"juzNumber":30,"pageNumber":592,"arabicText":"وَإِلَى ٱلْجِبَالِ كَيْفَ نُصِبَتْ","translationText":"und zu den Bergen, wie sie aufgerichtet sind"},{"key":"88:20","surahNumber":88,"ayahNumber":20,"juzNumber":30,"pageNumber":592,"arabicText":"وَإِلَى ٱلْأَرْضِ كَيْفَ سُطِحَتْ","translationText":"und zu der Erde, wie sie ausgebreitet worden ist?"},{"key":"88:21","surahNumber":88,"ayahNumber":21,"juzNumber":30,"pageNumber":592,"arabicText":"فَذَكِّرْ إِنَّمَآ أَنتَ مُذَكِّرٌۭ","translationText":"So ermahne; denn du bist zwar ein Ermahner"},{"key":"88:22","surahNumber":88,"ayahNumber":22,"juzNumber":30,"pageNumber":592,"arabicText":"لَّسْتَ عَلَيْهِم بِمُصَيْطِرٍ","translationText":"du hast aber keine Macht über sie"},{"key":"88:23","surahNumber":88,"ayahNumber":23,"juzNumber":30,"pageNumber":592,"arabicText":"إِلَّا مَن تَوَلَّىٰ وَكَفَرَ","translationText":"was jedoch den anbelangt, der sich abkehrt und im Unglauben verharrt."},{"key":"88:24","surahNumber":88,"ayahNumber":24,"juzNumber":30,"pageNumber":592,"arabicText":"فَيُعَذِّبُهُ ٱللَّهُ ٱلْعَذَابَ ٱلْأَكْبَرَ","translationText":"Allah wird ihn dann mit der schwersten Strafe bestrafen."},{"key":"88:25","surahNumber":88,"ayahNumber":25,"juzNumber":30,"pageNumber":592,"arabicText":"إِنَّ إِلَيْنَآ إِيَابَهُمْ","translationText":"Zu Uns ist ihre Heimkehr."},{"key":"88:26","surahNumber":88,"ayahNumber":26,"juzNumber":30,"pageNumber":592,"arabicText":"ثُمَّ إِنَّ عَلَيْنَا حِسَابَهُم","translationText":"Alsdann obliegt es Uns, mit ihnen abzurechnen."}],"translationEditionUsed":"de.aburida"}