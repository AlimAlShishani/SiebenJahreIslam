{"pageNumber":585,"juzNumber":30,"verses":[{"key":"80:1","surahNumber":80,"ayahNumber":1,"juzNumber":30,"pageNumber":585,"arabicText":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ عَبَسَ وَتَوَلَّىٰٓ","translationText":"Er runzelte die Stirn und wandte sich ab"},{"key":"80:2","surahNumber":80,"ayahNumber":2,"juzNumber":30,"pageNumber":585,"arabicText":"أَن جَآءَهُ ٱلْأَعْمَىٰ","translationText":"als der blinde Mann zu ihm kam."},{"key":"80:3","surahNumber":80,"ayahNumber":3,"juzNumber":30,"pageNumber":585,"arabicText":"وَمَا يُدْرِيكَ لَعَلَّهُۥ يَزَّكَّىٰٓ","translationText":"Was läßt dich aber wissen, daß er sich nicht reinigen wollte"},{"key":"80:4","surahNumber":80,"ayahNumber":4,"juzNumber":30,"pageNumber":585,"arabicText":"أَوْ يَذَّكَّرُ فَتَنفَعَهُ ٱلذِّكْرَىٰٓ","translationText":"oder daß er Ermahnung suchte und ihm somit die Lehre nützlich würde?"},{"key":"80:5","surahNumber":80,"ayahNumber":5,"juzNumber":30,"pageNumber":585,"arabicText":"أَمَّا مَنِ ٱسْتَغْنَىٰ","translationText":"Wer aber es nicht für nötig hält"},{"key":"80:6","surahNumber":80,"ayahNumber":6,"juzNumber":30,"pageNumber":585,"arabicText":"فَأَنتَ لَهُۥ تَصَدَّىٰ","translationText":"dem kommst du (bereitwillig) entgegen"},{"key":"80:7","surahNumber":80,"ayahNumber":7,"juzNumber":30,"pageNumber":585,"arabicText":"وَمَا عَلَيْكَ أَلَّا يَزَّكَّىٰ","translationText":"ohne dir etwas daraus zu machen, daß er sich nicht reinigen will."},{"key":"80:8","surahNumber":80,"ayahNumber":8,"juzNumber":30,"pageNumber":585,"arabicText":"وَأَمَّا مَن جَآءَكَ يَسْعَىٰ","translationText":"Was aber den anbelangt, der in Eifer zu dir kommt"},{"key":"80:9","surahNumber":80,"ayahNumber":9,"juzNumber":30,"pageNumber":585,"arabicText":"وَهُوَ يَخْشَىٰ","translationText":"und gottesfürchtig ist"},{"key":"80:10","surahNumber":80,"ayahNumber":10,"juzNumber":30,"pageNumber":585,"arabicText":"فَأَنتَ عَنْهُ تَلَهَّىٰ","translationText":"um den kümmerst du dich nicht."},{"key":"80:11","surahNumber":80,"ayahNumber":11,"juzNumber":30,"pageNumber":585,"arabicText":"كَلَّآ إِنَّهَا تَذْكِرَةٌۭ","translationText":"Nicht so. Wahrlich, dies ist eine Ermahnung"},{"key":"80:12","surahNumber":80,"ayahNumber":12,"juzNumber":30,"pageNumber":585,"arabicText":"فَمَن شَآءَ ذَكَرَهُۥ","translationText":"so möge, wer da will, diesem eingedenk sein."},{"key":"80:13","surahNumber":80,"ayahNumber":13,"juzNumber":30,"pageNumber":585,"arabicText":"فِى صُحُفٍۢ مُّكَرَّمَةٍۢ","translationText":"Auf geehrten Seiten, die in Ehren gehalten werden"},{"key":"80:14","surahNumber":80,"ayahNumber":14,"juzNumber":30,"pageNumber":585,"arabicText":"مَّرْفُوعَةٍۢ مُّطَهَّرَةٍۭ","translationText":"sind sie emporgehoben, rein"},{"key":"80:15","surahNumber":80,"ayahNumber":15,"juzNumber":30,"pageNumber":585,"arabicText":"بِأَيْدِى سَفَرَةٍۢ","translationText":"in den Händen rechtschaffener Sendboten"},{"key":"80:16","surahNumber":80,"ayahNumber":16,"juzNumber":30,"pageNumber":585,"arabicText":"كِرَامٍۭ بَرَرَةٍۢ","translationText":"die edel und tugendhaft sind."},{"key":"80:17","surahNumber":80,"ayahNumber":17,"juzNumber":30,"pageNumber":585,"arabicText":"قُتِلَ ٱلْإِنسَٰنُ مَآ أَكْفَرَهُۥ","translationText":"Verderben auf den Menschen! Wie undankbar ist er!"},{"key":"80:18","surahNumber":80,"ayahNumber":18,"juzNumber":30,"pageNumber":585,"arabicText":"مِنْ أَىِّ شَىْءٍ خَلَقَهُۥ","translationText":"Woraus hat Er ihn erschaffen?"},{"key":"80:19","surahNumber":80,"ayahNumber":19,"juzNumber":30,"pageNumber":585,"arabicText":"مِن نُّطْفَةٍ خَلَقَهُۥ فَقَدَّرَهُۥ","translationText":"Aus einem Samenerguß hat Er ihn erschaffen und gebildet."},{"key":"80:20","surahNumber":80,"ayahNumber":20,"juzNumber":30,"pageNumber":585,"arabicText":"ثُمَّ ٱلسَّبِيلَ يَسَّرَهُۥ","translationText":"Dann ermöglicht Er ihm den Ausgang."},{"key":"80:21","surahNumber":80,"ayahNumber":21,"juzNumber":30,"pageNumber":585,"arabicText":"ثُمَّ أَمَاتَهُۥ فَأَقْبَرَهُۥ","translationText":"Dann läßt Er ihn sterben und läßt ihn ins Grab bringen."},{"key":"80:22","surahNumber":80,"ayahNumber":22,"juzNumber":30,"pageNumber":585,"arabicText":"ثُمَّ إِذَا شَآءَ أَنشَرَهُۥ","translationText":"Dann, wenn Er will, erweckt Er ihn wieder."},{"key":"80:23","surahNumber":80,"ayahNumber":23,"juzNumber":30,"pageNumber":585,"arabicText":"كَلَّا لَمَّا يَقْضِ مَآ أَمَرَهُۥ","translationText":"Wahrlich; er hat nicht getan, was Er ihm geboten hat."},{"key":"80:24","surahNumber":80,"ayahNumber":24,"juzNumber":30,"pageNumber":585,"arabicText":"فَلْيَنظُرِ ٱلْإِنسَٰنُ إِلَىٰ طَعَامِهِۦٓ","translationText":"So soll der Mensch doch seine Nahrung betrachten."},{"key":"80:25","surahNumber":80,"ayahNumber":25,"juzNumber":30,"pageNumber":585,"arabicText":"أَنَّا صَبَبْنَا ٱلْمَآءَ صَبًّۭا","translationText":"Siehe, Wir gossen das Wasser in Fülle aus."},{"key":"80:26","surahNumber":80,"ayahNumber":26,"juzNumber":30,"pageNumber":585,"arabicText":"ثُمَّ شَقَقْنَا ٱلْأَرْضَ شَقًّۭا","translationText":"alsdann spalteten Wir die Erde in wunderbarer Weise"},{"key":"80:27","surahNumber":80,"ayahNumber":27,"juzNumber":30,"pageNumber":585,"arabicText":"فَأَنۢبَتْنَا فِيهَا حَبًّۭا","translationText":"und ließen Korn in ihr wachsen"},{"key":"80:28","surahNumber":80,"ayahNumber":28,"juzNumber":30,"pageNumber":585,"arabicText":"وَعِنَبًۭا وَقَضْبًۭا","translationText":"und Reben und Gezweig"},{"key":"80:29","surahNumber":80,"ayahNumber":29,"juzNumber":30,"pageNumber":585,"arabicText":"وَزَيْتُونًۭا وَنَخْلًۭا","translationText":"und Ölbäume und Palmen"},{"key":"80:30","surahNumber":80,"ayahNumber":30,"juzNumber":30,"pageNumber":585,"arabicText":"وَحَدَآئِقَ غُلْبًۭا","translationText":"und dicht bepflanzte Gartengehege"},{"key":"80:31","surahNumber":80,"ayahNumber":31,"juzNumber":30,"pageNumber":585,"arabicText":"وَفَٰكِهَةًۭ وَأَبًّۭا","translationText":"und Obst und Futtergras"},{"key":"80:32","surahNumber":80,"ayahNumber":32,"juzNumber":30,"pageNumber":585,"arabicText":"مَّتَٰعًۭا لَّكُمْ وَلِأَنْعَٰمِكُمْ","translationText":"als Versorgung für euch und euer Vieh."},{"key":"80:33","surahNumber":80,"ayahNumber":33,"juzNumber":30,"pageNumber":585,"arabicText":"فَإِذَا جَآءَتِ ٱلصَّآخَّةُ","translationText":"Doch wenn das betäubende Getöse kommt"},{"key":"80:34","surahNumber":80,"ayahNumber":34,"juzNumber":30,"pageNumber":585,"arabicText":"يَوْمَ يَفِرُّ ٱلْمَرْءُ مِنْ أَخِيهِ","translationText":"am Tage, da der Mensch seinen Bruder fluchtartig verläßt"},{"key":"80:35","surahNumber":80,"ayahNumber":35,"juzNumber":30,"pageNumber":585,"arabicText":"وَأُمِّهِۦ وَأَبِيهِ","translationText":"sowie seine Mutter und seinen Vater"},{"key":"80:36","surahNumber":80,"ayahNumber":36,"juzNumber":30,"pageNumber":585,"arabicText":"وَصَٰحِبَتِهِۦ وَبَنِيهِ","translationText":"und seine Frau und seine Söhne"},{"key":"80:37","surahNumber":80,"ayahNumber":37,"juzNumber":30,"pageNumber":585,"arabicText":"لِكُلِّ ٱمْرِئٍۢ مِّنْهُمْ يَوْمَئِذٍۢ شَأْنٌۭ يُغْنِيهِ","translationText":"an jenem Tage wird jeder eigene Sorgen genug haben, die ihn beschäftigen."},{"key":"80:38","surahNumber":80,"ayahNumber":38,"juzNumber":30,"pageNumber":585,"arabicText":"وُجُوهٌۭ يَوْمَئِذٍۢ مُّسْفِرَةٌۭ","translationText":"An jenem Tage werden manche Gesichter strahlend sein"},{"key":"80:39","surahNumber":80,"ayahNumber":39,"juzNumber":30,"pageNumber":585,"arabicText":"ضَاحِكَةٌۭ مُّسْتَبْشِرَةٌۭ","translationText":"heiter und freudig."},{"key":"80:40","surahNumber":80,"ayahNumber":40,"juzNumber":30,"pageNumber":585,"arabicText":"وَوُجُوهٌۭ يَوْمَئِذٍ عَلَيْهَا غَبَرَةٌۭ","translationText":"Und andere Gesichter, an jenem Tage, werden staubbedeckt sein."},{"key":"80:41","surahNumber":80,"ayahNumber":41,"juzNumber":30,"pageNumber":585,"arabicText":"تَرْهَقُهَا قَتَرَةٌ","translationText":"Trübung wird darauf liegen."},{"key":"80:42","surahNumber":80,"ayahNumber":42,"juzNumber":30,"pageNumber":585,"arabicText":"أُو۟لَٰٓئِكَ هُمُ ٱلْكَفَرَةُ ٱلْفَجَرَةُ","translationText":"Das sind die Ungläubigen, die Unverschämten."}],"translationEditionUsed":"de.aburida"}