{"pageNumber":450,"juzNumber":23,"verses":[{"key":"37:103","surahNumber":37,"ayahNumber":103,"juzNumber":23,"pageNumber":450,"arabicText":"فَلَمَّآ أَسْلَمَا وَتَلَّهُۥ لِلْجَبِينِ","translationText":"Когда они оба покорились, и он уложил его на бок,"},{"key":"37:104","surahNumber":37,"ayahNumber":104,"juzNumber":23,"pageNumber":450,"arabicText":"وَنَٰدَيْنَٰهُ أَن يَٰٓإِبْرَٰهِيمُ","translationText":"Мы воззвали к нему: «О Ибрахим (Авраам)!"},{"key":"37:105","surahNumber":37,"ayahNumber":105,"juzNumber":23,"pageNumber":450,"arabicText":"قَدْ صَدَّقْتَ ٱلرُّءْيَآ ۚ إِنَّا كَذَٰلِكَ نَجْزِى ٱلْمُحْسِنِينَ","translationText":"Ты оправдал сновидение». Воистину, так Мы воздаем творящим добро."},{"key":"37:106","surahNumber":37,"ayahNumber":106,"juzNumber":23,"pageNumber":450,"arabicText":"إِنَّ هَٰذَا لَهُوَ ٱلْبَلَٰٓؤُا۟ ٱلْمُبِينُ","translationText":"Это и есть явное испытание (или явная милость)."},{"key":"37:107","surahNumber":37,"ayahNumber":107,"juzNumber":23,"pageNumber":450,"arabicText":"وَفَدَيْنَٰهُ بِذِبْحٍ عَظِيمٍۢ","translationText":"Мы выкупили его великой жертвой."},{"key":"37:108","surahNumber":37,"ayahNumber":108,"juzNumber":23,"pageNumber":450,"arabicText":"وَتَرَكْنَا عَلَيْهِ فِى ٱلْءَاخِرِينَ","translationText":"Мы оставили о нем в последующих поколениях добрую молву."},{"key":"37:109","surahNumber":37,"ayahNumber":109,"juzNumber":23,"pageNumber":450,"arabicText":"سَلَٰمٌ عَلَىٰٓ إِبْرَٰهِيمَ","translationText":"Мир Ибрахиму (Аврааму)!"},{"key":"37:110","surahNumber":37,"ayahNumber":110,"juzNumber":23,"pageNumber":450,"arabicText":"كَذَٰلِكَ نَجْزِى ٱلْمُحْسِنِينَ","translationText":"Воистину, так Мы воздаем творящим добро."},{"key":"37:111","surahNumber":37,"ayahNumber":111,"juzNumber":23,"pageNumber":450,"arabicText":"إِنَّهُۥ مِنْ عِبَادِنَا ٱلْمُؤْمِنِينَ","translationText":"Воистину, он - один из Наших верующих рабов."},{"key":"37:112","surahNumber":37,"ayahNumber":112,"juzNumber":23,"pageNumber":450,"arabicText":"وَبَشَّرْنَٰهُ بِإِسْحَٰقَ نَبِيًّۭا مِّنَ ٱلصَّٰلِحِينَ","translationText":"Мы обрадовали его вестью об Исхаке (Исааке) - пророке из числа праведников."},{"key":"37:113","surahNumber":37,"ayahNumber":113,"juzNumber":23,"pageNumber":450,"arabicText":"وَبَٰرَكْنَا عَلَيْهِ وَعَلَىٰٓ إِسْحَٰقَ ۚ وَمِن ذُرِّيَّتِهِمَا مُحْسِنٌۭ وَظَالِمٌۭ لِّنَفْسِهِۦ مُبِينٌۭ","translationText":"Мы благословили его и Исхака (Исаака). Среди их потомства есть творящие добро и поступающие явно несправедливо к самим себе."},{"key":"37:114","surahNumber":37,"ayahNumber":114,"juzNumber":23,"pageNumber":450,"arabicText":"وَلَقَدْ مَنَنَّا عَلَىٰ مُوسَىٰ وَهَٰرُونَ","translationText":"Мы оказали милость Мусе (Моисею) и Харуну (Аарону)."},{"key":"37:115","surahNumber":37,"ayahNumber":115,"juzNumber":23,"pageNumber":450,"arabicText":"وَنَجَّيْنَٰهُمَا وَقَوْمَهُمَا مِنَ ٱلْكَرْبِ ٱلْعَظِيمِ","translationText":"Мы спасли их обоих и их народ от великой печали."},{"key":"37:116","surahNumber":37,"ayahNumber":116,"juzNumber":23,"pageNumber":450,"arabicText":"وَنَصَرْنَٰهُمْ فَكَانُوا۟ هُمُ ٱلْغَٰلِبِينَ","translationText":"Мы оказали им помощь, и именно они стали победителями."},{"key":"37:117","surahNumber":37,"ayahNumber":117,"juzNumber":23,"pageNumber":450,"arabicText":"وَءَاتَيْنَٰهُمَا ٱلْكِتَٰبَ ٱلْمُسْتَبِينَ","translationText":"Мы даровали им ясное Писание"},{"key":"37:118","surahNumber":37,"ayahNumber":118,"juzNumber":23,"pageNumber":450,"arabicText":"وَهَدَيْنَٰهُمَا ٱلصِّرَٰطَ ٱلْمُسْتَقِيمَ","translationText":"и повели их прямым путем."},{"key":"37:119","surahNumber":37,"ayahNumber":119,"juzNumber":23,"pageNumber":450,"arabicText":"وَتَرَكْنَا عَلَيْهِمَا فِى ٱلْءَاخِرِينَ","translationText":"Мы оставили о них в последующих поколениях добрую молву."},{"key":"37:120","surahNumber":37,"ayahNumber":120,"juzNumber":23,"pageNumber":450,"arabicText":"سَلَٰمٌ عَلَىٰ مُوسَىٰ وَهَٰرُونَ","translationText":"Мир Мусе (Моисею) и Харуну (Аарону)!"},{"key":"37:121","surahNumber":37,"ayahNumber":121,"juzNumber":23,"pageNumber":450,"arabicText":"إِنَّا كَذَٰلِكَ نَجْزِى ٱلْمُحْسِنِينَ","translationText":"Воистину, так Мы воздаем творящим добро."},{"key":"37:122","surahNumber":37,"ayahNumber":122,"juzNumber":23,"pageNumber":450,"arabicText":"إِنَّهُمَا مِنْ عِبَادِنَا ٱلْمُؤْمِنِينَ","translationText":"Воистину, они - одни из Наших верующих рабов."},{"key":"37:123","surahNumber":37,"ayahNumber":123,"juzNumber":23,"pageNumber":450,"arabicText":"وَإِنَّ إِلْيَاسَ لَمِنَ ٱلْمُرْسَلِينَ","translationText":"Ильяс (Илия) также был одним из посланников."},{"key":"37:124","surahNumber":37,"ayahNumber":124,"juzNumber":23,"pageNumber":450,"arabicText":"إِذْ قَالَ لِقَوْمِهِۦٓ أَلَا تَتَّقُونَ","translationText":"Он сказал своему народу: «Неужели вы не устрашитесь?"},{"key":"37:125","surahNumber":37,"ayahNumber":125,"juzNumber":23,"pageNumber":450,"arabicText":"أَتَدْعُونَ بَعْلًۭا وَتَذَرُونَ أَحْسَنَ ٱلْخَٰلِقِينَ","translationText":"Неужели вы взываете к Балу и оставляете Самого прекрасного из творцов -"},{"key":"37:126","surahNumber":37,"ayahNumber":126,"juzNumber":23,"pageNumber":450,"arabicText":"ٱللَّهَ رَبَّكُمْ وَرَبَّ ءَابَآئِكُمُ ٱلْأَوَّلِينَ","translationText":"Аллаха, Господа вашего и Господа ваших праотцев?»."}],"translationEditionUsed":"ru.kuliev"}