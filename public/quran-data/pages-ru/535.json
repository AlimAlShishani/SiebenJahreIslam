{"pageNumber":535,"juzNumber":27,"verses":[{"key":"56:17","surahNumber":56,"ayahNumber":17,"juzNumber":27,"pageNumber":535,"arabicText":"يَطُوفُ عَلَيْهِمْ وِلْدَٰنٌۭ مُّخَلَّدُونَ","translationText":"Вечно юные отроки будут обходить их"},{"key":"56:18","surahNumber":56,"ayahNumber":18,"juzNumber":27,"pageNumber":535,"arabicText":"بِأَكْوَابٍۢ وَأَبَارِيقَ وَكَأْسٍۢ مِّن مَّعِينٍۢ","translationText":"с чашами, кувшинами и кубками с родниковым напитком (вином),"},{"key":"56:19","surahNumber":56,"ayahNumber":19,"juzNumber":27,"pageNumber":535,"arabicText":"لَّا يُصَدَّعُونَ عَنْهَا وَلَا يُنزِفُونَ","translationText":"от которого не болит голова и не теряют рассудок,"},{"key":"56:20","surahNumber":56,"ayahNumber":20,"juzNumber":27,"pageNumber":535,"arabicText":"وَفَٰكِهَةٍۢ مِّمَّا يَتَخَيَّرُونَ","translationText":"с фруктами, которые они выбирают,"},{"key":"56:21","surahNumber":56,"ayahNumber":21,"juzNumber":27,"pageNumber":535,"arabicText":"وَلَحْمِ طَيْرٍۢ مِّمَّا يَشْتَهُونَ","translationText":"и мясом птиц, которое они желают."},{"key":"56:22","surahNumber":56,"ayahNumber":22,"juzNumber":27,"pageNumber":535,"arabicText":"وَحُورٌ عِينٌۭ","translationText":"Их женами будут черноокие, большеглазые девы,"},{"key":"56:23","surahNumber":56,"ayahNumber":23,"juzNumber":27,"pageNumber":535,"arabicText":"كَأَمْثَٰلِ ٱللُّؤْلُؤِ ٱلْمَكْنُونِ","translationText":"подобные сокрытым жемчужинам."},{"key":"56:24","surahNumber":56,"ayahNumber":24,"juzNumber":27,"pageNumber":535,"arabicText":"جَزَآءًۢ بِمَا كَانُوا۟ يَعْمَلُونَ","translationText":"Таково воздаяние за то, что они совершали."},{"key":"56:25","surahNumber":56,"ayahNumber":25,"juzNumber":27,"pageNumber":535,"arabicText":"لَا يَسْمَعُونَ فِيهَا لَغْوًۭا وَلَا تَأْثِيمًا","translationText":"Они не услышат там ни празднословия, ни греховных речей,"},{"key":"56:26","surahNumber":56,"ayahNumber":26,"juzNumber":27,"pageNumber":535,"arabicText":"إِلَّا قِيلًۭا سَلَٰمًۭا سَلَٰمًۭا","translationText":"а только слова: «Мир! Мир!»."},{"key":"56:27","surahNumber":56,"ayahNumber":27,"juzNumber":27,"pageNumber":535,"arabicText":"وَأَصْحَٰبُ ٱلْيَمِينِ مَآ أَصْحَٰبُ ٱلْيَمِينِ","translationText":"И будут те, кто по правую сторону. Кто же будет по правую сторону?"},{"key":"56:28","surahNumber":56,"ayahNumber":28,"juzNumber":27,"pageNumber":535,"arabicText":"فِى سِدْرٍۢ مَّخْضُودٍۢ","translationText":"Они пребудут среди лотосов, лишенных шипов,"},{"key":"56:29","surahNumber":56,"ayahNumber":29,"juzNumber":27,"pageNumber":535,"arabicText":"وَطَلْحٍۢ مَّنضُودٍۢ","translationText":"под бананами (или акациями камеденосными) с висящими рядами плодами,"},{"key":"56:30","surahNumber":56,"ayahNumber":30,"juzNumber":27,"pageNumber":535,"arabicText":"وَظِلٍّۢ مَّمْدُودٍۢ","translationText":"в распростертой тени,"},{"key":"56:31","surahNumber":56,"ayahNumber":31,"juzNumber":27,"pageNumber":535,"arabicText":"وَمَآءٍۢ مَّسْكُوبٍۢ","translationText":"среди разлитых вод"},{"key":"56:32","surahNumber":56,"ayahNumber":32,"juzNumber":27,"pageNumber":535,"arabicText":"وَفَٰكِهَةٍۢ كَثِيرَةٍۢ","translationText":"и многочисленных фруктов,"},{"key":"56:33","surahNumber":56,"ayahNumber":33,"juzNumber":27,"pageNumber":535,"arabicText":"لَّا مَقْطُوعَةٍۢ وَلَا مَمْنُوعَةٍۢ","translationText":"которые не кончаются и доступны."},{"key":"56:34","surahNumber":56,"ayahNumber":34,"juzNumber":27,"pageNumber":535,"arabicText":"وَفُرُشٍۢ مَّرْفُوعَةٍ","translationText":"Они будут лежать на приподнятых матрацах."},{"key":"56:35","surahNumber":56,"ayahNumber":35,"juzNumber":27,"pageNumber":535,"arabicText":"إِنَّآ أَنشَأْنَٰهُنَّ إِنشَآءًۭ","translationText":"Мы сотворим их в новом облике (совершенными)"},{"key":"56:36","surahNumber":56,"ayahNumber":36,"juzNumber":27,"pageNumber":535,"arabicText":"فَجَعَلْنَٰهُنَّ أَبْكَارًا","translationText":"и сделаем их девственницами,"},{"key":"56:37","surahNumber":56,"ayahNumber":37,"juzNumber":27,"pageNumber":535,"arabicText":"عُرُبًا أَتْرَابًۭا","translationText":"любящими и равными по возрасту."},{"key":"56:38","surahNumber":56,"ayahNumber":38,"juzNumber":27,"pageNumber":535,"arabicText":"لِّأَصْحَٰبِ ٱلْيَمِينِ","translationText":"Это - для тех, кто по правую сторону."},{"key":"56:39","surahNumber":56,"ayahNumber":39,"juzNumber":27,"pageNumber":535,"arabicText":"ثُلَّةٌۭ مِّنَ ٱلْأَوَّلِينَ","translationText":"Многие из них - из первых поколений,"},{"key":"56:40","surahNumber":56,"ayahNumber":40,"juzNumber":27,"pageNumber":535,"arabicText":"وَثُلَّةٌۭ مِّنَ ٱلْءَاخِرِينَ","translationText":"а многие - из последних."},{"key":"56:41","surahNumber":56,"ayahNumber":41,"juzNumber":27,"pageNumber":535,"arabicText":"وَأَصْحَٰبُ ٱلشِّمَالِ مَآ أَصْحَٰبُ ٱلشِّمَالِ","translationText":"И будут те, кто по левую сторону. Кто же будет по левую сторону?"},{"key":"56:42","surahNumber":56,"ayahNumber":42,"juzNumber":27,"pageNumber":535,"arabicText":"فِى سَمُومٍۢ وَحَمِيمٍۢ","translationText":"Они окажутся под знойным ветром и в кипятке,"},{"key":"56:43","surahNumber":56,"ayahNumber":43,"juzNumber":27,"pageNumber":535,"arabicText":"وَظِلٍّۢ مِّن يَحْمُومٍۢ","translationText":"в тени черного дыма,"},{"key":"56:44","surahNumber":56,"ayahNumber":44,"juzNumber":27,"pageNumber":535,"arabicText":"لَّا بَارِدٍۢ وَلَا كَرِيمٍ","translationText":"которая не приносит ни прохлады, ни добра."},{"key":"56:45","surahNumber":56,"ayahNumber":45,"juzNumber":27,"pageNumber":535,"arabicText":"إِنَّهُمْ كَانُوا۟ قَبْلَ ذَٰلِكَ مُتْرَفِينَ","translationText":"Прежде они нежились роскошью,"},{"key":"56:46","surahNumber":56,"ayahNumber":46,"juzNumber":27,"pageNumber":535,"arabicText":"وَكَانُوا۟ يُصِرُّونَ عَلَى ٱلْحِنثِ ٱلْعَظِيمِ","translationText":"упорствовали в великом грехе"},{"key":"56:47","surahNumber":56,"ayahNumber":47,"juzNumber":27,"pageNumber":535,"arabicText":"وَكَانُوا۟ يَقُولُونَ أَئِذَا مِتْنَا وَكُنَّا تُرَابًۭا وَعِظَٰمًا أَءِنَّا لَمَبْعُوثُونَ","translationText":"и говорили: «Неужели мы будем воскрешены после того, как мы умрем и станем прахом и костями?"},{"key":"56:48","surahNumber":56,"ayahNumber":48,"juzNumber":27,"pageNumber":535,"arabicText":"أَوَءَابَآؤُنَا ٱلْأَوَّلُونَ","translationText":"Или же наши праотцы?»."},{"key":"56:49","surahNumber":56,"ayahNumber":49,"juzNumber":27,"pageNumber":535,"arabicText":"قُلْ إِنَّ ٱلْأَوَّلِينَ وَٱلْءَاخِرِينَ","translationText":"Скажи: «Воистину, как первые, так и последние поколения"},{"key":"56:50","surahNumber":56,"ayahNumber":50,"juzNumber":27,"pageNumber":535,"arabicText":"لَمَجْمُوعُونَ إِلَىٰ مِيقَٰتِ يَوْمٍۢ مَّعْلُومٍۢ","translationText":"будут собраны в определенном месте в известный день."}],"translationEditionUsed":"ru.kuliev"}