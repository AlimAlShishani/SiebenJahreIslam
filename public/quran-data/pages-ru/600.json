{"pageNumber":600,"juzNumber":30,"verses":[{"key":"100:10","surahNumber":100,"ayahNumber":10,"juzNumber":30,"pageNumber":600,"arabicText":"وَحُصِّلَ مَا فِى ٱلصُّدُورِ","translationText":"и когда обнаружится то, что в груди,"},{"key":"100:11","surahNumber":100,"ayahNumber":11,"juzNumber":30,"pageNumber":600,"arabicText":"إِنَّ رَبَّهُم بِهِمْ يَوْمَئِذٍۢ لَّخَبِيرٌۢ","translationText":"в тот день Господь их будет осведомлен о них?"},{"key":"101:1","surahNumber":101,"ayahNumber":1,"juzNumber":30,"pageNumber":600,"arabicText":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ ٱلْقَارِعَةُ","translationText":"Великое бедствие (День воскресения)!"},{"key":"101:2","surahNumber":101,"ayahNumber":2,"juzNumber":30,"pageNumber":600,"arabicText":"مَا ٱلْقَارِعَةُ","translationText":"Что такое Великое бедствие (День воскресения)?"},{"key":"101:3","surahNumber":101,"ayahNumber":3,"juzNumber":30,"pageNumber":600,"arabicText":"وَمَآ أَدْرَىٰكَ مَا ٱلْقَارِعَةُ","translationText":"Откуда ты мог знать, что такое Великое бедствие (День воскресения)?"},{"key":"101:4","surahNumber":101,"ayahNumber":4,"juzNumber":30,"pageNumber":600,"arabicText":"يَوْمَ يَكُونُ ٱلنَّاسُ كَٱلْفَرَاشِ ٱلْمَبْثُوثِ","translationText":"В тот день люди будут подобны рассеянным мотылькам,"},{"key":"101:5","surahNumber":101,"ayahNumber":5,"juzNumber":30,"pageNumber":600,"arabicText":"وَتَكُونُ ٱلْجِبَالُ كَٱلْعِهْنِ ٱلْمَنفُوشِ","translationText":"а горы будут подобны расчесанной шерсти."},{"key":"101:6","surahNumber":101,"ayahNumber":6,"juzNumber":30,"pageNumber":600,"arabicText":"فَأَمَّا مَن ثَقُلَتْ مَوَٰزِينُهُۥ","translationText":"Тогда тот, чья чаша Весов окажется тяжелой,"},{"key":"101:7","surahNumber":101,"ayahNumber":7,"juzNumber":30,"pageNumber":600,"arabicText":"فَهُوَ فِى عِيشَةٍۢ رَّاضِيَةٍۢ","translationText":"обретет приятную жизнь."},{"key":"101:8","surahNumber":101,"ayahNumber":8,"juzNumber":30,"pageNumber":600,"arabicText":"وَأَمَّا مَنْ خَفَّتْ مَوَٰزِينُهُۥ","translationText":"Для того же, чья чаша Весов окажется легкой,"},{"key":"101:9","surahNumber":101,"ayahNumber":9,"juzNumber":30,"pageNumber":600,"arabicText":"فَأُمُّهُۥ هَاوِيَةٌۭ","translationText":"матерью станет Пропасть (грешники будут искать убежище в Аду, подобно тому, как ребенок ищет убежище у своей матери; или грешники будут падать в Адскую Пропасть вниз головой)."},{"key":"101:10","surahNumber":101,"ayahNumber":10,"juzNumber":30,"pageNumber":600,"arabicText":"وَمَآ أَدْرَىٰكَ مَا هِيَهْ","translationText":"Откуда ты мог знать, что это такое?"},{"key":"101:11","surahNumber":101,"ayahNumber":11,"juzNumber":30,"pageNumber":600,"arabicText":"نَارٌ حَامِيَةٌۢ","translationText":"Это - жаркий Огонь!"},{"key":"102:1","surahNumber":102,"ayahNumber":1,"juzNumber":30,"pageNumber":600,"arabicText":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ أَلْهَىٰكُمُ ٱلتَّكَاثُرُ","translationText":"Страсть к приумножению (похвальба богатством и детьми) увлекает вас"},{"key":"102:2","surahNumber":102,"ayahNumber":2,"juzNumber":30,"pageNumber":600,"arabicText":"حَتَّىٰ زُرْتُمُ ٱلْمَقَابِرَ","translationText":"настолько, что вы посещаете кладбища, чтобы бахвалиться своими покойниками (или пока вы сами не посетите могилы)."},{"key":"102:3","surahNumber":102,"ayahNumber":3,"juzNumber":30,"pageNumber":600,"arabicText":"كَلَّا سَوْفَ تَعْلَمُونَ","translationText":"Но нет! Скоро вы узнаете!"},{"key":"102:4","surahNumber":102,"ayahNumber":4,"juzNumber":30,"pageNumber":600,"arabicText":"ثُمَّ كَلَّا سَوْفَ تَعْلَمُونَ","translationText":"Еще раз нет! Скоро вы узнаете!"},{"key":"102:5","surahNumber":102,"ayahNumber":5,"juzNumber":30,"pageNumber":600,"arabicText":"كَلَّا لَوْ تَعْلَمُونَ عِلْمَ ٱلْيَقِينِ","translationText":"Но нет! Если бы вы только обладали убедительным знанием!"},{"key":"102:6","surahNumber":102,"ayahNumber":6,"juzNumber":30,"pageNumber":600,"arabicText":"لَتَرَوُنَّ ٱلْجَحِيمَ","translationText":"А ведь вы непременно увидите Ад."},{"key":"102:7","surahNumber":102,"ayahNumber":7,"juzNumber":30,"pageNumber":600,"arabicText":"ثُمَّ لَتَرَوُنَّهَا عَيْنَ ٱلْيَقِينِ","translationText":"Вы увидите его глазами убежденными."},{"key":"102:8","surahNumber":102,"ayahNumber":8,"juzNumber":30,"pageNumber":600,"arabicText":"ثُمَّ لَتُسْـَٔلُنَّ يَوْمَئِذٍ عَنِ ٱلنَّعِيمِ","translationText":"В тот день вы будете спрошены о благах."}],"translationEditionUsed":"ru.kuliev"}