{"pageNumber":592,"juzNumber":30,"verses":[{"key":"87:16","surahNumber":87,"ayahNumber":16,"juzNumber":30,"pageNumber":592,"arabicText":"بَلْ تُؤْثِرُونَ ٱلْحَيَوٰةَ ٱلدُّنْيَا","translationText":"Но нет! Вы отдаете предпочтение мирской жизни,"},{"key":"87:17","surahNumber":87,"ayahNumber":17,"juzNumber":30,"pageNumber":592,"arabicText":"وَٱلْءَاخِرَةُ خَيْرٌۭ وَأَبْقَىٰٓ","translationText":"хотя Последняя жизнь - лучше и дольше."},{"key":"87:18","surahNumber":87,"ayahNumber":18,"juzNumber":30,"pageNumber":592,"arabicText":"إِنَّ هَٰذَا لَفِى ٱلصُّحُفِ ٱلْأُولَىٰ","translationText":"Воистину, это записано в первых свитках -"},{"key":"87:19","surahNumber":87,"ayahNumber":19,"juzNumber":30,"pageNumber":592,"arabicText":"صُحُفِ إِبْرَٰهِيمَ وَمُوسَىٰ","translationText":"свитках Ибрахима (Авраама) и Мусы (Моисея)."},{"key":"88:1","surahNumber":88,"ayahNumber":1,"juzNumber":30,"pageNumber":592,"arabicText":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ هَلْ أَتَىٰكَ حَدِيثُ ٱلْغَٰشِيَةِ","translationText":"Дошел ли до тебя рассказ о Покрывающем (Дне воскресения)?"},{"key":"88:2","surahNumber":88,"ayahNumber":2,"juzNumber":30,"pageNumber":592,"arabicText":"وُجُوهٌۭ يَوْمَئِذٍ خَٰشِعَةٌ","translationText":"Одни лица в тот день будут унижены,"},{"key":"88:3","surahNumber":88,"ayahNumber":3,"juzNumber":30,"pageNumber":592,"arabicText":"عَامِلَةٌۭ نَّاصِبَةٌۭ","translationText":"изнурены и утомлены."},{"key":"88:4","surahNumber":88,"ayahNumber":4,"juzNumber":30,"pageNumber":592,"arabicText":"تَصْلَىٰ نَارًا حَامِيَةًۭ","translationText":"Они войдут в Огонь жаркий."},{"key":"88:5","surahNumber":88,"ayahNumber":5,"juzNumber":30,"pageNumber":592,"arabicText":"تُسْقَىٰ مِنْ عَيْنٍ ءَانِيَةٍۢ","translationText":"Их будут поить из источника кипящего"},{"key":"88:6","surahNumber":88,"ayahNumber":6,"juzNumber":30,"pageNumber":592,"arabicText":"لَّيْسَ لَهُمْ طَعَامٌ إِلَّا مِن ضَرِيعٍۢ","translationText":"и кормить только ядовитыми колючками,"},{"key":"88:7","surahNumber":88,"ayahNumber":7,"juzNumber":30,"pageNumber":592,"arabicText":"لَّا يُسْمِنُ وَلَا يُغْنِى مِن جُوعٍۢ","translationText":"от которых не поправляются и которые не утоляют голода."},{"key":"88:8","surahNumber":88,"ayahNumber":8,"juzNumber":30,"pageNumber":592,"arabicText":"وُجُوهٌۭ يَوْمَئِذٍۢ نَّاعِمَةٌۭ","translationText":"Другие же лица в тот день будут радостны."},{"key":"88:9","surahNumber":88,"ayahNumber":9,"juzNumber":30,"pageNumber":592,"arabicText":"لِّسَعْيِهَا رَاضِيَةٌۭ","translationText":"Они будут довольны своими стараниями"},{"key":"88:10","surahNumber":88,"ayahNumber":10,"juzNumber":30,"pageNumber":592,"arabicText":"فِى جَنَّةٍ عَالِيَةٍۢ","translationText":"в Вышних садах."},{"key":"88:11","surahNumber":88,"ayahNumber":11,"juzNumber":30,"pageNumber":592,"arabicText":"لَّا تَسْمَعُ فِيهَا لَٰغِيَةًۭ","translationText":"Они не услышат там словоблудия."},{"key":"88:12","surahNumber":88,"ayahNumber":12,"juzNumber":30,"pageNumber":592,"arabicText":"فِيهَا عَيْنٌۭ جَارِيَةٌۭ","translationText":"Там есть источник текущий."},{"key":"88:13","surahNumber":88,"ayahNumber":13,"juzNumber":30,"pageNumber":592,"arabicText":"فِيهَا سُرُرٌۭ مَّرْفُوعَةٌۭ","translationText":"Там воздвигнуты ложа,"},{"key":"88:14","surahNumber":88,"ayahNumber":14,"juzNumber":30,"pageNumber":592,"arabicText":"وَأَكْوَابٌۭ مَّوْضُوعَةٌۭ","translationText":"расставлены чаши,"},{"key":"88:15","surahNumber":88,"ayahNumber":15,"juzNumber":30,"pageNumber":592,"arabicText":"وَنَمَارِقُ مَصْفُوفَةٌۭ","translationText":"разложены подушки,"},{"key":"88:16","surahNumber":88,"ayahNumber":16,"juzNumber":30,"pageNumber":592,"arabicText":"وَزَرَابِىُّ مَبْثُوثَةٌ","translationText":"и разостланы ковры."},{"key":"88:17","surahNumber":88,"ayahNumber":17,"juzNumber":30,"pageNumber":592,"arabicText":"أَفَلَا يَنظُرُونَ إِلَى ٱلْإِبِلِ كَيْفَ خُلِقَتْ","translationText":"Неужели они не видят, как созданы верблюды,"},{"key":"88:18","surahNumber":88,"ayahNumber":18,"juzNumber":30,"pageNumber":592,"arabicText":"وَإِلَى ٱلسَّمَآءِ كَيْفَ رُفِعَتْ","translationText":"как вознесено небо,"},{"key":"88:19","surahNumber":88,"ayahNumber":19,"juzNumber":30,"pageNumber":592,"arabicText":"وَإِلَى ٱلْجِبَالِ كَيْفَ نُصِبَتْ","translationText":"как водружены горы,"},{"key":"88:20","surahNumber":88,"ayahNumber":20,"juzNumber":30,"pageNumber":592,"arabicText":"وَإِلَى ٱلْأَرْضِ كَيْفَ سُطِحَتْ","translationText":"как распростерта земля?"},{"key":"88:21","surahNumber":88,"ayahNumber":21,"juzNumber":30,"pageNumber":592,"arabicText":"فَذَكِّرْ إِنَّمَآ أَنتَ مُذَكِّرٌۭ","translationText":"Наставляй же, ведь ты - наставник,"},{"key":"88:22","surahNumber":88,"ayahNumber":22,"juzNumber":30,"pageNumber":592,"arabicText":"لَّسْتَ عَلَيْهِم بِمُصَيْطِرٍ","translationText":"и ты не властен над ними."},{"key":"88:23","surahNumber":88,"ayahNumber":23,"juzNumber":30,"pageNumber":592,"arabicText":"إِلَّا مَن تَوَلَّىٰ وَكَفَرَ","translationText":"А тех, кто отвернется и не уверует,"},{"key":"88:24","surahNumber":88,"ayahNumber":24,"juzNumber":30,"pageNumber":592,"arabicText":"فَيُعَذِّبُهُ ٱللَّهُ ٱلْعَذَابَ ٱلْأَكْبَرَ","translationText":"Аллах подвергнет величайшим мучениям."},{"key":"88:25","surahNumber":88,"ayahNumber":25,"juzNumber":30,"pageNumber":592,"arabicText":"إِنَّ إِلَيْنَآ إِيَابَهُمْ","translationText":"К Нам они вернутся,"},{"key":"88:26","surahNumber":88,"ayahNumber":26,"juzNumber":30,"pageNumber":592,"arabicText":"ثُمَّ إِنَّ عَلَيْنَا حِسَابَهُم","translationText":"и затем Мы потребуем у них отчета."}],"translationEditionUsed":"ru.kuliev"}