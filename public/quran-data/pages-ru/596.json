{"pageNumber":596,"juzNumber":30,"verses":[{"key":"92:15","surahNumber":92,"ayahNumber":15,"juzNumber":30,"pageNumber":596,"arabicText":"لَا يَصْلَىٰهَآ إِلَّا ٱلْأَشْقَى","translationText":"Войдет в него только самый несчастный,"},{"key":"92:16","surahNumber":92,"ayahNumber":16,"juzNumber":30,"pageNumber":596,"arabicText":"ٱلَّذِى كَذَّبَ وَتَوَلَّىٰ","translationText":"который считает истину ложью и отворачивается."},{"key":"92:17","surahNumber":92,"ayahNumber":17,"juzNumber":30,"pageNumber":596,"arabicText":"وَسَيُجَنَّبُهَا ٱلْأَتْقَى","translationText":"Отдален от него будет самый богобоязненный,"},{"key":"92:18","surahNumber":92,"ayahNumber":18,"juzNumber":30,"pageNumber":596,"arabicText":"ٱلَّذِى يُؤْتِى مَالَهُۥ يَتَزَكَّىٰ","translationText":"который раздает свое имущество, очищаясь,"},{"key":"92:19","surahNumber":92,"ayahNumber":19,"juzNumber":30,"pageNumber":596,"arabicText":"وَمَا لِأَحَدٍ عِندَهُۥ مِن نِّعْمَةٍۢ تُجْزَىٰٓ","translationText":"и всякую милость возмещает сполна"},{"key":"92:20","surahNumber":92,"ayahNumber":20,"juzNumber":30,"pageNumber":596,"arabicText":"إِلَّا ٱبْتِغَآءَ وَجْهِ رَبِّهِ ٱلْأَعْلَىٰ","translationText":"только из стремления к Лику своего Всевышнего Господа."},{"key":"92:21","surahNumber":92,"ayahNumber":21,"juzNumber":30,"pageNumber":596,"arabicText":"وَلَسَوْفَ يَرْضَىٰ","translationText":"И он непременно будет удовлетворен."},{"key":"93:1","surahNumber":93,"ayahNumber":1,"juzNumber":30,"pageNumber":596,"arabicText":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلضُّحَىٰ","translationText":"Клянусь утром!"},{"key":"93:2","surahNumber":93,"ayahNumber":2,"juzNumber":30,"pageNumber":596,"arabicText":"وَٱلَّيْلِ إِذَا سَجَىٰ","translationText":"Клянусь ночью, когда она успокаивается (или покрывается мраком)!"},{"key":"93:3","surahNumber":93,"ayahNumber":3,"juzNumber":30,"pageNumber":596,"arabicText":"مَا وَدَّعَكَ رَبُّكَ وَمَا قَلَىٰ","translationText":"Не покинул тебя твой Господь и не возненавидел."},{"key":"93:4","surahNumber":93,"ayahNumber":4,"juzNumber":30,"pageNumber":596,"arabicText":"وَلَلْءَاخِرَةُ خَيْرٌۭ لَّكَ مِنَ ٱلْأُولَىٰ","translationText":"Воистину, будущее для тебя лучше, чем настоящее."},{"key":"93:5","surahNumber":93,"ayahNumber":5,"juzNumber":30,"pageNumber":596,"arabicText":"وَلَسَوْفَ يُعْطِيكَ رَبُّكَ فَتَرْضَىٰٓ","translationText":"Господь твой непременно одарит тебя, и ты будешь удовлетворен."},{"key":"93:6","surahNumber":93,"ayahNumber":6,"juzNumber":30,"pageNumber":596,"arabicText":"أَلَمْ يَجِدْكَ يَتِيمًۭا فَـَٔاوَىٰ","translationText":"Разве Он не нашел тебя сиротой и не дал тебе приют?"},{"key":"93:7","surahNumber":93,"ayahNumber":7,"juzNumber":30,"pageNumber":596,"arabicText":"وَوَجَدَكَ ضَآلًّۭا فَهَدَىٰ","translationText":"Он нашел тебя заблудшим и повел прямым путем."},{"key":"93:8","surahNumber":93,"ayahNumber":8,"juzNumber":30,"pageNumber":596,"arabicText":"وَوَجَدَكَ عَآئِلًۭا فَأَغْنَىٰ","translationText":"Он нашел тебя бедным и обогатил."},{"key":"93:9","surahNumber":93,"ayahNumber":9,"juzNumber":30,"pageNumber":596,"arabicText":"فَأَمَّا ٱلْيَتِيمَ فَلَا تَقْهَرْ","translationText":"Посему не притесняй сироту!"},{"key":"93:10","surahNumber":93,"ayahNumber":10,"juzNumber":30,"pageNumber":596,"arabicText":"وَأَمَّا ٱلسَّآئِلَ فَلَا تَنْهَرْ","translationText":"И не гони просящего!"},{"key":"93:11","surahNumber":93,"ayahNumber":11,"juzNumber":30,"pageNumber":596,"arabicText":"وَأَمَّا بِنِعْمَةِ رَبِّكَ فَحَدِّثْ","translationText":"И возвещай о милости своего Господа."},{"key":"94:1","surahNumber":94,"ayahNumber":1,"juzNumber":30,"pageNumber":596,"arabicText":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ أَلَمْ نَشْرَحْ لَكَ صَدْرَكَ","translationText":"Разве Мы не раскрыли для тебя грудь твою?"},{"key":"94:2","surahNumber":94,"ayahNumber":2,"juzNumber":30,"pageNumber":596,"arabicText":"وَوَضَعْنَا عَنكَ وِزْرَكَ","translationText":"и не сняли с тебя ношу,"},{"key":"94:3","surahNumber":94,"ayahNumber":3,"juzNumber":30,"pageNumber":596,"arabicText":"ٱلَّذِىٓ أَنقَضَ ظَهْرَكَ","translationText":"которая отягощала твою спину?"},{"key":"94:4","surahNumber":94,"ayahNumber":4,"juzNumber":30,"pageNumber":596,"arabicText":"وَرَفَعْنَا لَكَ ذِكْرَكَ","translationText":"Разве Мы не возвеличили для тебя славу твою?"},{"key":"94:5","surahNumber":94,"ayahNumber":5,"juzNumber":30,"pageNumber":596,"arabicText":"فَإِنَّ مَعَ ٱلْعُسْرِ يُسْرًا","translationText":"Воистину, за каждой тягостью наступает облегчение."},{"key":"94:6","surahNumber":94,"ayahNumber":6,"juzNumber":30,"pageNumber":596,"arabicText":"إِنَّ مَعَ ٱلْعُسْرِ يُسْرًۭا","translationText":"За каждой тягостью наступает облегчение."},{"key":"94:7","surahNumber":94,"ayahNumber":7,"juzNumber":30,"pageNumber":596,"arabicText":"فَإِذَا فَرَغْتَ فَٱنصَبْ","translationText":"Посему, как только освободишься, будь деятелен (как только освободишься от мирских дел, усердно поклоняйся Аллаху, или как только завершишь намаз, усердно взывай к Аллаху с молитвами)"},{"key":"94:8","surahNumber":94,"ayahNumber":8,"juzNumber":30,"pageNumber":596,"arabicText":"وَإِلَىٰ رَبِّكَ فَٱرْغَب","translationText":"и устремись к своему Господу."}],"translationEditionUsed":"ru.kuliev"}