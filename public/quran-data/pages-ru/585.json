{"pageNumber":585,"juzNumber":30,"verses":[{"key":"80:1","surahNumber":80,"ayahNumber":1,"juzNumber":30,"pageNumber":585,"arabicText":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ عَبَسَ وَتَوَلَّىٰٓ","translationText":"Он нахмурился и отвернулся,"},{"key":"80:2","surahNumber":80,"ayahNumber":2,"juzNumber":30,"pageNumber":585,"arabicText":"أَن جَآءَهُ ٱلْأَعْمَىٰ","translationText":"потому что к нему подошел слепой."},{"key":"80:3","surahNumber":80,"ayahNumber":3,"juzNumber":30,"pageNumber":585,"arabicText":"وَمَا يُدْرِيكَ لَعَلَّهُۥ يَزَّكَّىٰٓ","translationText":"Откуда тебе знать? Возможно, он бы очистился"},{"key":"80:4","surahNumber":80,"ayahNumber":4,"juzNumber":30,"pageNumber":585,"arabicText":"أَوْ يَذَّكَّرُ فَتَنفَعَهُ ٱلذِّكْرَىٰٓ","translationText":"или помянул бы наставление, и поминание принесло бы ему пользу."},{"key":"80:5","surahNumber":80,"ayahNumber":5,"juzNumber":30,"pageNumber":585,"arabicText":"أَمَّا مَنِ ٱسْتَغْنَىٰ","translationText":"Тому, кто решил, что он ни в чем не нуждается,"},{"key":"80:6","surahNumber":80,"ayahNumber":6,"juzNumber":30,"pageNumber":585,"arabicText":"فَأَنتَ لَهُۥ تَصَدَّىٰ","translationText":"ты уделяешь внимание,"},{"key":"80:7","surahNumber":80,"ayahNumber":7,"juzNumber":30,"pageNumber":585,"arabicText":"وَمَا عَلَيْكَ أَلَّا يَزَّكَّىٰ","translationText":"Что же будет тебе, если он не очистится?"},{"key":"80:8","surahNumber":80,"ayahNumber":8,"juzNumber":30,"pageNumber":585,"arabicText":"وَأَمَّا مَن جَآءَكَ يَسْعَىٰ","translationText":"А того, кто приходит к тебе со рвением"},{"key":"80:9","surahNumber":80,"ayahNumber":9,"juzNumber":30,"pageNumber":585,"arabicText":"وَهُوَ يَخْشَىٰ","translationText":"и страшится Аллаха,"},{"key":"80:10","surahNumber":80,"ayahNumber":10,"juzNumber":30,"pageNumber":585,"arabicText":"فَأَنتَ عَنْهُ تَلَهَّىٰ","translationText":"ты оставляешь без внимания."},{"key":"80:11","surahNumber":80,"ayahNumber":11,"juzNumber":30,"pageNumber":585,"arabicText":"كَلَّآ إِنَّهَا تَذْكِرَةٌۭ","translationText":"Но нет! Это есть Назидание,"},{"key":"80:12","surahNumber":80,"ayahNumber":12,"juzNumber":30,"pageNumber":585,"arabicText":"فَمَن شَآءَ ذَكَرَهُۥ","translationText":"и пусть помянет его всякий желающий."},{"key":"80:13","surahNumber":80,"ayahNumber":13,"juzNumber":30,"pageNumber":585,"arabicText":"فِى صُحُفٍۢ مُّكَرَّمَةٍۢ","translationText":"Оно записано в свитках почитаемых,"},{"key":"80:14","surahNumber":80,"ayahNumber":14,"juzNumber":30,"pageNumber":585,"arabicText":"مَّرْفُوعَةٍۢ مُّطَهَّرَةٍۭ","translationText":"вознесенных и очищенных,"},{"key":"80:15","surahNumber":80,"ayahNumber":15,"juzNumber":30,"pageNumber":585,"arabicText":"بِأَيْدِى سَفَرَةٍۢ","translationText":"в руках посланцев"},{"key":"80:16","surahNumber":80,"ayahNumber":16,"juzNumber":30,"pageNumber":585,"arabicText":"كِرَامٍۭ بَرَرَةٍۢ","translationText":"благородных и покорных."},{"key":"80:17","surahNumber":80,"ayahNumber":17,"juzNumber":30,"pageNumber":585,"arabicText":"قُتِلَ ٱلْإِنسَٰنُ مَآ أَكْفَرَهُۥ","translationText":"Да сгинет человек! Как же он неблагодарен!"},{"key":"80:18","surahNumber":80,"ayahNumber":18,"juzNumber":30,"pageNumber":585,"arabicText":"مِنْ أَىِّ شَىْءٍ خَلَقَهُۥ","translationText":"Из чего Он сотворил его?"},{"key":"80:19","surahNumber":80,"ayahNumber":19,"juzNumber":30,"pageNumber":585,"arabicText":"مِن نُّطْفَةٍ خَلَقَهُۥ فَقَدَّرَهُۥ","translationText":"Он сотворил его из капли и соразмерил (или предопределил стадии его развития),"},{"key":"80:20","surahNumber":80,"ayahNumber":20,"juzNumber":30,"pageNumber":585,"arabicText":"ثُمَّ ٱلسَّبِيلَ يَسَّرَهُۥ","translationText":"потом облегчил ему путь,"},{"key":"80:21","surahNumber":80,"ayahNumber":21,"juzNumber":30,"pageNumber":585,"arabicText":"ثُمَّ أَمَاتَهُۥ فَأَقْبَرَهُۥ","translationText":"потом умертвил его и поместил в могилу."},{"key":"80:22","surahNumber":80,"ayahNumber":22,"juzNumber":30,"pageNumber":585,"arabicText":"ثُمَّ إِذَا شَآءَ أَنشَرَهُۥ","translationText":"Потом, когда пожелает, Он воскресит его."},{"key":"80:23","surahNumber":80,"ayahNumber":23,"juzNumber":30,"pageNumber":585,"arabicText":"كَلَّا لَمَّا يَقْضِ مَآ أَمَرَهُۥ","translationText":"Но нет! Он не выполняет того, что Он приказал ему."},{"key":"80:24","surahNumber":80,"ayahNumber":24,"juzNumber":30,"pageNumber":585,"arabicText":"فَلْيَنظُرِ ٱلْإِنسَٰنُ إِلَىٰ طَعَامِهِۦٓ","translationText":"Пусть посмотрит человек на свое пропитание!"},{"key":"80:25","surahNumber":80,"ayahNumber":25,"juzNumber":30,"pageNumber":585,"arabicText":"أَنَّا صَبَبْنَا ٱلْمَآءَ صَبًّۭا","translationText":"Мы проливаем обильные ливни,"},{"key":"80:26","surahNumber":80,"ayahNumber":26,"juzNumber":30,"pageNumber":585,"arabicText":"ثُمَّ شَقَقْنَا ٱلْأَرْضَ شَقًّۭا","translationText":"затем рассекаем землю трещинами"},{"key":"80:27","surahNumber":80,"ayahNumber":27,"juzNumber":30,"pageNumber":585,"arabicText":"فَأَنۢبَتْنَا فِيهَا حَبًّۭا","translationText":"и взращиваем на ней зерна,"},{"key":"80:28","surahNumber":80,"ayahNumber":28,"juzNumber":30,"pageNumber":585,"arabicText":"وَعِنَبًۭا وَقَضْبًۭا","translationText":"виноград и люцерну,"},{"key":"80:29","surahNumber":80,"ayahNumber":29,"juzNumber":30,"pageNumber":585,"arabicText":"وَزَيْتُونًۭا وَنَخْلًۭا","translationText":"маслины и финиковые пальмы,"},{"key":"80:30","surahNumber":80,"ayahNumber":30,"juzNumber":30,"pageNumber":585,"arabicText":"وَحَدَآئِقَ غُلْبًۭا","translationText":"сады густые (или с могучими деревьями),"},{"key":"80:31","surahNumber":80,"ayahNumber":31,"juzNumber":30,"pageNumber":585,"arabicText":"وَفَٰكِهَةًۭ وَأَبًّۭا","translationText":"фрукты и травы"},{"key":"80:32","surahNumber":80,"ayahNumber":32,"juzNumber":30,"pageNumber":585,"arabicText":"مَّتَٰعًۭا لَّكُمْ وَلِأَنْعَٰمِكُمْ","translationText":"на пользу вам и вашей скотине."},{"key":"80:33","surahNumber":80,"ayahNumber":33,"juzNumber":30,"pageNumber":585,"arabicText":"فَإِذَا جَآءَتِ ٱلصَّآخَّةُ","translationText":"Когда же раздастся Оглушительный глас,"},{"key":"80:34","surahNumber":80,"ayahNumber":34,"juzNumber":30,"pageNumber":585,"arabicText":"يَوْمَ يَفِرُّ ٱلْمَرْءُ مِنْ أَخِيهِ","translationText":"в тот день человек бросит своего брата,"},{"key":"80:35","surahNumber":80,"ayahNumber":35,"juzNumber":30,"pageNumber":585,"arabicText":"وَأُمِّهِۦ وَأَبِيهِ","translationText":"свою мать и своего отца,"},{"key":"80:36","surahNumber":80,"ayahNumber":36,"juzNumber":30,"pageNumber":585,"arabicText":"وَصَٰحِبَتِهِۦ وَبَنِيهِ","translationText":"свою жену и своих сыновей,"},{"key":"80:37","surahNumber":80,"ayahNumber":37,"juzNumber":30,"pageNumber":585,"arabicText":"لِكُلِّ ٱمْرِئٍۢ مِّنْهُمْ يَوْمَئِذٍۢ شَأْنٌۭ يُغْنِيهِ","translationText":"ибо у каждого человека своих забот будет сполна."},{"key":"80:38","surahNumber":80,"ayahNumber":38,"juzNumber":30,"pageNumber":585,"arabicText":"وُجُوهٌۭ يَوْمَئِذٍۢ مُّسْفِرَةٌۭ","translationText":"В тот день одни лица будут сиять,"},{"key":"80:39","surahNumber":80,"ayahNumber":39,"juzNumber":30,"pageNumber":585,"arabicText":"ضَاحِكَةٌۭ مُّسْتَبْشِرَةٌۭ","translationText":"смеяться и ликовать."},{"key":"80:40","surahNumber":80,"ayahNumber":40,"juzNumber":30,"pageNumber":585,"arabicText":"وَوُجُوهٌۭ يَوْمَئِذٍ عَلَيْهَا غَبَرَةٌۭ","translationText":"На других же лицах в тот день будет прах,"},{"key":"80:41","surahNumber":80,"ayahNumber":41,"juzNumber":30,"pageNumber":585,"arabicText":"تَرْهَقُهَا قَتَرَةٌ","translationText":"покрывающий их мраком."},{"key":"80:42","surahNumber":80,"ayahNumber":42,"juzNumber":30,"pageNumber":585,"arabicText":"أُو۟لَٰٓئِكَ هُمُ ٱلْكَفَرَةُ ٱلْفَجَرَةُ","translationText":"Это будут неверующие грешники."}],"translationEditionUsed":"ru.kuliev"}