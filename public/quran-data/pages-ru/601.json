{"pageNumber":601,"juzNumber":30,"verses":[{"key":"103:1","surahNumber":103,"ayahNumber":1,"juzNumber":30,"pageNumber":601,"arabicText":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلْعَصْرِ","translationText":"Клянусь предвечерним временем (или временем)!"},{"key":"103:2","surahNumber":103,"ayahNumber":2,"juzNumber":30,"pageNumber":601,"arabicText":"إِنَّ ٱلْإِنسَٰنَ لَفِى خُسْرٍ","translationText":"Воистину, каждый человек в убытке,"},{"key":"103:3","surahNumber":103,"ayahNumber":3,"juzNumber":30,"pageNumber":601,"arabicText":"إِلَّا ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ وَتَوَاصَوْا۟ بِٱلْحَقِّ وَتَوَاصَوْا۟ بِٱلصَّبْرِ","translationText":"кроме тех, которые уверовали, совершали праведные деяния, заповедали друг другу истину и заповедали друг другу терпение!"},{"key":"104:1","surahNumber":104,"ayahNumber":1,"juzNumber":30,"pageNumber":601,"arabicText":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَيْلٌۭ لِّكُلِّ هُمَزَةٍۢ لُّمَزَةٍ","translationText":"Горе всякому хулителю и обидчику,"},{"key":"104:2","surahNumber":104,"ayahNumber":2,"juzNumber":30,"pageNumber":601,"arabicText":"ٱلَّذِى جَمَعَ مَالًۭا وَعَدَّدَهُۥ","translationText":"который копит состояние и пересчитывает его,"},{"key":"104:3","surahNumber":104,"ayahNumber":3,"juzNumber":30,"pageNumber":601,"arabicText":"يَحْسَبُ أَنَّ مَالَهُۥٓ أَخْلَدَهُۥ","translationText":"думая, что богатство увековечит его."},{"key":"104:4","surahNumber":104,"ayahNumber":4,"juzNumber":30,"pageNumber":601,"arabicText":"كَلَّا ۖ لَيُنۢبَذَنَّ فِى ٱلْحُطَمَةِ","translationText":"Но нет! Его непременно ввергнут в Огонь сокрушающий."},{"key":"104:5","surahNumber":104,"ayahNumber":5,"juzNumber":30,"pageNumber":601,"arabicText":"وَمَآ أَدْرَىٰكَ مَا ٱلْحُطَمَةُ","translationText":"Откуда ты мог знать, что такое Огонь сокрушающий?"},{"key":"104:6","surahNumber":104,"ayahNumber":6,"juzNumber":30,"pageNumber":601,"arabicText":"نَارُ ٱللَّهِ ٱلْمُوقَدَةُ","translationText":"Это - разожженный Огонь Аллаха,"},{"key":"104:7","surahNumber":104,"ayahNumber":7,"juzNumber":30,"pageNumber":601,"arabicText":"ٱلَّتِى تَطَّلِعُ عَلَى ٱلْأَفْـِٔدَةِ","translationText":"который вздымается над сердцами."},{"key":"104:8","surahNumber":104,"ayahNumber":8,"juzNumber":30,"pageNumber":601,"arabicText":"إِنَّهَا عَلَيْهِم مُّؤْصَدَةٌۭ","translationText":"Воистину, он сомкнется над ними"},{"key":"104:9","surahNumber":104,"ayahNumber":9,"juzNumber":30,"pageNumber":601,"arabicText":"فِى عَمَدٍۢ مُّمَدَّدَةٍۭ","translationText":"высокими столбами (мученики будут прикованы к этим столбам или врата Ада будут заперты и закреплены этими столбами)."},{"key":"105:1","surahNumber":105,"ayahNumber":1,"juzNumber":30,"pageNumber":601,"arabicText":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ أَلَمْ تَرَ كَيْفَ فَعَلَ رَبُّكَ بِأَصْحَٰبِ ٱلْفِيلِ","translationText":"Разве ты не видел, что сделал твой Господь с владельцами слона?"},{"key":"105:2","surahNumber":105,"ayahNumber":2,"juzNumber":30,"pageNumber":601,"arabicText":"أَلَمْ يَجْعَلْ كَيْدَهُمْ فِى تَضْلِيلٍۢ","translationText":"Разве Он не запутал их козни"},{"key":"105:3","surahNumber":105,"ayahNumber":3,"juzNumber":30,"pageNumber":601,"arabicText":"وَأَرْسَلَ عَلَيْهِمْ طَيْرًا أَبَابِيلَ","translationText":"и не наслал на них птиц стаями?"},{"key":"105:4","surahNumber":105,"ayahNumber":4,"juzNumber":30,"pageNumber":601,"arabicText":"تَرْمِيهِم بِحِجَارَةٍۢ مِّن سِجِّيلٍۢ","translationText":"Они бросали в них каменья из обожженной глины"},{"key":"105:5","surahNumber":105,"ayahNumber":5,"juzNumber":30,"pageNumber":601,"arabicText":"فَجَعَلَهُمْ كَعَصْفٍۢ مَّأْكُولٍۭ","translationText":"и превратили их в подобие изъеденных иссохших злаковых листьев."}],"translationEditionUsed":"ru.kuliev"}