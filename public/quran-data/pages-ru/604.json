{"pageNumber":604,"juzNumber":30,"verses":[{"key":"112:1","surahNumber":112,"ayahNumber":1,"juzNumber":30,"pageNumber":604,"arabicText":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ قُلْ هُوَ ٱللَّهُ أَحَدٌ","translationText":"Скажи: «Он - Аллах Единый,"},{"key":"112:2","surahNumber":112,"ayahNumber":2,"juzNumber":30,"pageNumber":604,"arabicText":"ٱللَّهُ ٱلصَّمَدُ","translationText":"Аллах Самодостаточный."},{"key":"112:3","surahNumber":112,"ayahNumber":3,"juzNumber":30,"pageNumber":604,"arabicText":"لَمْ يَلِدْ وَلَمْ يُولَدْ","translationText":"Он не родил и не был рожден,"},{"key":"112:4","surahNumber":112,"ayahNumber":4,"juzNumber":30,"pageNumber":604,"arabicText":"وَلَمْ يَكُن لَّهُۥ كُفُوًا أَحَدٌۢ","translationText":"и нет никого равного Ему»."},{"key":"113:1","surahNumber":113,"ayahNumber":1,"juzNumber":30,"pageNumber":604,"arabicText":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ قُلْ أَعُوذُ بِرَبِّ ٱلْفَلَقِ","translationText":"Скажи: «Прибегаю к защите Господа рассвета"},{"key":"113:2","surahNumber":113,"ayahNumber":2,"juzNumber":30,"pageNumber":604,"arabicText":"مِن شَرِّ مَا خَلَقَ","translationText":"от зла того, что Он сотворил,"},{"key":"113:3","surahNumber":113,"ayahNumber":3,"juzNumber":30,"pageNumber":604,"arabicText":"وَمِن شَرِّ غَاسِقٍ إِذَا وَقَبَ","translationText":"от зла мрака, когда он наступает,"},{"key":"113:4","surahNumber":113,"ayahNumber":4,"juzNumber":30,"pageNumber":604,"arabicText":"وَمِن شَرِّ ٱلنَّفَّٰثَٰتِ فِى ٱلْعُقَدِ","translationText":"от зла колдуний, поплевывающих на узлы,"},{"key":"113:5","surahNumber":113,"ayahNumber":5,"juzNumber":30,"pageNumber":604,"arabicText":"وَمِن شَرِّ حَاسِدٍ إِذَا حَسَدَ","translationText":"от зла завистника, когда он завидует»."},{"key":"114:1","surahNumber":114,"ayahNumber":1,"juzNumber":30,"pageNumber":604,"arabicText":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ قُلْ أَعُوذُ بِرَبِّ ٱلنَّاسِ","translationText":"Скажи: «Прибегаю к защите Господа людей,"},{"key":"114:2","surahNumber":114,"ayahNumber":2,"juzNumber":30,"pageNumber":604,"arabicText":"مَلِكِ ٱلنَّاسِ","translationText":"Царя людей,"},{"key":"114:3","surahNumber":114,"ayahNumber":3,"juzNumber":30,"pageNumber":604,"arabicText":"إِلَٰهِ ٱلنَّاسِ","translationText":"Бога людей,"},{"key":"114:4","surahNumber":114,"ayahNumber":4,"juzNumber":30,"pageNumber":604,"arabicText":"مِن شَرِّ ٱلْوَسْوَاسِ ٱلْخَنَّاسِ","translationText":"от зла искусителя отступающего (или сжимающегося) при поминании Аллаха,"},{"key":"114:5","surahNumber":114,"ayahNumber":5,"juzNumber":30,"pageNumber":604,"arabicText":"ٱلَّذِى يُوَسْوِسُ فِى صُدُورِ ٱلنَّاسِ","translationText":"который наущает в груди людей"},{"key":"114:6","surahNumber":114,"ayahNumber":6,"juzNumber":30,"pageNumber":604,"arabicText":"مِنَ ٱلْجِنَّةِ وَٱلنَّاسِ","translationText":"и бывает из джиннов и людей»."}],"translationEditionUsed":"ru.kuliev"}