{"pageNumber":451,"juzNumber":23,"verses":[{"key":"37:127","surahNumber":37,"ayahNumber":127,"juzNumber":23,"pageNumber":451,"arabicText":"فَكَذَّبُوهُ فَإِنَّهُمْ لَمُحْضَرُونَ","translationText":"Они сочли его лжецом, и все они непременно будут собраны в Аду,"},{"key":"37:128","surahNumber":37,"ayahNumber":128,"juzNumber":23,"pageNumber":451,"arabicText":"إِلَّا عِبَادَ ٱللَّهِ ٱلْمُخْلَصِينَ","translationText":"кроме избранных (или искренних) рабов Аллаха."},{"key":"37:129","surahNumber":37,"ayahNumber":129,"juzNumber":23,"pageNumber":451,"arabicText":"وَتَرَكْنَا عَلَيْهِ فِى ٱلْءَاخِرِينَ","translationText":"Мы оставили о нем в последующих поколениях добрую молву."},{"key":"37:130","surahNumber":37,"ayahNumber":130,"juzNumber":23,"pageNumber":451,"arabicText":"سَلَٰمٌ عَلَىٰٓ إِلْ يَاسِينَ","translationText":"Мир Ильясину (Ильясу, или семейству Йасина)!"},{"key":"37:131","surahNumber":37,"ayahNumber":131,"juzNumber":23,"pageNumber":451,"arabicText":"إِنَّا كَذَٰلِكَ نَجْزِى ٱلْمُحْسِنِينَ","translationText":"Воистину, так Мы воздаем творящим добро."},{"key":"37:132","surahNumber":37,"ayahNumber":132,"juzNumber":23,"pageNumber":451,"arabicText":"إِنَّهُۥ مِنْ عِبَادِنَا ٱلْمُؤْمِنِينَ","translationText":"Воистину, он - один из Наших верующих рабов."},{"key":"37:133","surahNumber":37,"ayahNumber":133,"juzNumber":23,"pageNumber":451,"arabicText":"وَإِنَّ لُوطًۭا لَّمِنَ ٱلْمُرْسَلِينَ","translationText":"Лут (Лот) также был одним из посланников."},{"key":"37:134","surahNumber":37,"ayahNumber":134,"juzNumber":23,"pageNumber":451,"arabicText":"إِذْ نَجَّيْنَٰهُ وَأَهْلَهُۥٓ أَجْمَعِينَ","translationText":"Мы спасли его и всю его семью,"},{"key":"37:135","surahNumber":37,"ayahNumber":135,"juzNumber":23,"pageNumber":451,"arabicText":"إِلَّا عَجُوزًۭا فِى ٱلْغَٰبِرِينَ","translationText":"кроме старухи, которая была в числе оставшихся позади."},{"key":"37:136","surahNumber":37,"ayahNumber":136,"juzNumber":23,"pageNumber":451,"arabicText":"ثُمَّ دَمَّرْنَا ٱلْءَاخَرِينَ","translationText":"Затем Мы уничтожили всех остальных."},{"key":"37:137","surahNumber":37,"ayahNumber":137,"juzNumber":23,"pageNumber":451,"arabicText":"وَإِنَّكُمْ لَتَمُرُّونَ عَلَيْهِم مُّصْبِحِينَ","translationText":"Вы проходите мимо них утром"},{"key":"37:138","surahNumber":37,"ayahNumber":138,"juzNumber":23,"pageNumber":451,"arabicText":"وَبِٱلَّيْلِ ۗ أَفَلَا تَعْقِلُونَ","translationText":"и вечером. Неужели вы не разумеете?"},{"key":"37:139","surahNumber":37,"ayahNumber":139,"juzNumber":23,"pageNumber":451,"arabicText":"وَإِنَّ يُونُسَ لَمِنَ ٱلْمُرْسَلِينَ","translationText":"Йунус (Иона) также был одним из посланников."},{"key":"37:140","surahNumber":37,"ayahNumber":140,"juzNumber":23,"pageNumber":451,"arabicText":"إِذْ أَبَقَ إِلَى ٱلْفُلْكِ ٱلْمَشْحُونِ","translationText":"Он сбежал на переполненный корабль."},{"key":"37:141","surahNumber":37,"ayahNumber":141,"juzNumber":23,"pageNumber":451,"arabicText":"فَسَاهَمَ فَكَانَ مِنَ ٱلْمُدْحَضِينَ","translationText":"Он бросил жребий вместе с другими и оказался проигравшим."},{"key":"37:142","surahNumber":37,"ayahNumber":142,"juzNumber":23,"pageNumber":451,"arabicText":"فَٱلْتَقَمَهُ ٱلْحُوتُ وَهُوَ مُلِيمٌۭ","translationText":"Его проглотила рыба, когда он был достоин порицания."},{"key":"37:143","surahNumber":37,"ayahNumber":143,"juzNumber":23,"pageNumber":451,"arabicText":"فَلَوْلَآ أَنَّهُۥ كَانَ مِنَ ٱلْمُسَبِّحِينَ","translationText":"Если бы он не был одним из прославляющих Аллаха,"},{"key":"37:144","surahNumber":37,"ayahNumber":144,"juzNumber":23,"pageNumber":451,"arabicText":"لَلَبِثَ فِى بَطْنِهِۦٓ إِلَىٰ يَوْمِ يُبْعَثُونَ","translationText":"то непременно остался бы в ее чреве до того дня, когда они будут воскрешены."},{"key":"37:145","surahNumber":37,"ayahNumber":145,"juzNumber":23,"pageNumber":451,"arabicText":"۞ فَنَبَذْنَٰهُ بِٱلْعَرَآءِ وَهُوَ سَقِيمٌۭ","translationText":"Мы выбросили его на открытую местность, и он был болен."},{"key":"37:146","surahNumber":37,"ayahNumber":146,"juzNumber":23,"pageNumber":451,"arabicText":"وَأَنۢبَتْنَا عَلَيْهِ شَجَرَةًۭ مِّن يَقْطِينٍۢ","translationText":"Мы взрастили над ним (или возле него) тыкву."},{"key":"37:147","surahNumber":37,"ayahNumber":147,"juzNumber":23,"pageNumber":451,"arabicText":"وَأَرْسَلْنَٰهُ إِلَىٰ مِا۟ئَةِ أَلْفٍ أَوْ يَزِيدُونَ","translationText":"Мы отправили его к ста тысячам или даже больше того."},{"key":"37:148","surahNumber":37,"ayahNumber":148,"juzNumber":23,"pageNumber":451,"arabicText":"فَـَٔامَنُوا۟ فَمَتَّعْنَٰهُمْ إِلَىٰ حِينٍۢ","translationText":"Они уверовали, и Мы позволили им пользоваться благами до определенного времени."},{"key":"37:149","surahNumber":37,"ayahNumber":149,"juzNumber":23,"pageNumber":451,"arabicText":"فَٱسْتَفْتِهِمْ أَلِرَبِّكَ ٱلْبَنَاتُ وَلَهُمُ ٱلْبَنُونَ","translationText":"Спроси их, почему это у твоего Господа дочери, а у них - сыновья?"},{"key":"37:150","surahNumber":37,"ayahNumber":150,"juzNumber":23,"pageNumber":451,"arabicText":"أَمْ خَلَقْنَا ٱلْمَلَٰٓئِكَةَ إِنَٰثًۭا وَهُمْ شَٰهِدُونَ","translationText":"Или же Мы сотворили ангелов женщинами, и они присутствовали при этом?"},{"key":"37:151","surahNumber":37,"ayahNumber":151,"juzNumber":23,"pageNumber":451,"arabicText":"أَلَآ إِنَّهُم مِّنْ إِفْكِهِمْ لَيَقُولُونَ","translationText":"Воистину, по своей лживости они говорят:"},{"key":"37:152","surahNumber":37,"ayahNumber":152,"juzNumber":23,"pageNumber":451,"arabicText":"وَلَدَ ٱللَّهُ وَإِنَّهُمْ لَكَٰذِبُونَ","translationText":"«Аллах родил». Воистину, они - лжецы."},{"key":"37:153","surahNumber":37,"ayahNumber":153,"juzNumber":23,"pageNumber":451,"arabicText":"أَصْطَفَى ٱلْبَنَاتِ عَلَى ٱلْبَنِينَ","translationText":"Неужели Он избрал дочерей и возвысил их над сыновьями?"}],"translationEditionUsed":"ru.kuliev"}