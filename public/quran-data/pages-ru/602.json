{"pageNumber":602,"juzNumber":30,"verses":[{"key":"106:1","surahNumber":106,"ayahNumber":1,"juzNumber":30,"pageNumber":602,"arabicText":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ لِإِيلَٰفِ قُرَيْشٍ","translationText":"Ради единения курейшитов,"},{"key":"106:2","surahNumber":106,"ayahNumber":2,"juzNumber":30,"pageNumber":602,"arabicText":"إِۦلَٰفِهِمْ رِحْلَةَ ٱلشِّتَآءِ وَٱلصَّيْفِ","translationText":"единения их во время зимних и летних поездок."},{"key":"106:3","surahNumber":106,"ayahNumber":3,"juzNumber":30,"pageNumber":602,"arabicText":"فَلْيَعْبُدُوا۟ رَبَّ هَٰذَا ٱلْبَيْتِ","translationText":"Пусть же они поклоняются Господу этого Дома (Каабы),"},{"key":"106:4","surahNumber":106,"ayahNumber":4,"juzNumber":30,"pageNumber":602,"arabicText":"ٱلَّذِىٓ أَطْعَمَهُم مِّن جُوعٍۢ وَءَامَنَهُم مِّنْ خَوْفٍۭ","translationText":"Который накормил их после голода и избавил их от страха."},{"key":"107:1","surahNumber":107,"ayahNumber":1,"juzNumber":30,"pageNumber":602,"arabicText":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ أَرَءَيْتَ ٱلَّذِى يُكَذِّبُ بِٱلدِّينِ","translationText":"Видел ли ты того, кто считает ложью воздаяние?"},{"key":"107:2","surahNumber":107,"ayahNumber":2,"juzNumber":30,"pageNumber":602,"arabicText":"فَذَٰلِكَ ٱلَّذِى يَدُعُّ ٱلْيَتِيمَ","translationText":"Это - тот, кто гонит сироту"},{"key":"107:3","surahNumber":107,"ayahNumber":3,"juzNumber":30,"pageNumber":602,"arabicText":"وَلَا يَحُضُّ عَلَىٰ طَعَامِ ٱلْمِسْكِينِ","translationText":"и не побуждает накормить бедняка."},{"key":"107:4","surahNumber":107,"ayahNumber":4,"juzNumber":30,"pageNumber":602,"arabicText":"فَوَيْلٌۭ لِّلْمُصَلِّينَ","translationText":"Горе молящимся,"},{"key":"107:5","surahNumber":107,"ayahNumber":5,"juzNumber":30,"pageNumber":602,"arabicText":"ٱلَّذِينَ هُمْ عَن صَلَاتِهِمْ سَاهُونَ","translationText":"которые небрежны к своим намазам,"},{"key":"107:6","surahNumber":107,"ayahNumber":6,"juzNumber":30,"pageNumber":602,"arabicText":"ٱلَّذِينَ هُمْ يُرَآءُونَ","translationText":"которые лицемерят"},{"key":"107:7","surahNumber":107,"ayahNumber":7,"juzNumber":30,"pageNumber":602,"arabicText":"وَيَمْنَعُونَ ٱلْمَاعُونَ","translationText":"и отказывают даже в мелочи!"},{"key":"108:1","surahNumber":108,"ayahNumber":1,"juzNumber":30,"pageNumber":602,"arabicText":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ إِنَّآ أَعْطَيْنَٰكَ ٱلْكَوْثَرَ","translationText":"Мы даровали тебе аль-Каусар (бесчисленные блага, в том числе одноименную реку в Раю)."},{"key":"108:2","surahNumber":108,"ayahNumber":2,"juzNumber":30,"pageNumber":602,"arabicText":"فَصَلِّ لِرَبِّكَ وَٱنْحَرْ","translationText":"Посему совершай намаз ради своего Господа и закалывай жертву."},{"key":"108:3","surahNumber":108,"ayahNumber":3,"juzNumber":30,"pageNumber":602,"arabicText":"إِنَّ شَانِئَكَ هُوَ ٱلْأَبْتَرُ","translationText":"Воистину, твой ненавистник сам окажется безвестным."}],"translationEditionUsed":"ru.kuliev"}