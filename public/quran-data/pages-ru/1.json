{"pageNumber":1,"juzNumber":1,"verses":[{"key":"1:1","surahNumber":1,"ayahNumber":1,"juzNumber":1,"pageNumber":1,"arabicText":"﻿بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ","translationText":"Во имя Аллаха, Милостивого, Милосердного!"},{"key":"1:2","surahNumber":1,"ayahNumber":2,"juzNumber":1,"pageNumber":1,"arabicText":"ٱلْحَمْدُ لِلَّهِ رَبِّ ٱلْعَٰلَمِينَ","translationText":"Хвала Аллаху, Господу миров,"},{"key":"1:3","surahNumber":1,"ayahNumber":3,"juzNumber":1,"pageNumber":1,"arabicText":"ٱلرَّحْمَٰنِ ٱلرَّحِيمِ","translationText":"Милостивому, Милосердному,"},{"key":"1:4","surahNumber":1,"ayahNumber":4,"juzNumber":1,"pageNumber":1,"arabicText":"مَٰلِكِ يَوْمِ ٱلدِّينِ","translationText":"Властелину Дня воздаяния!"},{"key":"1:5","surahNumber":1,"ayahNumber":5,"juzNumber":1,"pageNumber":1,"arabicText":"إِيَّاكَ نَعْبُدُ وَإِيَّاكَ نَسْتَعِينُ","translationText":"Тебе одному мы поклоняемся и Тебя одного молим о помощи."},{"key":"1:6","surahNumber":1,"ayahNumber":6,"juzNumber":1,"pageNumber":1,"arabicText":"ٱهْدِنَا ٱلصِّرَٰطَ ٱلْمُسْتَقِيمَ","translationText":"Веди нас прямым путем,"},{"key":"1:7","surahNumber":1,"ayahNumber":7,"juzNumber":1,"pageNumber":1,"arabicText":"صِرَٰطَ ٱلَّذِينَ أَنْعَمْتَ عَلَيْهِمْ غَيْرِ ٱلْمَغْضُوبِ عَلَيْهِمْ وَلَا ٱلضَّآلِّينَ","translationText":"путем тех, кого Ты облагодетельствовал, не тех, на кого пал гнев, и не заблудших."}],"translationEditionUsed":"ru.kuliev"}